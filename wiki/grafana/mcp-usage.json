{
  "__inputs": [
    {
      "name": "DS_PROM",
      "label": "Metrics (Mimir/Prometheus)",
      "description": "The Prometheus-compatible datasource holding the oa_mcp_* series (Mimir).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "OpenAgenda MCP — per-tool usage from the server's own OTel metrics (oa_mcp_*). Import and pick the Mimir datasource. Series names follow the OTLP→Prometheus convention; verify against the live series after the first deploy.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["openagenda", "mcp"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "OpenAgenda MCP — usage",
  "uid": "oa-mcp-usage",
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${DS_PROM}",
        "query": "label_values(oa_mcp_execute_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "label": "Instance"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "execute — calls/s by outcome",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "sum by (outcome) (rate(oa_mcp_execute_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "execute — error ratio (non-ok)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "sum(rate(oa_mcp_execute_total{instance=~\"$instance\",outcome!=\"ok\"}[5m])) / clamp_min(sum(rate(oa_mcp_execute_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "execute — in flight",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "sum(oa_mcp_concurrency_inflight{instance=~\"$instance\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "execute — latency (ms)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(oa_mcp_execute_duration_milliseconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_execute_duration_milliseconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(oa_mcp_execute_duration_milliseconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "warm-pool — hit ratio & idle spares",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "hit ratio" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "sum(rate(oa_mcp_warm_pool_hits_total{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(oa_mcp_warm_pool_hits_total{instance=~\"$instance\"}[5m])) + sum(rate(oa_mcp_warm_pool_misses_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "hit ratio",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "sum(oa_mcp_warm_pool_idle{instance=~\"$instance\"})",
          "legendFormat": "idle spares",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "search_docs — calls/s",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
          "expr": "sum(rate(oa_mcp_search_docs_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "search_docs",
          "refId": "A"
        }
      ]
    }
  ]
}
