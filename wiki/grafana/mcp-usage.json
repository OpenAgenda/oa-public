{
  "__inputs": [
    {
      "name": "DS_PROM",
      "label": "Metrics (Mimir/Prometheus)",
      "description": "The Prometheus-compatible datasource holding the oa_mcp_* series (Mimir).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "OpenAgenda MCP — per-tool usage from the server's own OTel metrics (oa_mcp_*). Import and pick the Mimir datasource. Series names follow the OTLP→Prometheus convention; verify against the live series after the first deploy.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["openagenda", "mcp"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "title": "OpenAgenda MCP — usage",
  "uid": "oa-mcp-usage",
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${DS_PROM}",
        "query": "label_values(oa_mcp_execute_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "label": "Instance"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "execute — calls/s by outcome",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum by (outcome) (rate(oa_mcp_execute_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "execute — failure ratio (real failures)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_execute_total{instance=~\"$instance\",outcome=~\"threw|timed_out|nonzero_exit|credential_error|output_capped\"}[5m])) / clamp_min(sum(rate(oa_mcp_execute_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "execute — in flight",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(oa_mcp_concurrency_inflight{instance=~\"$instance\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "execute — latency (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(oa_mcp_execute_duration_milliseconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_execute_duration_milliseconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(oa_mcp_execute_duration_milliseconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "warm-pool — hit ratio & idle spares",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "hit ratio"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_warm_pool_hits_total{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(oa_mcp_warm_pool_hits_total{instance=~\"$instance\"}[5m])) + sum(rate(oa_mcp_warm_pool_misses_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "hit ratio",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(oa_mcp_warm_pool_idle{instance=~\"$instance\"})",
          "legendFormat": "idle spares",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "search_docs — calls/s",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_search_docs_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "search_docs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "µVM host RAM peak (real footprint / µVM)",
      "description": "Peak host RAM per µVM = the libkrun VMM's VmHWM (incl. VMM + guest kernel + touched pages). The REAL per-µVM host cost — concurrency × this sizes the host. NOT the OA_SANDBOX_MEMORY_MB cap, which is a demand-paged ceiling, not a reservation.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(oa_mcp_uvm_host_peak_bytes_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_uvm_host_peak_bytes_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(oa_mcp_uvm_host_peak_bytes_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "µVM workload memory peak — touched above boot",
      "description": "Peak host RAM above the runtime's boot baseline ≈ memory the run's guest workload actually touched (≈ the in-VM cost). Compares runtimes / spots heavy executes; for runtime/cap tuning, read together with the host-peak panel.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(oa_mcp_uvm_workload_peak_bytes_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_uvm_workload_peak_bytes_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "µVM CPU per run (seconds)",
      "description": "Per-µVM CPU time from the libkrun VMM's utime+stime (cumulative → accurate even for sub-150ms runs, unlike sb.metrics() cpu% which reads 0). cpu = total (boot + run); workload = above the boot baseline. CPU is the VPS bottleneck — concurrency × this sizes vCPUs.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_uvm_cpu_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "total p95",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_uvm_workload_cpu_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "workload p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(oa_mcp_uvm_workload_cpu_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "workload p50",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "concurrency — rejections/s by reason",
      "description": "execute runs the concurrency guard refused before they ran (the run never started — a retryable busy for the client). queue_full = instantaneous burst over the cap+queue; timeout = sustained overload (waited the full queue timeout); shutting_down = drained at shutdown. Sustained queue_full/timeout means OA_MAX_CONCURRENCY/queue is undersized for the load.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum by (reason) (rate(oa_mcp_concurrency_rejected_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "warm-pool — churn (created / failed / expired) /s",
      "description": "Warm µVM pool health (microsandbox + pooling on). created = spares booted; failed = spare boots that failed (rising = the image/host can't keep spares warm — expect more inline misses); expired = spares evicted past their TTL before use (rising with a low hit ratio = spares idle out faster than calls arrive, so the pool size is larger than the traffic needs).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_warm_pool_created_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_warm_pool_failed_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "failed",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_warm_pool_expired_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "expired",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "execute — backpressure ratio (caps/limits engaging, not failures)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_execute_total{instance=~\"$instance\",outcome=~\"caller_busy|rate_limited|busy|shutting_down|disabled\"}[5m])) / clamp_min(sum(rate(oa_mcp_execute_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "backpressure (total)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_execute_total{instance=~\"$instance\",outcome=\"caller_busy\"}[5m])) / clamp_min(sum(rate(oa_mcp_execute_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "caller_cap",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "caller concurrency at admission (runs the caller already held)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "sum(rate(oa_mcp_caller_concurrency_at_admission_sum{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(oa_mcp_caller_concurrency_at_admission_count{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "mean held at admission",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oa_mcp_caller_concurrency_at_admission_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    }
  ]
}
