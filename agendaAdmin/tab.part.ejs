<li class="menu-item js_menu_item <%= 'js_menu_item_' + t.key %> <% if ( tab==t.key ) { %> selected<% } %>">
  <a class="<% if ( tab==t.key ) { %> active<% } %>" href="<%= genUrl( t.uri, { slug: agenda.slug } ) + (t.suffix || '') %>">
<% if ( t.key === 'locations' ) { %>
    <span><%= t.label %></span>
    <span class="js_locations_counter" data-options="<%= JSON.stringify( {
      res: genUrl( 'locationToVerifyCount', { slug: agenda.slug } )
    } ) %>"></span>
<% } else { %>
    <span><%= t.label %></span>
<% } %>
  </a>
<% if ( typeof t.badge !== 'undefined' ) { %>
  <a class="badge badge-primary" href="<%= t.badge.link %>" target="_blank">
    <%= t.badge.label %>
  </a>
<% } %>
</li>