<li class="menu-item js_menu_item <% if ( tab==t.key ) { %> selected<% } %>">
  <a class="<% if ( tab==t.key ) { %> active<% } %>" href="<%= genUrl( t.uri, { slug: agenda.slug } ) %>">
<% if ( t.key === 'locations' ) { %>
    <span><%= t.label %></span>
    <span class="js_locations_counter" data-options="<%= JSON.stringify( {
      res: genUrl( 'locationToVerifyCount', { slug: agenda.slug } )
    } ) %>"></span>
<% } else { %>
    <span><%= t.label %></span>
<% } %>
  </a>
</li>