<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="shortcut icon" href="/images/favicon.ico"/>
    <link href='https://fonts.googleapis.com/css?family=Roboto:400,300,700' rel='stylesheet' type='text/css'>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="language" content="<%= lang %>"/>
    <% if ( metas.title ) { %>
    <title><%- __( metas.title ) %></title>
    <% } %>
    <% include ../layout/metas.part.ejs %>
    <% include ../layout/css.part.ejs %>
    <% include ../layout/js.part.ejs %>

    <!--[if lt IE 9]>
    <script src="https://oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"></script>
    <![endif]-->
    <script type="text/javascript">window.templates = 'bs';</script>
</head>
<body
        <% if ( pageId ) { %>
        id="<%= pageId %>"
        <% } %>
        class="<% if ( pageClass ) { %> <%= pageClass %> <% } %>js_toggle"
        data-options="<%- typeof scriptParams !== 'undefined' ? _esc( JSON.stringify( scriptParams ) ) : '' %>">
<div id="outdated"></div>
<nav class="corpo-header navbar navbar-default navbar-static-top">
    <div class="container">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle collapsed" data-toggle="collapse"
                    data-target="#bs-navbar-collapse" aria-expanded="false">
                <i class="fa fa-bars"></i>
            </button>
            <a class="navbar-brand" href="/">
                <div class="logo"></div>
            </a>
        </div>
        <div class="navbar-collapse collapse" id="bs-navbar-collapse" aria-expanded="false">
            <ul class="nav navbar-nav navbar-left">
                <li><a href="#fonctions"><%= __( 'layoutFunctions' ) %></a></li>
                <li><a href="#tarifs"><%= __( 'layoutPricing' ) %></a></li>
                <li><a href="#testimonials"><%= __( 'layoutTestimonials' ) %></a></li>
            </ul>
            <ul class="nav navbar-nav navbar-right">
                <li class="signin"><a href="<%= genUrl( 'start', { a: 'header_signin' } ) %>"><%= __( 'layoutSignin' ) %></a></li>
                <li class="signup"><a href="<%= genUrl( 'start', { a: 'header_signup' } ) %>"><%= __( 'layoutSignup' ) %></a></li>
                <li class="tel">
                    <p class="navbar-btn">
                        <a href="tel:+33176350143" class="btn btn-default">
                            <i class="fa fa-phone" aria-hidden="true"></i>&nbsp;&nbsp;+33 1 76 35 01 43
                        </a>
                    </p>
                </li>
                <li class="language-menu">
                    <a href="#" data-toggle="dropdown"><%= lang %> <i class="fa fa-angle-down"></i></a>
                    <ul class="dropdown-menu">
                        <% [ 'fr', 'en' ].forEach( function( l ) { %>
                        <% if ( lang == l ) { %>
                        <li>
                            <a href="?lang=<%= l %>" hreflang="<%= l %>" class="selected">
                                <%= langLabels[ l ] %> - <%= l.toUpperCase() %>
                            </a>
                        </li>
                        <% } else { %>
                        <li>
                            <a rel="alternate" href="?lang=<%= l %>" hreflang="<%= l %>">
                                <%= langLabels[ l ] %> - <%= l.toUpperCase() %>
                            </a>
                        </li>
                        <% } %>
                        <% } ); %>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav><!-- content --><% include mainBottom.ejs %>