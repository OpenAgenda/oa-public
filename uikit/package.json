{
  "name": "@openagenda/uikit",
  "version": "0.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa-public.git"
  },
  "homepage": "https://github.com/OpenAgenda/oa-public",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "postinstall": "chakra typegen src/theme/index.ts",
    "sb": "storybook dev",
    "start": "yarn sb",
    "prepack": "tsdown"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/theme/index.d.mts",
        "default": "./dist/theme/index.mjs"
      },
      "require": {
        "types": "./dist/theme/index.d.cts",
        "default": "./dist/theme/index.cjs"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/components/index.d.mts",
        "default": "./dist/components/index.mjs"
      },
      "require": {
        "types": "./dist/components/index.d.cts",
        "default": "./dist/components/index.cjs"
      }
    },
    "./snippets": {
      "import": {
        "types": "./dist/snippets/index.d.mts",
        "default": "./dist/snippets/index.mjs"
      },
      "require": {
        "types": "./dist/snippets/index.d.cts",
        "default": "./dist/snippets/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "dependencies": {
    "@chakra-ui/cli": "^3.34.0",
    "@chakra-ui/react": "^3.34.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "react-icons": "^5.5.0",
    "react-remove-scroll": "^2.7.1"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^2.1.0",
    "@openagenda/tsconfig": "^0.0.0",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "storybook": "^10.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  }
}
