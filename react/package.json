{
  "name": "@openagenda/react",
  "version": "0.0.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa-public.git"
  },
  "homepage": "https://github.com/OpenAgenda/oa-public",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "sb": "storybook dev",
    "start": "yarn sb",
    "prepack": "oa-intl compile --esm -o 'src/locales/compiled/%lang%.json' && tsdown",
    "extract-messages": "oa-intl --esm --compiled 'src/locales/compiled/%lang%.json'"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/components/index.d.mts",
        "default": "./dist/components/index.mjs"
      },
      "require": {
        "types": "./dist/components/index.d.cts",
        "default": "./dist/components/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks/index.d.mts",
        "default": "./dist/hooks/index.mjs"
      },
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^6.6.0",
    "@fortawesome/free-regular-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.3",
    "@openagenda/common-labels": "^2.0.0",
    "@openagenda/mails": "^6.0.1",
    "@openagenda/react-filters": "^2.13.7",
    "@openagenda/react-shared": "^3.0.0",
    "@openagenda/uikit": "^0.1.0",
    "base64-js": "^1.5.1",
    "ky": "^1.7.2",
    "lodash": "^4.17.21",
    "qs": "^6.11.0",
    "react-intersection-observer": "^9.16.0",
    "react-intl": "^10.1.1",
    "react-use": "^17.6.0",
    "swr": "^2.1.1"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^2.0.0",
    "@openagenda/intl": "^2.0.0",
    "@openagenda/tsconfig": "^0.0.0",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "@types/lodash": "^4",
    "@types/qs": "^6",
    "msw": "^2.3.0",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "storybook": "^10.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  },
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  }
}
