{
  "extends": "@openagenda",

  "parserOptions": {
    "sourceType": "script"
  },

  "ignorePatterns": [
    "client/build"
  ],

  "rules": {
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "test/**/*.js",
          "testconfig.sample.js",
          "stories/**/*.js"
        ]
      }
    ]
  },

  "overrides": [
    {
      "files": [
        "client/src/**/*.js",
        "dev/client/**/*.js",
        "stories/**/*.js"
      ],
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ]
}
