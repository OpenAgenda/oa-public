      },
      "description": {
        "fr": "32e édition du festival des Journées de la BD !",
        "en": "32nd edition of the Journées de la BD festival!"
      },
      "longDescription": {
        "fr": "Vous pourrez échanger avec une quarantaine d'auteurs réunis autour de Frank Margerin.",
        "en": "You will be able to exchange with some forty authors gathered around Frank Margerin."
      },
      "keywords": {},
      "conditions": {},
