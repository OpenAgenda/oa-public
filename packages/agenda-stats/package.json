{
  "name": "@openagenda/agenda-stats",
  "version": "1.10.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa.git"
  },
  "main": "dist/app.js",
  "scripts": {
    "start": "NODE_ENV=development start-storybook -p 9001",
    "build": "babel --copy-files src -d dist -s",
    "clean": "rimraf dist",
    "prepack": "yarn clean && yarn oa-intl compile && yarn build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged",
    "extract-messages": "yarn oa-intl"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.13.17",
    "@emotion/react": "^11.1.5",
    "@openagenda/event-search": "^2.8.0",
    "@openagenda/intl": "^1.1.2",
    "@openagenda/react-filters": "^2.8.2",
    "@openagenda/react-shared": "^2.4.0",
    "classnames": "^2.3.1",
    "core-js": "^3.10.2",
    "date-fns": "^2.11.1",
    "distinct-colors": "^2.1.0",
    "final-form": "^4.20.2",
    "lodash": "^4.17.15",
    "qs": "^6.9.1",
    "react-beautiful-dnd": "^13.0.0",
    "react-content-loader": "^5.1.0",
    "react-date-range": "^1.1.3",
    "react-final-form": "^6.5.3",
    "react-intl": "^5.12.2",
    "react-query": "^3.6.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "react-uid": "^2.3.0",
    "react-use": "^15.3.4",
    "recharts": "^2.0.0-beta.6",
    "redial": "^0.5.0",
    "uuid": "^8.2.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/core": "^7.13.16",
    "@emotion/babel-preset-css-prop": "^11.2.0",
    "@loadable/babel-plugin": "^5.13.2",
    "@loadable/component": "^5.14.1",
    "@openagenda/babel-preset": "^1.4.1",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/eslint-config": "^1.3.1",
    "@storybook/react": "^6.2.8",
    "babel-loader": "^8.2.2",
    "eslint": "^6.8.0",
    "history": "^4.10.1",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^5.1.2",
    "redux": "^4.0.5",
    "rimraf": "^3.0.1",
    "webpack": "^5.53.0"
  },
  "peerDependencies": {
    "@loadable/component": "^5.12.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router": "^5.0.0",
    "react-router-dom": "^5.0.0",
    "redux": "^4.0.5"
  }
