{
  "name": "@openagenda/agenda-stats",
  "version": "1.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/openagenda/oa.git"
  },
  "main": "dist/app.js",
  "scripts": {
    "start": "NODE_ENV=development start-storybook -p 9001",
    "build": "babel --copy-files src -d dist -s",
    "clean": "rimraf dist",
    "prepack": "yarn clean && yarn build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged",
    "extract-messages": "yarn oa:extract-messages --messages-pattern 'dist/messages/**/*.json'"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.8.4",
    "@emotion/core": "^10.0.28",
    "@openagenda/react-components": "^2.3.2",
    "@openagenda/react-shared": "^2.0.0",
    "@openagenda/react-utils": "^4.1.1",
    "classnames": "^2.2.6",
    "core-js": "^3.6.4",
    "date-fns": "^2.11.1",
    "distinct-colors": "^2.1.0",
    "lodash": "^4.17.15",
    "qs": "^6.9.1",
    "react-date-range": "^1.0.3",
    "react-hot-loader": "^4.12.20",
    "react-intl": "^3.11.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "recharts": "^2.0.0-beta.4",
    "redial": "^0.5.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.8.4",
    "@emotion/babel-preset-css-prop": "^10.0.27",
    "@loadable/babel-plugin": "^5.12.0",
    "@loadable/component": "^5.12.0",
    "@openagenda/babel-preset": "^1.3.1",
    "@openagenda/bs-templates": "^2.4.2",
    "@openagenda/eslint-config": "^1.0.2",
    "@storybook/react": "^5.3.9",
    "babel-loader": "^8.0.6",
    "eslint": "^6.8.0",
    "final-form": "^4.19.1",
    "history": "^4.10.1",
    "jest": "^25.1.0",
    "lint-staged": "^10.0.7",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-router-dom": "^5.1.2",
    "redux": "^4.0.5",
    "rimraf": "^3.0.1",
    "webpack": "^4.41.5"
  },
  "peerDependencies": {
    "@loadable/component": "^5.12.0",
    "final-form": "^4.18.5",
    "react": "^16.12.0",
    "react-router": "^5.0.0",
    "react-router-dom": "^5.0.0",
    "redux": "^4.0.5"
  }
}
