{
  "id" : {
    "type" : "number",
    "server" : true
  },
  "uid" : {
    "type" : "number",
    "optional" : false,
    "server" : true
  },
  "slug" : {
    "type" : "slug",
    "optional" : false,
    "min" : 1
  },
  "ownerUid" : {
    "type" : "number",
    "server" : true
  },
  "agendaUid" : {
    "type" : "number",
    "server" : true
  },
  "locationUid" : {
    "type" : "number"
  },
  "title" : {
    "type" : "multilingual",
    "min" : 1,
    "max" : 140,
    "optional" : false
  },
  "description" : {
    "type" : "multilingual",
    "max" : 255
  },
  "longDescription" : {
    "type" : "multilingual",
    "max" : 10000
  },
  "keywords" : {
    "type" : "multilingual",
    "max" : 255
  },
  "registration" : {
    "type" : "list",
    "default" : [],
    "types" : [ "phone", "link", "email" ]
  },
  "conditions" : {
    "type" : "multilingual",
    "max" : 255
  },
  "image" : {
    "filename" : {
      "type" : "string",
      "max" : 255
    },
    "credits" : {
      "type" : "string",
      "max" : 255
    },
    "size" : {
      "height" : {
        "type" : "number"
      },
      "width" : {
        "type" : "number"
      }
    },
    "variants" : {
      "list" : true,
      "fields" : {
        "type" : {
          "type" : "string"
        },
        "filename" : {
          "type" : "string",
          "max" : 255
        },
        "size" : {
          "height" : {
            "type" : "number"
          },
          "width" : {
            "type" : "number"
          }
        }
      }
    }
  },
  "draft" : {
    "type" : "boolean",
    "default" : true
  },
  "private" : {
    "type" : "boolean",
    "default" : false,
    "server" : true
  },
  "accessibility" : {
    "mi" : {
      "type" : "boolean",
      "default" : false
    },
    "hi" : {
      "type" : "boolean",
      "default" : false
    },
    "pi" : {
      "type" : "boolean",
      "default" : false
    },
    "vi" : {
      "type" : "boolean",
      "default" : false
    },
    "sl" : {
      "type" : "boolean",
      "default" : false
    }
  },
  "timezone" : {
    "type" : "text",
    "default" : "Europe/Paris",
    "min" : 3,
    "max" : 255
  },
  "timings" : {
    "list" : true,
    "fields" : {
      "begin" : {
        "type" : "date",
        "optional" : false
      },
      "end" : {
        "type" : "date",
        "optional" : false
      }
    }
  },
  "age" : {
    "min" : {
      "type" : "number",
      "min" : 0
    },
    "max" : {
      "type" : "number",
      "max" : 122
    }
  },
  "updatedAt" : {
    "type" : "date",
    "optional" : false
  },
  "createdAt" : {
    "type" : "date",
    "optional" : false
  }
}