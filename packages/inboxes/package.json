    "ajv": "^5.2.2",
    "ajv-errors": "^1.0.0",
    "ajv-keywords": "^2.1.0",
    "axios": "^0.19.0",
    "core-js": "^3.6.5",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "mime-types": "^2.1.25",
    "mysql": "^2.14.1",
    "redis": "^2.8.0",
    "regenerator-runtime": "^0.13.5",
