    "@openagenda/babel-preset": "^1.3.8",
    "@openagenda/eslint-config": "^1.2.4",
    "@openagenda/fixtures": "^2.0.2",
    "babel-jest": "^26.6.3",
    "eslint": "^6.8.0",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "prettier-eslint-cli": "^5.0.0",
    "rimraf": "^3.0.1"
  }
