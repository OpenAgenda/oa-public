  "description": "The inbox service provides functionality enabling users to exchange messages stored in conversations.",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/openagenda/oa.git"
  },
  "homepage": "https://bitbucket.org/openagenda/oa/src/master/packages/inboxes",
  "main": "dist/index.js",
  "directories": {
    "lib": "dist"
  },
  "scripts": {
    "build": "babel --copy-files src -d dist -s",
    "test": "jest --forceExit --detectOpenHandles",
    "clean": "rimraf dist",
    "prepack": "yarn clean && yarn build",
    "lint": "eslint -c .eslintrc '**/*.js'",
