{
  "presets": [
    "stage-0",
    [
      "env",
      {
        "targets": {
          "browsers": [
            "last 2 versions",
            "Firefox >= 24",
            "Chrome >= 33",
            "Safari >= 9",
            "IE >= 10"
          ],
          "node": "6"
        }
      }
    ]
  ],
  "plugins": [
    "transform-async-to-bluebird",
    "transform-promise-to-bluebird",
    "transform-runtime",
    "add-module-exports"
  ],
  "env": {
    "test": {
      "sourceMaps": "both"
    }
  }
}