    "prop-types": "^15.5.8",
    "react-bootstrap": "^0.31.0",
    "react-redux": "^4.4.5",
    "react-router": "^3.0.5",
    "react-router-redux": "^4.0.6",
    "react-waypoint": "^7.1.0",
    "redux": "^3.6.0",
    "redux-connect": "^5.1.0",
    "redux-form": "^6.1.1",
