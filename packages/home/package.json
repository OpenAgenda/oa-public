{
  "name": "@openagenda/home",
  "version": "2.1.2",
  "description": "Oh la home",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/openagenda/oa.git"
  },
  "author": "",
  "license": "ISC",
  "homepage": "https://bitbucket.org/openagenda/oa/src/master/packages/home",
  "directories": {
    "test": "test"
  },
  "main": "service/index.js",
  "scripts": {
    "start": "concurrently -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ./node_modules/.bin/knex",
    "build": "babel src -d dist -s",
    "clean": "rimraf dist",
    "prepublish": "yarn clean && yarn build"
  },
  "peerDependencies": {
    "react": "^16.7.0",
    "react-dom": "^16.7.0"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.1.2",
    "@openagenda/date-range": "^2.1.0",
    "@openagenda/labels": "^2.1.0",
    "@openagenda/react-components": "^2.2.1",
    "@openagenda/react-form-components": "^2.1.1",
    "@openagenda/react-utils": "^4.0.0",
    "classnames": "^2.2.5",
    "connected-react-router": "^6.1.0",
    "history": "^4.7.2",
    "knex": "^0.16.3",
    "lodash": "^4.17.4",
    "moment": "^2.18.1",
    "mysql": "^2.11.1",
    "prop-types": "^15.5.8",
    "react-redux": "^6.0.0",
    "react-router": "^4.3.1",
    "react-router-config": "^1.0.0-beta.4",
    "react-router-dom": "^4.3.1",
    "react-waypoint": "^7.1.0",
    "redial": "^0.5.0",
    "redux": "^4.0.1",
    "redux-form": "^8.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.2.2",
    "@babel/node": "^7.2.2",
    "@openagenda/agenda-stakeholders": "^2.1.2",
    "@openagenda/agendas": "^1.1.4",
    "@openagenda/bs-templates": "^2.2.0",
    "@openagenda/events": "^1.4.5",
    "@openagenda/fixtures": "^2.0.1",
    "@storybook/addon-actions": "^4.1.2",
    "@storybook/addon-links": "^4.1.2",
    "@storybook/addons": "^4.1.2",
    "@storybook/react": "^4.1.2",
    "babel-loader": "^8.0.4",
    "babel-preset-openagenda": "^1.1.1",
    "body-parser": "^1.18.3",
    "concurrently": "^4.1.0",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.16.4",
    "morgan": "^1.9.1",
    "nodemon": "^1.18.9",
    "react": "^16.7.0",
    "react-dom": "^16.7.0",
    "redux-devtools": "^3.5.0",
    "redux-devtools-dock-monitor": "^1.1.3",
    "redux-devtools-inspector": "^0.11.3",
    "rimraf": "^2.6.2"
  }
