{
  "name": "@openagenda/registration-apps",
  "version": "0.0.0",
  "main": "lib/index.js",
  "jsnext:main": "esm/index.js",
  "module": "esm/index.js",
  "description": "Components useful for registration features",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa.git"
  },
  "scripts": {
    "prepack": "yarn clean && yarn build",
    "storybook": "storybook dev -p 9001 --ci",
    "sb": "yarn storybook",
    "build": "yarn build:esm && yarn build:cjs",
    "build:esm": "babel --copy-files src -d esm -s --env-name esm",
    "build:cjs": "babel --copy-files src -d lib -s",
    "clean": "rimraf esm lib",
    "test": "jest"
  },
  "dependencies": {
    "@openagenda/react-shared": "^2.4.1",
    "@openagenda/registrations": "^0.0.2",
    "autosize": "^6.0.1",
    "classnames": "^2.5.1",
    "fastest-levenshtein": "^1.0.16",
    "immer": "^10.0.3",
    "lodash": "^4.17.21",
    "react-select": "^5.7.4",
    "react-tagsinput": "^3.19.0",
    "slugify": "^1.4.6",
    "why": "^0.6.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.3",
    "@emotion/babel-plugin": "^11.11.0",
    "@loadable/babel-plugin": "^5.13.2",
    "@openagenda/babel-preset": "^1.5.0",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/eslint-config": "^1.4.0",
    "@storybook/react-webpack5": "^7.4.2",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^3.0.1",
    "storybook": "^7.6.4"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "msw": {
    "workerDirectory": ".storybook/public"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/test/*.js"
    ]
  }
}
