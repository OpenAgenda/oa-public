{
  "name": "@openagenda/registration-apps",
  "version": "0.0.0",
  "main": "lib/index.js",
  "jsnext:main": "esm/index.js",
  "module": "esm/index.js",
  "description": "Components useful for registration features",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa.git"
  },
  "scripts": {
    "prepack": "yarn clean && yarn build",
    "storybook": "start-storybook -c .storybook -p 9001 --ci",
    "sb": "yarn storybook",
    "build": "yarn build:esm && yarn build:cjs",
    "build:esm": "babel --copy-files src -d esm -s --env-name esm",
    "build:cjs": "babel --copy-files src -d lib -s",
    "clean": "rimraf esm lib",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write '**/*.js'",
    "test": "jest"
  },
  "dependencies": {
    "@openagenda/react-shared": "^2.4.0",
    "@openagenda/validators": "^2.4.0",
    "date-fns": "^2.11.1",
    "immer": "^9.0.1",
    "react-select": "^5.7.4",
    "react-tagsinput": "^3.19.0",
    "slugify": "^1.4.6",
    "validator": "^12.2.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.21.0",
    "@babel/core": "^7.21.0",
    "@emotion/babel-plugin": "^11.10.5",
    "@loadable/babel-plugin": "^5.13.2",
    "@openagenda/babel-preset": "^1.5.0",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/eslint-config": "^1.4.0",
    "@storybook/react": "^6.5.9",
    "babel-jest": "^26.6.3",
    "eslint": "^8.24.0",
    "jest": "^28.1.2",
    "msw": "^0.49.2",
    "msw-storybook-addon": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "msw": {
    "workerDirectory": ".storybook/public"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/test/*.js"
    ]
  }
}
