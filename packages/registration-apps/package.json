{
  "name": "@openagenda/registration-apps",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "description": "Components useful for registration features",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa.git"
  },
  "scripts": {
    "prepack": "yarn build",
    "sb": "storybook dev",
    "build": "tsdown",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest"
  },
  "dependencies": {
    "@openagenda/react-shared": "^3.0.0",
    "@openagenda/registrations": "^0.0.5",
    "autosize": "^6.0.1",
    "classnames": "^2.5.1",
    "fastest-levenshtein": "^1.0.16",
    "immer": "^10.0.3",
    "react-select": "^5.8.3",
    "react-tagsinput": "^3.19.0",
    "slugify": "^1.4.6",
    "validator": "^12.2.0",
    "why": "^0.6.2"
  },
  "devDependencies": {
    "@openagenda/bs-templates": "^2.6.0",
    "@openagenda/eslint-config": "^2.0.0",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "jest": "^29.7.0",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.6",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "storybook": "^10.2.0",
    "tsdown": "^0.22.0"
  },
  "peerDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  },
  "msw": {
    "workerDirectory": ".storybook/public"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/test/*.js"
    ],
    "transform": {}
  }
}
