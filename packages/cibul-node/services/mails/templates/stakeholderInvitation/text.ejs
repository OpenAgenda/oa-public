<%- __(
  isStakeholder
    ? 'titleForExistantStakeholder'
    : 'title', { agenda, credential: __( credential ) }
) %>:

<%- typeof message === 'string'
  ? message.replace(/(?:\r\n|\r|\n)/g, '<br/>')
  : __( 'description', { agenda, credential: __( credential ) } ) %>

<%- __( isStakeholder ? 'showAgenda' : 'signup' ) %>: <%- link %>

<%- __( isRegisteredUser ? 'unsubscribe' : 'unsubscribeGuest' ) %>: <%- unsubscribeLink %>
<% if ( isRegisteredUser ) { %><%- __( 'changeEmailSettings' ) %>: <%- emailSettingsLink %><% } %>

