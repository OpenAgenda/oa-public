<%- __(
  isMember
    ? 'subjectForExistingMember'
    : 'subject', { agenda, role: __(role), roleVerb: __(role + 'Verb') }
) %>:

<%- typeof message === 'string'
  ? stripHtml(message)
  : '' %>

<%- __(isMember ? 'memberAction' : 'signup', { role }) %>: <%- link %>

<%- __(isRegisteredUser ? 'unsubscribe' : 'unsubscribeGuest') %>: <%- unsubscribeLink %>
<% if (isRegisteredUser) { %><%- __('changeEmailSettings') %>: <%- emailSettingsLink %><% } %>

