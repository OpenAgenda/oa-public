"use strict";

var parser = require( '../parser' ),

fs = require( 'fs' );

var t = fs.readFileSync( __dirname + '/replicate.tblr' ).toString(),

m = fs.readFileSync( __dirname + '/replicate.mapping' ).toString(),

p = parser( JSON.parse( m ) );

p.load( t );

p.render( {
  title: 'Maison&Objet Americas',
  image: false,
  description: 'Maison & Objet Americas',
}) );
