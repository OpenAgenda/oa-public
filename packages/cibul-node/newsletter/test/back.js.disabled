// clear db
// load user and agenda in db
// attempt connect

process.env.NODE_ENV = 'testing';

var debug = require('debug');

debug.enable('*');

var log = debug('back tests'),

fixtures = require('../../test/lib/fixtures');

fixtures.clearAll(function( err ) {

  if ( err ) {

    log('something went wrong');

    return;

  }

  fixtures.load( 'users', 'gaetan', function( err, result ) {

    if ( err ) return console.log( err );

    console.log( result );

  } )

});