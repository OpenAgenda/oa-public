{
  "collectionName": "components_components_split_heroes",
  "info": {
    "displayName": "SplitHero",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "text": {
      "type": "richtext",
      "required": true
    },
    "imagePosition": {
      "type": "enumeration",
      "default": "left",
      "enum": ["left", "right"]
    },
    "CTAs": {
      "type": "component",
      "component": "components.cta-button",
      "repeatable": true
    },
    "background": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::background.background"
    },
    "fontColor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::color.color"
    },
    "coverImage": {
      "type": "boolean",
      "default": false
    },
    "imageMaxWidth": {
      "type": "integer",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "coverImage"
            },
            true
          ]
        }
      },
      "default": 33,
      "min": 0,
      "max": 100
    }
  }
}
