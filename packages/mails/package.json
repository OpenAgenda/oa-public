{
  "name": "@openagenda/mails",
  "version": "2.2.0",
  "license": "MIT",
  "main": "index.js",
  "bin": {
    "oa-mails-editor": "./bin/editor.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "nodemon server.dev.js -w $MAILS_TEMPLATES_DIR",
    "test": "jest --forceExit --detectOpenHandles",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@openagenda/logs": "^1.1.8",
    "ejs": "^2.7.4",
    "express": "^4.17.1",
    "html-to-text": "^5.1.1",
    "isemail": "^3.2.0",
    "lodash": "^4.17.15",
    "mjml": "^4.6.2",
    "nodemailer": "^6.3.0",
    "nodemon": "^2.0.6",
    "reload": "^3.0.4",
    "verror": "^1.10.0",
    "walk": "^2.3.14"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^1.3.0",
    "@openagenda/queues": "^1.2.6",
    "eslint": "^6.8.0",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "morgan": "^1.9.1",
    "prettier-eslint-cli": "^5.0.0",
    "redis": "^2.8.0"
  },
  "nodemonConfig": {
    "ext": "js,json,mjml,ejs"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  }
}
