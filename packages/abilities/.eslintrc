{
  "extends": "airbnb-base",
  "plugins": [
    "jest"
  ],
  "rules": {
    "strict": [
      "error",
      "safe"
    ],
    "no-param-reassign": "off",
    "no-underscore-dangle": "off",
    "no-restricted-syntax": "off",
    "no-continue": "off",
    "no-await-in-loop": "off",
    "consistent-return": "off",
    "space-in-parens": [
      "error",
      "always"
    ],
    "max-len": [
      "warn",
      120
    ],
    "arrow-parens": [
      "error",
      "as-needed"
    ],
    "comma-dangle": [
      "error",
      "only-multiline"
    ],
    "computed-property-spacing": [
      "error",
      "always"
    ],
    "array-bracket-spacing": [
      "error",
      "always"
    ],
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "test/setup.js",
          "**/*.{test,spec}.js"
        ]
      }
    ]
  },
  "overrides": [ {
    "files": "**/*.{test,spec}.js",
    "rules": {
      "no-unused-expressions": "off"
    }
  } ],
  "parserOptions": {
    "sourceType": "script"
  },
  "env": {
    "es6": true,
    "node": true,
    "jest/globals": true
  }
}
