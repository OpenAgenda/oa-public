{
  "extends": [
    "airbnb",
    "plugin:jest/recommended"
  ],
  "plugins": [
    "react",
    "import"
  ],
  "env": {
    "browser": true,
    "node": true
  },
  "parserOptions": {
    "sourceType": "script"
  },
  "rules": {
    "strict": [
      "error",
      "safe"
    ],
    "no-param-reassign": "off",
    "no-underscore-dangle": "off",
    "no-restricted-syntax": "off",
    "no-continue": "off",
    "no-await-in-loop": "off",
    "consistent-return": "off",
    "space-in-parens": [
      "error",
      "always"
    ],
    "max-len": [
      "off",
      80
    ],
    "arrow-parens": [
      "error",
      "as-needed"
    ],
    "comma-dangle": [
      "error",
      "only-multiline"
    ],
    "computed-property-spacing": [
      "error",
      "always"
    ],
    "array-bracket-spacing": [
      "error",
      "always"
    ],
    "import/no-unresolved": "error",
    "import/named": "error",
    "import/namespace": "error",
    "import/default": "error",
    "import/export": "error",
    "import/no-named-as-default": "warn",
    "import/no-named-as-default-member": "off",
    "import/no-duplicates": "warn",
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          ".babelrc.js",
          ".storybook/**/*.js",
          "stories/**/*.js",
          "server.dev.js",
          "test/**/*.js"
        ]
      }
    ],
    "import/order": [
      "error",
      {
        "groups": [
          "builtin",
          "external",
          "parent",
          "sibling",
          "index"
        ]
      }
    ],
    "react/jsx-filename-extension": [
      "error",
      {
        "extensions": [
          ".js",
          ".jsx"
        ]
      }
    ],
    "react/jsx-one-expression-per-line": "off",
    "react/prop-types": [
      "error",
      {
        "skipUndeclared": true
      }
    ],
    "jsx-a11y/label-has-for": [
      "error",
      {
        "required": "id"
      }
    ],
    "jsx-a11y/label-has-associated-control": [
      "error",
      {
        "labelComponents": [
          "label"
        ],
        "labelAttributes": [
          "htmlFor"
        ],
        "controlComponents": [
          "Field",
          "input"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "src/**/*.js",
        ".storybook/**/*.js",
        "stories/**/*.js",
        "server.dev.js",
        "test/**/*.js"
      ],
      "env": {
        "es6": true
      },
      "parser": "babel-eslint",
      "parserOptions": {
        "sourceType": "module",
        "ecmaFeatures": {
          "jsx": true
        }
      }
    },
    {
      "files": "**/*.{test,spec}.js",
      "rules": {
        "import/default": "off"
      }
    }
  ]
}
