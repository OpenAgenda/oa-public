{
  "extends": "airbnb",
  "plugins": [
    "import",
    "jest"
  ],
  "env": {
    "browser": true,
    "node": true
  },
  "parserOptions": {
    "sourceType": "script"
  },
  "settings": {
    "react": {
      "version": "16.5.2"
    }
  },
  "rules": {
    "strict": [
      "error",
      "safe"
    ],
    "no-param-reassign": "off",
    "no-underscore-dangle": "off",
    "no-restricted-syntax": "off",
    "no-continue": "off",
    "no-await-in-loop": "off",
    "consistent-return": "off",
    "space-in-parens": [
      "error",
      "always"
    ],
    "max-len": [
      "warn",
      120
    ],
    "arrow-parens": [
      "error",
      "as-needed"
    ],
    "comma-dangle": [
      "error",
      "only-multiline"
    ],
    "computed-property-spacing": [
      "error",
      "always"
    ],
    "array-bracket-spacing": [
      "error",
      "always"
    ],
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "test/setup.js",
          "**/*.{test,spec}.js"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": "{src,test}/**/*.js",
      "env":  {
        "es6": true
      },
      "parser": "babel-eslint",
      "parserOptions": {
        "sourceType": "module",
        "ecmaFeatures": {
          "jsx": true
        }
      }
    },
    {
      "files": "**/*.{test,spec}.js",
      "env": {
        "jest":  true
      }
    }
  ]
}
