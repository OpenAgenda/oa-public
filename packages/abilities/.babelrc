{
  "presets": [
    [
      "openagenda",
      {
        "modules": "commonjs"
      }
    ]
  ],
  "plugins": [
    [
      "react-intl",
      {
        "messagesDir": "./build/messages/"
      }
    ]
  ],
  "env": {
    "test": {
      "plugins": [
        "babel-plugin-require-context-hook"
      ]
    }
  },
  "sourceType": "unambiguous"
}
