{
  "name": "@openagenda/abilities",
  "version": "1.3.3",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/service/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/service/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn sb --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM server.dev.js",
    "sb": "STORYBOOK_API_PORT=3000 storybook dev",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --testEnvironment=node --forceExit --detectOpenHandles",
    "build": "tsdown",
    "extract-messages": "oa-intl --esm",
    "prepack": "oa-intl compile --esm && yarn build"
  },
  "dependencies": {
    "@casl/ability": "^2.4.2",
    "@openagenda/bs-templates": "^2.5.1",
    "@openagenda/intl": "^1.1.6",
    "@openagenda/logs": "^1.1.10",
    "@openagenda/react-shared": "^2.4.6",
    "classnames": "^2.3.1",
    "final-form": "^4.20.2",
    "final-form-calculate": "^1.3.2",
    "final-form-set-field-data": "^1.0.2",
    "fuse.js": "^3.4.6",
    "knex": "^2.4.2",
    "ky": "^1.1.3",
    "lodash": "^4.17.15",
    "mysql2": "^3.15.1",
    "rc-collapse": "^3.1.0",
    "react-final-form": "^4.1.0",
    "react-intl": "^10.1.1",
    "react-use": "^17.6.0"
  },
  "devDependencies": {
    "@openagenda/agendas": "^1.7.1",
    "@openagenda/eslint-config": "^1.4.0",
    "@openagenda/users": "^3.1.1",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "concurrently": "^6.0.2",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.17.1",
    "jest": "^29.7.0",
    "morgan": "^1.9.1",
    "nodemon": "^3.0.3",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "storybook": "^10.2.0",
    "tsdown": "^0.22.0"
  },
  "peerDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  },
  "jest": {
    "transform": {}
  }
}
