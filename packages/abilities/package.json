{
  "name": "@openagenda/abilities",
  "version": "1.1.0",
  "license": "MIT",
  "main": "build/service/index.js",
  "scripts": {
    "dev": "concurrently -k -i -n server,storybook \"yarn watch-dev-server\" \"yarn storybook --ci\"",
    "watch-dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "build-storybook": "STORYBOOK_API_PORT=3000 build-storybook",
    "knex": "babel-node ./node_modules/.bin/knex",
    "test": "STORYBOOK_MODE=test jest --testPathIgnorePatterns image-snapshots --forceExit --detectOpenHandles",
    "image-snapshots": "STORYBOOK_API_PORT=3302 build-storybook && yarn do-image-snapshots --forceExit --detectOpenHandles",
    "do-image-snapshots": "STORYBOOK_API_PORT=3302 jest image-snapshots",
    "lint": "eslint -c .eslintrc '**/*.js' .storybook",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc '**/*.js'",
    "build": "rimraf build && babel --copy-files -d build src -s",
    "extract-messages": "node scripts/extract-messages.js",
    "prepublish": "yarn build"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc",
      "git add"
    ]
  },
  "dependencies": {
    "@casl/ability": "^2.4.2",
    "@openagenda/bs-templates": "^2.2.0",
    "@openagenda/logs": "^1.1.0",
    "@openagenda/react-components": "^2.2.0",
    "axios": "^0.18.0",
    "classnames": "^2.2.6",
    "final-form": "^4.10.0",
    "final-form-calculate": "^1.2.1",
    "final-form-set-field-data": "^1.0.1",
    "knex": "^0.15.2",
    "lodash": "^4.17.11",
    "mysql": "^2.16.0",
    "prop-types": "^15.6.2",
    "rc-collapse": "^1.10.0",
    "react": "^16.5.2",
    "react-dom": "^16.5.2",
    "react-final-form": "^3.6.7",
    "react-intl": "^2.7.1",
    "recompose": "^0.30.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.1.2",
    "@babel/core": "^7.1.2",
    "@babel/node": "^7.0.0",
    "@openagenda/agenda-stakeholders": "^2.1.0",
    "@openagenda/agendas": "^1.1.0",
    "@openagenda/users": "^2.2.0",
    "@storybook/addon-a11y": "^4.0.0-rc.0",
    "@storybook/addon-actions": "^4.0.0-rc.0",
    "@storybook/addon-knobs": "^v4.0.0-rc.2",
    "@storybook/addon-options": "^4.0.0-rc.0",
    "@storybook/addon-storyshots": "^4.0.8",
    "@storybook/addon-storyshots-puppeteer": "^4.0.0-rc.0",
    "@storybook/addon-storysource": "^4.0.0-rc.0",
    "@storybook/react": "^4.0.0-rc.0",
    "axe-core": "^3.1.2",
    "babel-core": "^7.0.0-bridge.0",
    "babel-eslint": "^10.0.1",
    "babel-jest": "^23.6.0",
    "babel-loader": "^8.0.4",
    "babel-plugin-react-intl": "^3.0.1",
    "babel-plugin-require-context-hook": "^1.0.0",
    "babel-preset-openagenda": "^1.1.0",
    "concurrently": "^4.0.1",
    "cors": "^2.8.4",
    "enzyme": "^3.7.0",
    "enzyme-adapter-react-16": "^1.6.0",
    "enzyme-to-json": "^3.3.4",
    "errorhandler": "^1.5.0",
    "eslint": "^5.9.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jest": "^21.22.1",
    "eslint-plugin-jsx-a11y": "^6.1.1",
    "eslint-plugin-react": "^7.11.1",
    "express": "^4.16.3",
    "glob": "^7.1.3",
    "husky": "^1.1.2",
    "jest": "^23.6.0",
    "lint-staged": "^7.3.0",
    "morgan": "^1.9.1",
    "nodemon": "^1.18.4",
    "prettier-eslint-cli": "^4.7.1",
    "react-test-renderer": "^16.5.2",
    "rimraf": "^2.6.2",
    "webpack": "^4.26.0",
    "why-did-you-update": "^1.0.6"
  }
}
