{
  "name": "@openagenda/abilities",
  "version": "1.0.0",
  "license": "MIT",
  "main": "dist/service/index.js",
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc '**/*.js'",
    "lint": "eslint -c .eslintrc '**/*.js'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc",
      "git add"
    ]
  },
  "dependencies": {
    "@casl/ability": "^2.4.2",
    "@openagenda/logs": "^1.0.19",
    "knex": "^0.15.2",
    "lodash": "^4.17.11",
    "mysql": "^2.16.0"
  },
  "devDependencies": {
    "bluebird": "^3.5.2",
    "chai": "^4.1.2",
    "chai-as-promised": "^7.1.1",
    "chai-jest-diff": "^1.0.2",
    "eslint": "^5.6.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jest": "^21.22.1",
    "husky": "^1.0.0-rc.15",
    "jest": "^23.6.0",
    "lint-staged": "^7.3.0",
    "prettier-eslint-cli": "^4.7.1"
  }
}
