{
  "name": "@openagenda/abilities",
  "version": "1.2.0",
  "license": "MIT",
  "main": "build/service/index.js",
  "scripts": {
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ../../node_modules/.bin/knex",
    "test": "STORYBOOK_MODE=test jest --testEnvironment=node --forceExit --detectOpenHandles",
    "build": "rimraf build && babel --copy-files -d build src -s",
    "extract-messages": "yarn oa:extract-messages --messages-pattern 'build/messages/**/*.json'",
    "prepack": "yarn build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.10.4",
    "@casl/ability": "^2.4.2",
    "@openagenda/bs-templates": "^2.4.6",
    "@openagenda/logs": "^1.1.7",
    "@openagenda/react-components": "^2.3.8",
    "@openagenda/react-shared": "^2.0.6",
    "axios": "^0.19.0",
    "classnames": "^2.2.6",
    "core-js": "^3.6.5",
    "final-form-calculate": "^1.3.1",
    "final-form-set-field-data": "^1.0.2",
    "fuse.js": "^3.4.6",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "mysql": "^2.16.0",
    "prop-types": "^15.6.2",
    "rc-collapse": "^1.11.1",
    "react-final-form": "^4.1.0",
    "react-intl": "^3.11.0",
    "recompose": "^0.30.0",
    "regenerator-runtime": "^0.13.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.10.4",
    "@babel/core": "^7.10.4",
    "@babel/node": "^7.10.4",
    "@openagenda/agendas": "^1.5.1",
    "@openagenda/babel-preset": "^1.3.7",
    "@openagenda/eslint-config": "^1.2.4",
    "@openagenda/image-files": "^1.1.10",
    "@openagenda/users": "^3.0.14",
    "@storybook/addon-knobs": "^5.3.19",
    "@storybook/react": "^5.3.19",
    "babel-jest": "^26.0.1",
    "babel-loader": "^8.1.0",
    "concurrently": "^5.1.0",
    "cors": "^2.8.4",
    "errorhandler": "^1.5.0",
    "eslint": "^6.8.0",
    "express": "^4.17.1",
    "final-form": "^4.20.1",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "morgan": "^1.9.1",
    "nodemon": "^2.0.4",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "rimraf": "^3.0.1",
    "webpack": "^4.43.0"
  },
  "peerDependencies": {
    "final-form": "^4.18.5",
    "react": "^16.12.0",
    "react-dom": "^16.12.0"
  }
}
