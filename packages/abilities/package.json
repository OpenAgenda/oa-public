{
  "name": "@openagenda/abilities",
  "version": "1.1.3",
  "license": "MIT",
  "main": "build/service/index.js",
  "scripts": {
    "start": "concurrently -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ./node_modules/.bin/knex",
    "test": "STORYBOOK_MODE=test jest --forceExit --detectOpenHandles",
    "build": "rimraf build && babel --copy-files -d build src -s",
    "extract-messages": "node scripts/extract-messages.js",
    "prepublish": "yarn build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc '**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc",
      "git add"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.3.1",
    "@casl/ability": "^2.4.2",
    "@openagenda/bs-templates": "^2.2.1",
    "@openagenda/logs": "^1.1.1",
    "@openagenda/react-components": "^2.2.1",
    "axios": "^0.18.0",
    "classnames": "^2.2.6",
    "final-form": "^4.10.0",
    "final-form-calculate": "^1.2.1",
    "final-form-set-field-data": "^1.0.1",
    "fuse.js": "^3.4.4",
    "knex": "^0.16.3",
    "lodash": "^4.17.11",
    "mysql": "^2.16.0",
    "prop-types": "^15.6.2",
    "rc-collapse": "^1.11.1",
    "react-final-form": "^3.6.7",
    "react-intl": "^2.8.0",
    "recompose": "^0.30.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.2.2",
    "@babel/node": "^7.0.0",
    "@openagenda/agenda-stakeholders": "^2.1.2",
    "@openagenda/agendas": "^1.1.4",
    "@openagenda/babel-preset": "^1.1.1",
    "@openagenda/eslint-config": "^1.0.0",
    "@openagenda/users": "^3.0.0",
    "@storybook/addon-a11y": "^4.1.11",
    "@storybook/addon-actions": "^4.1.11",
    "@storybook/addon-knobs": "^4.1.11",
    "@storybook/addon-options": "^4.1.11",
    "@storybook/addon-storysource": "^4.1.11",
    "@storybook/react": "^4.1.11",
    "axe-core": "^3.1.2",
    "babel-core": "^7.0.0-bridge.0",
    "babel-jest": "^23.6.0",
    "babel-loader": "^8.0.4",
    "babel-plugin-react-intl": "^3.0.1",
    "concurrently": "^4.0.1",
    "cors": "^2.8.4",
    "errorhandler": "^1.5.0",
    "eslint": "^6.2.1",
    "express": "^4.16.3",
    "glob": "^7.1.3",
    "jest": "^23.6.0",
    "lint-staged": "^7.3.0",
    "morgan": "^1.9.1",
    "nodemon": "^1.18.4",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "rimraf": "^2.6.2",
    "webpack": "^4.26.0",
    "why-did-you-update": "^1.0.6"
  },
  "peerDependencies": {
    "react": "^16.8.6",
    "react-dom": "^16.8.6"
  }
}
