{
  "name": "@openagenda/abilities",
  "version": "1.3.1",
  "license": "MIT",
  "main": "build/service/index.js",
  "scripts": {
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ../../node_modules/.bin/knex",
    "test": "STORYBOOK_MODE=test jest --testEnvironment=node --forceExit --detectOpenHandles",
    "build": "babel --copy-files -d build src -s",
    "extract-messages": "yarn oa-intl",
    "prepack": "yarn clean && yarn oa-intl compile && yarn build",
    "clean": "rimraf build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.13.17",
    "@casl/ability": "^2.4.2",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/intl": "^1.1.2",
    "@openagenda/logs": "^1.1.9",
    "@openagenda/react-shared": "^2.3.2",
    "axios": "^0.21.1",
    "classnames": "^2.3.1",
    "core-js": "^3.10.2",
    "final-form": "^4.20.2",
    "final-form-calculate": "^1.3.2",
    "final-form-set-field-data": "^1.0.2",
    "fuse.js": "^3.4.6",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "mysql": "^2.16.0",
    "prop-types": "^15.6.2",
    "rc-collapse": "^3.1.0",
    "react-final-form": "^4.1.0",
    "react-intl": "^5.12.2",
    "recompose": "^0.30.0",
    "regenerator-runtime": "^0.13.8"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/core": "^7.13.16",
    "@babel/node": "^7.13.13",
    "@openagenda/agendas": "^1.7.0",
    "@openagenda/babel-preset": "^1.4.1",
    "@openagenda/eslint-config": "^1.3.1",
    "@openagenda/users": "^3.1.0",
    "@storybook/react": "^6.4.9",
    "babel-jest": "^26.6.3",
    "babel-loader": "^8.2.2",
    "concurrently": "^6.0.2",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "eslint": "^6.8.0",
    "express": "^4.17.1",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "morgan": "^1.9.1",
    "nodemon": "^2.0.4",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "rimraf": "^3.0.1",
    "webpack": "^5.53.0"
  },
  "peerDependencies": {
    "react": "^16.12.0",
    "react-dom": "^16.12.0"
  }
}
