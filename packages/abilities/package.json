{
  "name": "@openagenda/abilities",
  "version": "1.3.3",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "build/service/index.js",
  "scripts": {
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn sb --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM server.dev.js",
    "sb": "STORYBOOK_API_PORT=3000 storybook dev -p 9001",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --testEnvironment=node --forceExit --detectOpenHandles",
    "build": "babel --copy-files -d build src -s --env-name esm --root-mode upward",
    "extract-messages": "oa-intl --esm",
    "prepack": "yarn clean && oa-intl compile --esm && yarn build",
    "clean": "rimraf build"
  },
  "dependencies": {
    "@casl/ability": "^2.4.2",
    "@openagenda/bs-templates": "^2.5.1",
    "@openagenda/intl": "^1.1.6",
    "@openagenda/logs": "^1.1.10",
    "@openagenda/react-shared": "^2.4.5",
    "classnames": "^2.3.1",
    "final-form": "^4.20.2",
    "final-form-calculate": "^1.3.2",
    "final-form-set-field-data": "^1.0.2",
    "fuse.js": "^3.4.6",
    "knex": "^2.4.2",
    "ky": "^1.1.3",
    "lodash": "^4.17.15",
    "mysql": "^2.16.0",
    "rc-collapse": "^3.1.0",
    "react-final-form": "^4.1.0",
    "react-intl": "^6.8.4",
    "react-use": "^17.6.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@openagenda/agendas": "^1.7.1",
    "@openagenda/eslint-config": "^1.4.0",
    "@openagenda/users": "^3.1.1",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.6",
    "@storybook/react-webpack5": "^9.0.8",
    "babel-jest": "^29.7.0",
    "concurrently": "^6.0.2",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.17.1",
    "jest": "^29.7.0",
    "morgan": "^1.9.1",
    "nodemon": "^3.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^3.0.1",
    "storybook": "^9.0.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "jest": {
    "transform": {}
  }
}
