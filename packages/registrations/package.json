    "remark": "^14.0.3",
    "strip-markdown": "^5.0.1"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^1.4.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.24.0",
    "image-type": "^5.2.0",
    "is-base64": "^1.1.0",
    "jest": "^28.1.2",
