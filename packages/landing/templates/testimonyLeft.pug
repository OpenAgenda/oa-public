div( class='testimonials background-' + ( background || 'white' ) )
  .container
    .spaced
      .row.text-center
        .col-sm-3.text-center.margin-top-lg.margin-bottom-lg
          if ( action )
            h2 #{action.title}
            p.margin-top-lg
              a.btn.btn-primary.btn-lg(href=action.link)=action.label
          if ( typeof organization == 'object' )
            img( src=organization.logo alt=organization.name )
            p.margin-top-sm!=organization.name
            a(href=organization.link)!=organization.link
        .col-sm-2
        .col-sm-7.text-left.margin-top-lg.margin-bottom-lg
          blockquote.margin-top-lg
            .quote
              p!=testimony
            footer.media
              img(alt=name src=avatar class='img-circle' width=40)
              strong #{name}
              if ( typeof organization == 'string' )
                br
                span!=organization
              if ( role )
                br
                span!=role