div(class='background-' + ( background || 'white' ))
  div(class='container' + ( centered ? ' text-center' : '') )
    .spaced
      .media
        if typeof leftImage !== 'undefined'
          figure.media-left.media-middle
            img(src=leftImage width=imageWidth||256 class='big')
        article.media-body.media-middle
          h2.media-heading!=title
          if typeof text !== 'undefined'
            p!=text
          if typeof points !== 'undefined'
            ul
              each p in points
                li 
                  p!=p
          if action
            div.margin-top-lg
              a( class='btn-lg btn-primary', href=action.link )!=action.label

        if typeof rightImage !== 'undefined'
          figure.media-right.media-middle
            img(src=rightImage width=imageWidth||256 class='big')