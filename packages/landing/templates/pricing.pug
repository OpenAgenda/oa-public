div.background-blue.price-summary
  .container
    .spaced
      h2.text-center!=title
      .row.margin-top-md
        .col-lg-6
          .margin-h-md.margin-v-lg
            figure.text-center
              img.big(src='//cdn.openagenda.com/static/landing/agenda-white.png', width=300)
            h3!=agendaTitle
            div.separator
            p.sub!=agendaSub
            ul
              each p in agendaPoints
                li
                  p!=p
            a.btn.btn-primary.btn-lg.margin-top-md(href=agendaAction.link)!=agendaAction.label

        .col-lg-6
          .margin-h-md.margin-v-lg
            figure.text-center
              img.big(src='//cdn.openagenda.com/static/landing/network-white.png', width=300)
            h3!=networkTitle
            div.separator
            p.sub!=networkSub
            ul
              each p in networkPoints
                li
                  p!=p
            a.btn.btn-primary.btn-lg.margin-top-md(href=networkAction.link)!=networkAction.label
