div(class='background-' + ( background || 'white' ))
  .container
    .spaced
      h2.text-center!=title
      .row.margin-top-md
        .col-lg-6
          .margin-h-md.margin-v-lg
            figure.text-center
              img.big(src='//s3.eu-central-1.amazonaws.com/oastatic/landing/agenda.jpg', width=300)
            h3!=agendaTitle
            each p in agendaPoints  
              p!=p
            a.btn.btn-primary.btn-lg.margin-top-md(href=agendaAction.link)!=agendaAction.label

        .col-lg-6
          .margin-h-md.margin-v-lg
            figure.text-center
              img.big(src='//s3.eu-central-1.amazonaws.com/oastatic/landing/network300.jpg', width=300)
            h3!=networkTitle
            each p in networkPoints  
              p!=p
            a.btn.btn-primary.btn-lg.margin-top-md(href=networkAction.link)!=networkAction.label