footer.footer
  .container
    .row.spaced.text-center
      .col-sm-3.text-left
        h2 #{contact.title}
        ul.list-unstyled
          each m in contact.list
            li
              if m.form
                form(action=m.form.link, method='post')
                  .input-group
                    input.form-control(type='email', name='email', placeholder=m.form.placeholder)
                    span.input-group-btn
                      button.btn.btn-primary(type='submit')!=m.form.button
              else if m.ul
                ul.list-unstyled.list-inline
                  each mm in m.ul
                    li
                      a(href=mm.link)
                        i(class=mm.icon)
              else
                a(href=m.link)
                  if m.label
                    span!=m.label
                  else
                    i(class=m.icon)
      .col-sm-3
        h2 #{offers.title}
        ul.list-unstyled
          each o in offers.list
            li
              a(href=o.link)!=o.label
      .col-sm-3
        h2 #{more.title}
        ul.list-unstyled
          each m in more.list
            li
              a(href=m.link)!=m.label
      .col-sm-3
        h2 #{service.title}
        ul.list-unstyled
          each m in service.list
            li
              a(href=m.link)!=m.label