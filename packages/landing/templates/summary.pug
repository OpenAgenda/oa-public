div( class='summary background-' + ( background || 'white' ) )
  .container
    .spaced
      ul.list-unstyled.row.text-center.summary-head
        each col in featureCols
          li.col-xs-12.col-sm-4
            i( class='fa fa-4x ' + col.headIcon )
      ul.list-unstyled.row.text-center.margin-top-lg
        each col in featureCols
          li.col-xs-12.col-sm-4
            ul.list-unstyled.features.text-left
              if col.already.length
                each f in col.already
                  li.already-included
                    i.fa.fa-check.pull-right
                    span!=f
              
              each f in col.features
                li!=f.label