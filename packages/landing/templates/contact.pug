div(class='background-' + ( background || 'white' ))
  .container
    .spaced
      .row.text-center
        div(class=action?'col-sm-6':'col-sm-offset-3 col-sm-6')
          .contact
            h2(class=action? '' : 'text-center' ) #{contacts.title}
            ul(class=action? 'list-unstyled' : 'list-unstyled text-center' )
              li
                a(href='tel:' + contacts.phone)
                  i.fa.fa-phone
                  span #{contacts.phone}
              li
                a(href='mailto:' + contacts.email)
                  i.fa.fa-envelope
                  span #{contacts.email}
              li
                a(href='https://twitter.com/' + contacts.twitter)
                  i.fa.fa-twitter
                  span #{'@' + contacts.twitter}

        if action
          .col-sm-6.margin-top-lg.margin-bottom-lg
            h2 #{action.title}
            p
              a.btn.btn-primary.btn-lg(href=action.link)=action.label