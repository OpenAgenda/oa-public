div(class='background-' + ( background || 'white' ))
  .container
    .spaced
      .row.text-center
        .col-sm-6
          .contact
            h2 #{contacts.title}
            ul.list-unstyled  
              li
                a(href='tel:' + contacts.phone)
                  i.fa.fa-phone
                  span #{contacts.phone}
              li
                a(href='mailto:' + contacts.email)
                  i.fa.fa-envelope
                  span #{contacts.email}
              li
                a(href='@' + contacts.twitter)
                  i.fa.fa-twitter
                  span #{'https://twitter.com/' + contacts.twitter}

        .col-sm-6.margin-top-lg.margin-bottom-lg
          h2 #{action.title}
          p
            a.btn.btn-primary.btn-lg(href=action.link)=action.label