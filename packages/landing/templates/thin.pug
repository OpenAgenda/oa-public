div(class='background-' + ( background || 'white' ))
  .container
    if typeof title !== 'undefined'
      h2.margin-top-md.margin-bottom-md!=title

    if ( typeof text !== 'undefined' ) || ( typeof points !== 'undefined' )
      div.margin-top-lg.margin-bottom-lg

        if typeof text !== 'undefined'
          p.margin-bottom-md!=text

        if typeof points !== 'undefined'
          ul.margin-bottom-lg
            each p in points
              li 
                p!=p
