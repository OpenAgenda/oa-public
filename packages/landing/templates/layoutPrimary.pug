#presentation.primary
  .container
    .spaced.text-center
      h1.hook!=title
      p.under-hook!=description

    .row.counters
      .col-md-8.col-md-offset-2.text-center
        p
          span !{eventCount.replace( '%count%', events )}
          span !{agendaCount.replace( '%count%', agendas )}
          span !{contributorCount.replace( '%count%', contributors )}

    .row.spaced
      .col-md-3.col-md-offset-3.text-center
        a.btn.btn-primary.btn-lg.margin-bottom-md(href='/agendas?lang=' + lang)!=agendaSearch

      .col-md-3.text-center
        a.btn.btn-primary.btn-lg.margin-bottom-md(href='/signup?lang=' + lang)!=agendaCreate


#functions!=content
