div(class='background-' + ( background || 'white' ))
  .container
    .spaced
      .pricing
        ul
          each offer in offers
            li(class='price-canvas margin-v-md margin-h-' + ( offerMargin || 'lg' ) )
              div(class='unit price-primary ' + ( typeof classes !== 'undefined' ? classes : '' ) )
                div(class=typeof offer.count !== 'undefined'?'price-title':'price-title')
                  h3(class=typeof offer.priceDetail ? '' : 'padding-bottom-sm')!=offer.title
                  p!=offer.price
                  if offer.priceDetail
                    small!=offer.priceDetail
                .price-body
                  if offer.small || offer.count || offer.countDetail
                    div.price-body-head
                      if offer.small
                        small.margin-bottom-sm!=offer.small
                      if offer.count
                        p!=offer.count
                      if offer.countDetail
                        small!=offer.countDetail
                  ul
                    each feature in offer.features
                      if feature === true
                        li
                          i.fa.fa-check
                      else
                        li!=feature
                .price-foot
                  a.btn.btn-primary( href=offer.action.link, rel='nofollow' )!=offer.action.label
              if typeof offer.under !== 'undefined'
                p.price-underfoot!=offer.under