{
  "name": "@openagenda/react-shared",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "bin": {
    "oa:extract-messages": "./scripts/extract-messages.js"
  },
  "scripts": {
    "prepack": "yarn clean && yarn build",
    "build": "babel --copy-files src -d dist -s",
    "clean": "rimraf build",
    "lint": "eslint -c .eslintrc $(pwd)'/**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.8.4",
    "core-js": "^3.6.4",
    "dedent": "^0.7.0",
    "glob": "^7.1.6",
    "lodash": "^4.17.15",
    "shallowequal": "^1.1.0",
    "yargs": "^15.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.8.4",
    "@openagenda/babel-preset": "^1.2.0",
    "@openagenda/eslint-config": "^1.0.0",
    "eslint": "^6.8.0",
    "lint-staged": "^10.0.7",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^16.12.0"
  }
}
