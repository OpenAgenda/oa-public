{
  "name": "@openagenda/react-shared",
  "version": "2.0.7",
  "main": "lib/index.js",
  "jsnext:main": "esm/index.js",
  "module": "esm/index.js",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "lib",
    "esm"
  ],
  "bin": {
    "oa:extract-messages": "./scripts/extract-messages.js"
  },
  "scripts": {
    "prepack": "yarn clean && yarn build",
    "build": "yarn build:esm && yarn build:cjs",
    "build:esm": "babel --copy-files src -d esm -s --env-name esm",
    "build:cjs": "babel --copy-files src -d lib -s",
    "clean": "rimraf esm lib",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.10.4",
    "core-js": "^3.6.5",
    "dedent": "^0.7.0",
    "glob": "^7.1.6",
    "lodash": "^4.17.15",
    "prop-types": "^15.7.2",
    "react-dropzone": "^11.2.0",
    "shallowequal": "^1.1.0",
    "yargs": "^15.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.10.4",
    "@babel/core": "^7.10.4",
    "@emotion/core": "^10.0.28",
    "@openagenda/babel-preset": "^1.3.8",
    "@openagenda/eslint-config": "^1.2.4",
    "babel-jest": "^26.1.0",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "enzyme-to-json": "^3.5.0",
    "eslint": "^6.8.0",
    "final-form": "^4.20.1",
    "jest": "^26.1.0",
    "jest-emotion": "^10.0.32",
    "lint-staged": "^10.2.11",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-final-form": "^6.4.0",
    "react-select": "^3.1.0",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "final-form": "*",
    "react": "^16.12.0",
    "react-final-form": "*",
    "react-select": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "final-form": {
      "optional": true
    },
    "react-final-form": {
      "optional": true
    },
    "react-select": {
      "optional": true
    }
  }
}
