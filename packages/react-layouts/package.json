{
  "name": "@openagenda/react-layouts",
  "version": "2.2.1",
  "main": "dist/index.js",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "start-storybook -c .storybook -p 9001 --ci",
    "prepack": "yarn clean && yarn oa-intl compile && yarn build",
    "build": "babel --copy-files src -d dist -s",
    "extract-messages": "yarn oa-intl",
    "clean": "rimraf dist",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.13.17",
    "@emotion/react": "^11.1.5",
    "@openagenda/activity-apps": "^1.2.1",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/intl": "^1.1.0",
    "@openagenda/members": "^1.15.13",
    "@openagenda/react-shared": "^2.3.2",
    "@openagenda/sessions": "^4.1.0",
    "classnames": "^2.3.1",
    "core-js": "^3.10.2",
    "immer": "^9.0.1",
    "lodash": "^4.17.15",
    "qs": "^6.9.1",
    "react-error-boundary": "^1.2.5",
    "react-helmet": "^5.2.1",
    "react-intl": "^5.12.2",
    "react-is": "^16.13.1",
    "react-markdown": "^6.0.0",
    "react-outside-click-handler": "^1.3.0",
    "react-query": "^3.6.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "react-use": "^13.22.3",
    "redux": "^4.0.5",
    "remark-breaks": "^2.0.2",
    "shallowequal": "^1.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/core": "^7.13.16",
    "@emotion/babel-preset-css-prop": "^11.2.0",
    "@openagenda/axios-mock-adapter": "^1.21.2",
    "@openagenda/babel-preset": "^1.4.1",
    "@openagenda/eslint-config": "^1.3.1",
    "@storybook/react": "^6.2.8",
    "axios": "^0.21.1",
    "eslint": "^6.8.0",
    "history": "^4.10.1",
    "lint-staged": "^10.2.11",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-helmet-async": "^1.0.3",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^16.12.0",
    "react-router": "^5.0.0",
    "react-router-dom": "^5.0.0"
  }
}
