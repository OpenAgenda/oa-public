{
  "name": "@openagenda/react-layouts",
  "version": "2.1.0",
  "main": "dist/index.js",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "yarn clean && yarn build",
    "build": "babel --copy-files src -d dist -s",
    "extract-messages": "yarn oa:extract-messages --messages-pattern 'dist/messages/**/*.json'",
    "clean": "rimraf dist",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.10.4",
    "@emotion/core": "^10.0.28",
    "@openagenda/activity-apps": "^1.1.13",
    "@openagenda/members": "^1.15.11",
    "@openagenda/react-components": "^2.3.8",
    "@openagenda/react-shared": "^2.0.6",
    "@openagenda/react-utils": "^4.2.5",
    "@openagenda/sessions": "^4.0.8",
    "classnames": "^2.2.6",
    "core-js": "^3.6.5",
    "lodash": "^4.17.15",
    "qs": "^6.9.1",
    "react-error-boundary": "^1.2.5",
    "react-helmet": "^5.2.1",
    "react-intl": "^3.11.0",
    "react-is": "^16.13.1",
    "react-markdown": "^4.3.1",
    "react-outside-click-handler": "^1.3.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "react-use": "^13.22.3",
    "redux": "^4.0.5",
    "remark-breaks": "^1.0.5",
    "shallowequal": "^1.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.10.4",
    "@babel/core": "^7.10.4",
    "@emotion/babel-preset-css-prop": "^10.0.27",
    "@openagenda/babel-preset": "^1.3.7",
    "@openagenda/eslint-config": "^1.2.4",
    "eslint": "^6.8.0",
    "lint-staged": "^10.2.11",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^16.12.0",
    "react-router": "^5.0.0",
    "react-router-dom": "^5.0.0"
  }
}
