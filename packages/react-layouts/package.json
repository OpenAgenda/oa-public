{
  "name": "@openagenda/react-layouts",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublish": "yarn clean && yarn build",
    "build": "babel --copy-files src -d dist -s",
    "extract-messages": "node scripts/extract-messages.js",
    "clean": "rimraf build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc '**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc",
      "git add"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.6.3",
    "@openagenda/activity-apps": "^1.1.2",
    "@openagenda/react-components": "^2.2.1",
    "@openagenda/react-utils": "^4.0.0",
    "classnames": "^2.2.6",
    "core-js": "^3.3.6",
    "lodash": "^4.17.15",
    "react-error-boundary": "^1.2.5",
    "react-intl": "^3.3.2",
    "react-is": "^16.10.2",
    "react-outside-click-handler": "^1.3.0",
    "react-redux": "^7.1.1",
    "react-router-config": "^5.1.1",
    "redux": "^4.0.1",
    "use-memo-one": "^1.1.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.6.3",
    "@babel/core": "^7.6.3",
    "@openagenda/babel-preset": "^1.1.1",
    "@openagenda/eslint-config": "^1.0.0",
    "babel-plugin-react-intl": "^4.1.20",
    "eslint": "^6.5.1",
    "glob": "^7.1.3",
    "lint-staged": "^9.4.2",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.11.0",
    "react-dom": "^16.11.0",
    "rimraf": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^16.11.0",
    "react-router-dom": "^5.0.0"
  }
}
