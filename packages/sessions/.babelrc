{
  "presets": [
    "stage-0",
    [
      "env",
      {
        "targets": {
          "browsers": [
            "last 2 versions",
            "Firefox >= 24",
            "Chrome >= 33",
            "Safari >= 9",
            "IE >= 10"
          ],
          "node": "6"
        }
      }
    ]
  ],
  "plugins": [
    "lodash",
    "transform-runtime",
    "add-module-exports"
  ]
}