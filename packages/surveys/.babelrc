{
  "presets": [
    [
      "env",
      {
        "targets": {
          "browsers": [
            "last 2 versions",
            "Firefox >= 24",
            "Chrome >= 33",
            "Safari >= 9",
            "IE >= 10"
          ],
          "node": "6"
        }
      }
    ],
    "react"
  ],
  "plugins": [
    "lodash",
    "transform-object-rest-spread",
    "transform-es3-member-expression-literals",
    "transform-es3-property-literals"
  ],
  "env": {
    "production": {
      "presets": [
        [
          "minify",
          {
            "evaluate": true,
            "mangle": false
          }
        ]
      ]
    }
  }
}