{
  "name": "@openagenda/call-to-action",
  "version": "2.2.2",
  "main": "index.js",
  "scripts": {
    "start": "concurrently -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "clean": "rimraf dist",
    "build": "babel src -d dist -s",
    "prepublish": "yarn clean && yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/openagenda/oa.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "homepage": "https://bitbucket.org/openagenda/oa/src/master/packages/call-to-action",
  "directories": {
    "test": "test"
  },
  "description": "",
  "dependencies": {
    "@babel/runtime-corejs2": "^7.3.1",
    "@openagenda/labels": "^2.1.0",
    "@openagenda/logs": "^1.1.1",
    "@openagenda/react-components": "^2.2.1",
    "@openagenda/react-form-components": "^2.1.1",
    "@openagenda/react-utils": "^4.0.0",
    "@openagenda/sessions": "^3.0.13",
    "lodash": "^4.17.4",
    "prop-types": "^15.6.0",
    "react-redux": "^6.0.0",
    "redux": "^4.0.1",
    "redux-form": "^8.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.2.2",
    "@babel/node": "^7.2.2",
    "@openagenda/bs-templates": "^2.2.0",
    "@storybook/react": "^4.1.11",
    "babel-loader": "^8.0.4",
    "babel-preset-openagenda": "^1.1.1",
    "concurrently": "^4.1.0",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.16.4",
    "morgan": "^1.8.2",
    "nodemon": "^1.18.9",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "rimraf": "^2.6.2"
  },
  "peerDependencies": {
    "react": "^16.8.6",
    "react-dom": "^16.8.6"
  }
}
