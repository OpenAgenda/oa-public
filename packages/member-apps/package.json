    "prop-types": "^15.5.8",
    "qs": "^6.9.1",
    "react-bootstrap": "^0.33.1",
    "react-final-form": "^6.3.3",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "redial": "^0.5.0",
    "regenerator-runtime": "^0.13.5"
  },
