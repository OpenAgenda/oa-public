{
  "extends": [
    "@openagenda"
  ],

  "parserOptions": {
    "sourceType": "script"
  },

  "rules": {
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          ".babelrc.js",
          ".storybook/**/*.js",
          "stories/**/*.js",
          "server.dev.js",
          "test/**/*.js",
          "testconfig.sample.js",
          "testconfig.js",
          "scripts/**/*.js"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "src/**/*.js",
        ".storybook/**/*.js",
        "stories/**/*.js",
        "server.dev.js",
        "test/**/*.js"
      ],

      "parserOptions": {
        "sourceType": "module"
      }
    },
    {
      "files": [
        "**/*.{test,spec}.js",
        "scripts/**/*.js"
      ],
      "rules": {
        "import/default": "off"
      }
    }
  ]
}
