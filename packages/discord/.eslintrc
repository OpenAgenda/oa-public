{
    "extends": "@openagenda",
  
    "parserOptions": {
      "sourceType": "script"
    },
  
    "rules": {
      "import/no-extraneous-dependencies": [
        "error",
        {
          "devDependencies": [
            "testconfig.sample.js"
          ]
        }
      ]
    },
  
    "overrides": [
      {
        "files": [
          "components/src/**/*.js"
        ],
        "parserOptions": {
          "sourceType": "module"
        }
      }
    ]
  }