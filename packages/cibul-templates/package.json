{
  "name": "@openagenda/cibul-templates",
  "version": "1.1.6",
  "description": "cibul templates library",
  "license": "MIT",
  "scripts": {
    "start": "nodemon --ignore build --ignore node_modules app.js",
    "build:dev": "bnr build:dev",
    "build:prod": "bnr build:prod"
  },
  "betterScripts": {
    "build:dev": {
      "command": "node --max_old_space_size=4096 prodify/prodify",
      "env": {
        "NODE_ENV": "development",
        "BABEL_ENV": "development"
      }
    },
    "build:prod": {
      "command": "node --max_old_space_size=4096 prodify/prodify",
      "env": {
        "NODE_ENV": "production",
        "BABEL_ENV": "production"
      }
    }
  },
