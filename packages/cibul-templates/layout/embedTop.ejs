<%
const nonceAttr = typeof cspNonce !== 'undefined' ? ` nonce="${cspNonce}"` : '';
%><!DOCTYPE html>
<html lang="<%= lang ;%>">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="shortcut icon" href="/images/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="language" content="<%= lang ;%>" />
    <% if ( typeof indexed !== 'undefined' && !indexed ) { %>
      <meta name="robots" content="noindex">
    <% } else { %>
      <meta name="robots" content="index, follow">
    <% } %>
    <% if ( metas.title ) { %>
      <title><%- __(metas.title); %></title>
    <% } %>
    <% include ./metas.part.ejs %>
    <% include ./css.part.ejs %>
    <% include ./js.part.ejs %>
    <!--[if lt IE 9]>
    <script src="https://oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"<%- nonceAttr; %>></script>
  <![endif]-->
    <% if ( typeof top !== 'undefined' ) { %>
      <% if ( top.linkTags ) { %>
        <% top.linkTags.forEach( function(link) { %>
          <%- link; %>
        <% }); %>
      <% } %>
    <% } %>
    <script type="text/javascript"<%- nonceAttr; %>>
      window.templates = 'bs';
      if (!window.oa) window.oa = {};
      window.oa.domain = '<%= typeof domain === 'undefined' ? 'openagenda.com' : domain ;%>';
    </script>
    <% if ( typeof preloaded !== 'undefined' ) { %>
      <script type="text/javascript"<%- nonceAttr; %>>window.__PRELOADED__ =<%= preloaded ;%>;</script>
    <% } %>
  </head>
  <body<% if ( typeof pageClass !== 'undefined' ) { %> class="<%= pageClass %>"<% } %> data-options="<%- typeof scriptParams !== 'undefined' ? _esc( JSON.stringify( scriptParams ) ) : '' %>">
