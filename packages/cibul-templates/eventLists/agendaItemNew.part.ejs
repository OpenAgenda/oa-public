<article class="row">
  <aside class="col-sm-3 event-aside">
    <div>
<% if ( typeof event.featured !== 'undefined' && event.featured ) { %>
      <span class="featured"><i class="fa fa-thumb-tack"></i> <%= __( 'featured' ) %></span>
<% } %>
      <span class="time-count js_relative_time" data-relative-time="<%= event.closestDate %>"></span>
    </div>
  </aside>
  <section class="col-sm-9">
    <a class="event-card" href="<%= event.link %>">
      <span class="fav js_fav_item" data-event-uid="<%= event.uid %>"><i class="fa fa-star-o"></i></span>
      <h3 class="event-title"><%= event.title %></h3>
<% if ( event.image ) { %>    
      <div class="event-img">
        <img class="img-responsive" src="<%= event.image %>" width="568" height="213">
      </div>
<% } %>
      <div class="event-text">
        <p><%= event.description %></p>
        <ul class="metas">
          <li><i class="fa fa-clock-o"></i> <%= event.dateRange %></li>
          <li>
<% if (event.attendanceMode == 2) { %>
            <i class="fa fa-link"></i>
            <%= __( 'online' ) %>
<% } else { %>
            <i class="fa fa-map-marker"></i>
            <%= event.placeName %><% if ( ( typeof event.city !== 'undefined' ) && event.city ) { %>, <%= event.city %><% } %>
<% } %>
          </li>
<% if ( event.organization ) { %>
          <li data-slug="<%= event.organization.slug %>" class="org">
              <i class="fa fa-university"></i>
            <%= event.organization.label %>
          </li>
<% } %>
        </ul>
      </div>
    </a>
    <a class="event-action" type="button" href="<%= event.importUri %>">
      <img alt="logo" src="https://oastatic.s3.eu-central-1.amazonaws.com/whitelogo22.png">
      <span><%= __('share') %></span> 
    </a>
  </section>
</article>