<div class="cb e404">
  <div class="canvas center">
    <div class="errorLabel"><%= typeof code !== 'undefined' ? code : 500 %></div>
    <div>
<% if ( message ) { %>
      <p><%= __( message ) %>.</p>
<% } else if ( typeof code !== 'undefined' ) { %>
      <p><%= __( ( {
        401 : 'You are not authorized to access this page',
        403 : 'You do not have the credentials to access this page',
        404 : 'The page you requested does not exist' ,
        500 : 'There was a little technical problem. We are working on resolving it.'
      } )[ code ] ) %></p>
<% } else { %>
  <p><%= __( 'There was a little technical problem. We are working on resolving it.' ) %>.</p>
<% } %>
<% if ( link ) { %>
      <a class="url" href="<%= genUrl( link.uri, link.values ) %>"><%= __( link.label ) %></a>
<% } %>
    </div>
    <div class="search">
      <form class="cform csingle bigger" method="get" action="/events/search">
        <input type="text" name="search[what]" value="<%= search && ( typeof search.what !== 'undefined' ) ? search.what : '' %>"/>
        <button type="submit">
          <i class="fa fa-search"></i>
        </button>
      </form>
    </div>
  </div>
</div>
