<dl class="event-item-info">
<% for ( var i in custom ) { %>
<% if ( custom[ i ].value ) { %>
<% if ( custom[ i ].fieldType == 'url' ) { %>
  <dt class="<%= typeof private !== 'undefined' && private ? 'privateable' : '' %>">
    <span><%= labels[ custom[ i ].name ] %></span>
    <% if ( typeof private !== 'undefined' && private ) { %><%- private %><% } %>
  </dt>
  <dd>
    <a target="_blank" href="<%= custom[ i ].value %>"><%= custom[ i ].value %></a>
  </dd>
<% } else if ( custom[ i ].fieldType === 'file' ) { %>
  <dt class="<%= typeof private !== 'undefined' && private ? 'privateable' : '' %>">
    <span><%= labels[ custom[ i ].name ] %></span>
    <% if ( typeof private !== 'undefined' && private ) { %><%- private %><% } %>
  </dt>
  <dd>
    <a target="_blank" href="<%= custom[ i ].value.link %>"><%= custom[ i ].value.name %></a>
  </dd>
<% } else if ( custom[ i ].fieldType == 'image' ) { %>
  <dt></dt>
  <dd class="image">
    <img src="<%= _i( custom[ i ].value ) %>" alt="<%= labels[ custom[ i ].name ] %>" />
  </dd>
<% } else if ( custom[ i ].fieldType == 'checkbox' ) { %>
  <% if ( !!(custom[ i ].value instanceof Array ? custom[ i ].value.length : custom[ i ].value ) ) { %><dt><%= labels[ custom[ i ].name ] %></dt><% } %>
<% } else if ( custom[ i ].fieldType == 'email' ) { %>
  <dt class="<%= typeof private !== 'undefined' && private ? 'privateable' : '' %>">
    <span><%= labels[ custom[ i ].name ] %></span>
    <% if ( typeof private !== 'undefined' && private ) { %><%- private %><% } %>
  </dt>
  <dd>
    <a href="mailto:<%= custom[ i ].value %>"><%= custom[ i ].value %></a>
  </dd>
<% } else if ( custom[ i ].label && [ 'radio', 'checkbox', 'select', 'multichoice' ].indexOf( custom[ i ].fieldType ) !== -1 ) { %>
  <dt class="<%= typeof private !== 'undefined' && private ? 'privateable' : '' %>">
    <span><%= labels[ custom[ i ].name ] %></span>
    <% if ( typeof private !== 'undefined' && private ) { %><%- private %><% } %>
  </dt>
  <dd>
    <span><%= typeof custom[ i ].label == 'string' ? custom[ i ].label : custom[ i ].label.join( ', ' )  %></span>
  </dd>
<% } else if ( custom[ i ].label && custom[ i ].fieldType === 'wysiwyg' ) { %>
  <dt class="<%= typeof private !== 'undefined' && private ? 'privateable' : '' %>">
    <span><%= labels[ custom[ i ].name ] %></span>
    <% if ( typeof private !== 'undefined' && private ) { %><%- private %><% } %>
  </dt>
  <dd>
    <span><%- custom[ i ].value %></span>
  </dd>
<% } else { %>
  <dt class="<%= typeof private !== 'undefined' && private ? 'privateable' : '' %>">
    <span><%= labels[ custom[ i ].name ] %></span>
    <% if ( typeof private !== 'undefined' && private ) { %><%- private %><% } %>
  </dt>
  <dd>
    <span><%= custom[ i ].value %></span>
  </dd>
<% } %>
<% } %>
<% } %>
</dl>
