<% if ( agenda ) { %>
<header class="agenda-header">
  <div class="container">
    <div class="row">
      <div class="col-sm-6 col-sm-offset-3 agenda-container">
        <a href="<%= genUrl('agendaShow', { slug: agenda.slug }) %>">
<% if ( agenda.image ) { %>
          <img class="avatar" src="<%= _i( agenda.image ) %>" alt="<%= agenda.title %>">
<% } %>
          <strong><%= agenda.title %></strong>
        </a>
      </div>
    </div>
  </div>
</header>
<% } %>
<div id="content">
  <div class="container share-page">
    <div class="row">
      <div class="col-sm-offset-3 col-sm-6 text-center">
        <h1><a href="<%= event.url %>"><%= event.title %></a></h1>
<% if ( back ) { %>
        <a href="<%= back %>"><%= __( 'go back to the agenda' ) %></a>
<% } else { %>
        <a href="<%= event.url %>"><%= __( 'go back to the event page' ) %></a>
<% } %>
      </div>
    </div>
    <div class="row text-left">
      <div class="col-sm-offset-3 col-sm-6 share-menu">
        <% include ./actionContent.part.ejs %>
      </div>
    </div>
  </div>
</div>
<% include ../bsLayout/footer.part.ejs %>
