<div id="admin-bar" class="edge-bar js_admin_controls display-none">
  <ul class="edge-list"><!--
    --><li class="edge-item w25 js_admin_item js_role_agenda_admin js_role_agenda_moderator">
      <div class="admin-nav">
<% if ( !!adminNav ) { %>
        <a class="nav-link prev edge-link<% if ( adminNav && adminNav.first ) { %> inactive<% } %>" href="<%= adminNav && adminNav.first ? '#' : genUrl( 'agendaEventAdminNavigate', [ { slug: slug, nav: 'prev', admin_nav: adminNav } ] ) %>">
          <i class="fa fa-chevron-left"></i>
        </a>
<% } %>
        <a class="edge-link center" rel="nofollow" data-href="<%= genUrl( 'agendaAdminShow', [ adminNav, { slug: slug } ] ) %>">
          <i class="fa fa-list"></i>
          <span><%= __( 'backToDashboard' ) %></span>
        </a>
<% if ( !!adminNav ) { %>
        <a class="nav-link next edge-link<% if ( adminNav && adminNav.last ) { %> inactive<% } %>" href="<%= adminNav && adminNav.last ? '#' : genUrl( 'agendaEventAdminNavigate', [ { slug: slug, nav: 'next', admin_nav: adminNav } ] ) %>">
          <i class="fa fa-chevron-right"></i>
        </a>
<% } %>
      </div>
    </li><!--
    --><li class="edge-item js_toggle w25 js_can_change_state display-none" data-toggle="js_dropdown_menu">
      <span class="edge-selected state <%= states[`state${indexedEvent.state}`].baseClass %>">
        <i class="sticker"></i>
        <span><%= __( 'state' ) %>: <%= __(states[`state${indexedEvent.state}`].label ) %></span>
      </span>
      <ul class="list-group js_dropdown_menu w380">
<% for( var i in states ) { %>
<% if ( !states[ i ].hideAction ) { %>
        <li class="list-group-item <%= states[ i ].classNames %>">
          <a data-href="<%= states[ i ].type !== null ? `/${slug}/events/${indexedEvent.slug}/state/${states[ i ].type}?redirect=${redirect}` : '#' %>" class="item bullet <% if ( i !== `state${indexedEvent.state}` ) { %> active<% } %>" rel="nofollow">
            <label><%= __( states[ i ].label ) %></label>
            <span><%= __( states[ i ].label + 'Info' ) %></span>
          </a>
        </li>
<% } %>
<% } %>
      </ul>
    </li><!--
 --><li class="edge-item js_toggle w25 js_cannot_change_state display-none" data-toggle="js_dropdown_menu">
      <span class="edge-selected state <%= states[`state${indexedEvent.state}`].baseClass %>">
        <i class="sticker"></i>
        <span><%= __( 'state' ) %>: <%= __( states[`state${indexedEvent.state}`].label ) %></span>
      </span>
      <ul class="list-group js_dropdown_menu w380">
        <li class="list-group-info-item">
          <span><%= __( states[`state${indexedEvent.state}`].label + 'ContributorInfo' ) %></span>
          <div class="margin-top-sm">
            <a class="btn btn-primary" href="/<%= slug %>/events/<%= indexedEvent.slug %>/contact"><%= __( 'contactAdministrators' ) %></a>
          </div>
        </li>
      </ul>
    </li><!--
    --><li class="edge-item js_admin_item js_role_agenda_admin js_role_agenda_moderator js_role_event_editor w25">
      <a class="edge-link" href="<%= `/${slug}/contribute/event/${indexedEvent.uid}?redirect=${redirect}` %>" rel="nofollow"><%= __( 'edit' ) %></a>
    </li><!--
    --><li class="edge-item js_admin_item js_role_event_editor js_role_agenda_admin js_toggle w25" data-toggle="js_dropdown_menu">
      <div class="edge-selected edge-head">
        <div class="edge-head-title"><%= __( 'actions') %></div>
        <div class="edge-head-info"><%= __('actionsInfo') %></div>
      </div>
      <ul class="list-group js_dropdown_menu">
        <li class="list-group-item js_admin_item js_role_agenda_admin js_role_agenda_moderator">
<% if ( indexedEvent.featured ) { %>
          <a class="item starify active" href="<%= `/${slug}/events/${indexedEvent.slug}/featured/notfeatured?redirect=${redirect}` %>" rel="nofollow"><span><label><%= __( 'featured' ) %></label></span><span class="hovered"><label><%= __('removeFromFeatured') %></label></span><span><%= __('featuredInfo') %></span><span class="hovered"><%= __('featuredInfo') %></span><i class="fa fa-thumb-tack"></i><i class="fa fa-thumb-tack"></i></a>
<% } else { %>
          <a class="item starify active" href="<%= `/${slug}/events/${indexedEvent.slug}/featured/featured?redirect=${redirect}` %>" rel="nofollow"><label><%= __('addToFeatured') %></label><i class="fa fa-thumb-tack-o"></i><i class="fa fa-thumb-tack"></i><span><%= __('featuredInfo') %></a>
<% } %>
        </li>
<% if ( hasOwnershipTransfer ) { %>
        <li class="list-group-item js_role_agenda_moderator js_ownership_transfer" data-res="/<%= slug %>/admin/members/transfer/<%= indexedEvent.slug %>">
          <a class="item active" rel="nofollow"><label><%= __( 'transferOwnership' ) %></label></a>
        </li>
<% } %>
        <li class="list-group-item js_admin_item js_role_event_editor">
          <a class="item active js_duplicate_event_link" href="/<%= slug %>/event/<%= indexedEvent.slug %>/duplicate" rel="nofollow"><label><%= __('duplicate') %></label><span><%= __('duplicateInfo') %></span></a>
        </li>
<% if (useDetailedStatusActions) { %>
        <li class="list-group-item w25 divider">
          <a
            class="item <% if (indexedEvent.status !== 1) { %>active<% } %> js_status display-none"
            href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}&status=1` %>"
            rel="nofollow"
          >
            <label><%= __('markAsScheduled') %></label>
            <span><%= __('statusScheduledInfo') %></span>
          </a>
        </li>
        <li class="list-group-item w25">
          <a
            class="item <% if (indexedEvent.status !== 2) { %>active<% } %> js_status display-none"
            href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}&status=2` %>"
            rel="nofollow"
          >
            <label><%= __('markAsRescheduled') %></label>
            <span><%= __('statusRescheduledInfo') %></span>
          </a>
        </li>
        <li class="list-group-item w25">
          <a
          class="item <% if (indexedEvent.status !== 3) { %>active<% } %> js_status display-none"
          href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}&status=3` %>"
          rel="nofollow"
          >
          <label><%= __('markAsMovedOnline') %></label>
          <span><%= __('statusMovedOnlineInfo') %></span>
        </a>
      </li>
      <li class="list-group-item w25">
        <a
          class="item <% if (indexedEvent.status !== 4) { %>active<% } %> js_status display-none"
          href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}&status=4` %>"
          rel="nofollow"
        >
          <label><%= __('markAsPostponed') %></label>
          <span><%= __('statusPostponedInfo') %></span>
        </a>
      </li>
      <li class="list-group-item w25">
        <a
          class="item <% if (indexedEvent.status !== 5) { %>active<% } %> js_status display-none"
          href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}&status=5` %>"
          rel="nofollow"
        >
          <label><%= __('markAsFull') %></label>
          <span><%= __('statusFullInfo') %></span>
        </a>
      </li>
      <li class="list-group-item w25 divider-bottom">
        <a
          class="item <% if (indexedEvent.status !== 6) { %>active<% } %> js_status display-none"
          href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}&status=6` %>"
          rel="nofollow"
        >
          <label><%= __('markAsCancelled') %></label>
          <span><%= __('statusCancelledInfo') %></span>
        </a>
      </li>
<% } else { %>
        <li class="list-group-item w25 divider divider-bottom">
          <a
            class="item active js_status display-none"
            href="<%= `/${slug}/events/${indexedEvent.slug}/status?redirect=${redirect}` %>"
            rel="nofollow"
          >
            <label><%= __(isCancelled ? 'uncancelEvent' : 'cancelEvent') %></label>
            <span><%= __(isCancelled ? 'uncancelInfo' : 'cancelInfo') %></span>
          </a>
        </li>
<% } %>
        <li class="list-group-item w25 js_disabled_status display-none">
          <a class="item" title="<%= __('cannotChangeStatus') %>" rel="nofollow">
            <label><%= __('cannotChangeStatus') %></label>
            <span><%= __('cannotChangeStatusInfo') %></span>
          </a>
        </li>
        <li class="list-group-item js_request_edition_rights display-none">
          <a class="item active" href="<%= `/${slug}/admin/events/${indexedEvent.slug}/edition-request?redirect=${redirect}` %>" rel="nofollow">
            <label><%= __('requestEditionRights') %></label>
            <span><%= __('requestEditionRightsInfo') %></span>
          </a>
        </li>
        <li class="list-group-item js_role_agenda_moderator js_role_event_editor w25">
          <a class="item active <% if (isOriginAgenda) { %>js_message_confirm<% } %>" data-confirm="<%= __( 'areYouSureToDelete' ) %>" data-ok="<%= __( 'confirm' ) %>" data-cancel="<%= __( 'cancel' ) %>" href="<%= `/${slug}/events/${indexedEvent.slug}/remove${removeRedirect ? '?redirect=' + removeRedirect : ''}` %>" rel="nofollow"><label><%= __(isOriginAgenda ? 'delete' : 'remove') %></label><span><%= __(isOriginAgenda ? 'deleteInfo' : 'removeInfo') %></span></a>
        </li>
      </ul>
    </li>
  </ul>
</div>
