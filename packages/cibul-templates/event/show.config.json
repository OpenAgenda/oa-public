{
  "layout": "bsLayout/main",
  "labels": "event/show",
  "bsCss": {
    "main": "/node_modules/@openagenda/bs-templates/compiled/main.css"
  },
  "helpers": {
    "_t": "time",
    "_i": "image",
    "_sl": "shareLinks",
    "_txt": "text",
    "_r": "redirect"
  },
  "base": {
    "pageId": "event",
    "indexed" : true,
    "event": {
      "owner": false
    },
    "hasCustomFields": false,
    "hasOwnershipTransfer": false,
    "mailto" : false,
    "impairments": {
      "hi": "accessibleToHearing",
      "pi": "accessibleToMentally",
      "mi": "accessibleToMotor",
      "vi": "accessibleToVisually",
      "sl": "signLanguageAvailable"
    },
    "adminNav": {},
    "states": {
      "draft": {
        "label": "draft",
        "type": null,
        "agendaOnly": false,
        "hideAction": true,
        "classNames": "js_role_event_editor js_role_agenda_moderator js_role_agenda_admin"
      },
      "refused" : {
        "label" : "refused",
        "type": -1,
        "agendaOnly" : true,
        "classNames" : "js_role_agenda_admin js_role_agenda_moderator"
      },
      "tocontrol": {
        "label": "toComplete",
        "type": 0,
        "agendaOnly": true,
        "classNames": "js_role_agenda_admin js_role_agenda_moderator"
      },
      "controlled": {
        "label": "readyForPublishing",
        "type": 1,
        "agendaOnly": true,
        "classNames": "js_role_agenda_admin js_role_agenda_moderator"
      },
      "published": {
        "label": "published",
        "type": 2,
        "agendaOnly": false,
        "classNames": "js_role_event_editor js_role_agenda_admin js_moderator_can_publish"
      }
    },
    "showRequestLocation" : true
  },
  "js": true
}
