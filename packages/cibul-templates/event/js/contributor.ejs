<div class="event-secondary">

  <h3 class="privateable">
    <span><%= contributorTitle %></span>
    <div class="private-label">
      <i class="fa fa-unlock-alt"></i>
      <span><%= privateInfo %></span>
    </div>
  </h3>

  <div class="event-content">
    <dl class="event-content-section event-item-info">
<% Object.keys( data ).forEach( function( field ) { %>
      <dt><%= labels[ field ] %></dt>
      <dd><%= data[ field ] %></dd>
<% } ) %>
    </dl>
  </div>

</div>