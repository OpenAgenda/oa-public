<div class="popup-overlay js_close_popup">
  <section>
    <header class="popup-title">
      <h2><%= __( 'Ownership transfer' ) %></h2>
      <a class="close-link" href=""><i class="fa fa-times fa-lg"></i></a>
    </header>
    <div class="js_popup_content popup-content">
      <p><%= __( 'Type the email of the user to which you want to handover this event') %></p>
      <form class="form-inline" method="post" action="<%= res %>">
        <div class="form-group">
          <input class="form-control" type="email" placeholder="email" name="email" style="width:20em;"/>
        </div>
        <button type="submit" class="btn btn-primary"><%= __( 'Transfer' ) %></button>
      </form>
    </div>
  </section>
</div>
