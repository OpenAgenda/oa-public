<%
  function locationPart(e, l) {
    const data = e.location[l];

    if (typeof data === 'string') {
      return data;
    }

    const v = data[lang];

    if (v === 'France (Métropole)') {
      return null;
    }

    return v;
  }
%>

<% include ./adminBar.part.ejs %>

<header class="agenda-header">
  <div class="container">
    <div class="row">
      <div class="col-sm-10 col-sm-offset-1 agenda-container">
        <a href="<%= backLink %>">
<% if (image) { %>
          <img class="avatar" src="<%= _i(image) %>" alt="<%= title %>">
<% } %>
          <strong><%= title %></strong>
          <span>(<%= __('seeAllEvents') %>)</span>
        </a>
      </div>
    </div>
  </div>
</header>
<div id="content" class="js_page_body">
  <div class="container">
    <div class="row">

      <section class="col-sm-7 col-sm-offset-1 col-xs-12">

<% if (indexedEvent.languages) { %>
        <div class="langs">
          <ul>
<% indexedEvent.languages.forEach(l => { %>
<% if (l.code === lang) { %>
            <li class="current"><a><%= l.code %></a></li>
<% } else { %>
            <li><a hreflang="<%= l.code %>" href="<%= l.link %>"><%= l.code %></a></li>
<% } %>
<% }) %>
          </ul>
        </div>
<% } %>

        <div class="event-content margin-print-bottom-lg">
          <span class="print-permalink display-none padding-bottom-sm"><%= __('printPermalink') %>: <%= indexedEvent.permalink %></span>
<% if (indexedEvent.status.id > 1) { %>
          <div class="padding-h-md padding-top-md status">
<% if (indexedEvent.status.id === 2) { %>
            <span
              title="<%= __('statusRescheduledInfo') %>"
              class="label label-warning"
            ><%= __('statusRescheduled') %></span>
<% } else if (indexedEvent.status.id === 3) { %>
            <span
              class="label label-warning"
              title="<%= __('statusMovedOnlineInfo') %>"
            ><%= __('statusMovedOnline') %></span>
<% } else if (indexedEvent.status.id === 4) { %>
            <span
              class="label label-warning"
              title="<%= __('statusPostponedInfo') %>"
            ><%= __('statusPostponed') %></span>
<% } else if (indexedEvent.status.id === 5) { %>
            <span
              class="label label-danger"
              title="<%= __('statusFullInfo') %>"
            ><%= __('statusFull') %></span>
<% } else if (indexedEvent.status.id === 6) { %>
            <span
              class="label label-danger"
              title="<%= __('statusCancelledInfo') %>"
            ><%= __('statusCancelled') %></span>
<% } %>
          </div>
<% } %>
          <h1><%= indexedEvent.title %></h1>
          <p class="short-description"><%= indexedEvent.description %></p>
        </div>
      </section>

      <aside class="col-sm-4 col-aside sidebar col-xs-12">
        <div class="sidebar-content padding-print-h-z">
          <section class="detail-item margin-bottom-xs shares">
            <h3><i class="fa fa-share-alt"></i></h3>
            <div class="detail-item-content">
              <div class="js_shareOnOa"></div>
            </div>
          </section>
          <section class="detail-item share margin-bottom-md margin-top-xs shares">
            <%= __('otherShares') %>&nbsp;:
            <% if (!indexedEvent.private && (indexedEvent.state === 2)) { %>
              <a
                href="<%= indexedEvent.facebookShare %>"
                target="_blank"
                class="fb text-muted"
                rel="nofollow"
              ><i class="fa fa-facebook"></i></a>
            <% } else { %>
              <a
                disabled
                class="fb text-muted"
                rel="nofollow"
                title="<%= __('cannotShareInfo') %>"
              ><i class="fa fa-facebook"></i></a>
            <% } %>
            <% if (!indexedEvent.private && (indexedEvent.state === 2)) { %>
              <a
                href="<%= indexedEvent.twitterShare %>"
                target="_blank"
                class="tw text-muted"
                rel="nofollow"
              ><i class="fa fa-twitter"></i></a>
            <% } else { %>
              <a
               disabled
               class="tw text-muted"
               rel="nofollow"
               title="<%= __('cannotShareInfo') %>"
              ><i class="fa fa-twitter"></i></a>
            <% } %>
            <% if (!indexedEvent.private && (indexedEvent.state === 2)) { %>
              <a
                href="<%= indexedEvent.linkedInShare %>"
                target="_blank"
                class="li text-muted"
                rel="nofollow"><i class="fa fa-linkedin"></i></a>
            <% } else { %>
              <a
                disabled
                class="li text-muted"
                rel="nofollow"
                title="<%= __('cannotShareInfo') %>"
              ><i class="fa fa-linkedin"></i></a>
            <% } %>
            <% if (!indexedEvent.private && (indexedEvent.state === 2)) { %>
              <div class="js_shareEmail share-button"></div>
            <% } else { %>
              <a
                disabled
                class="text-muted"
                rel="nofollow"
              ><i class="fa fa-envelope-o"></i></a>
            <% } %>
            <a href="#" class="text-muted js_print"><i class="fa fa-print"></i></a>
            <a title="<%= __('copyInClipboard') %>" href="<%= indexedEvent.permalink %>" class="js_permalink text-muted"><i class="fa fa-link"></i></a>
            <% if (!indexedEvent.private && (indexedEvent.state === 2)) { %>
              <div class="js_shareAll share-button">
                <%= __('allShares') %>
              </div>
            <% } else { %>
              <a
                disabled
                class="text-muted"
                rel="nofollow"
                title="<%= __('cannotShareInfo') %>"
              ><%= __('allShares') %></a>
            <% } %>
          </section>
          <div class="row">
            <div class="col-sm-12 col-print-6 padding-print-h-z">
              <% if (indexedEvent.onlineAccessLink) { %>
              <section class="detail-item margin-bottom-md online-access-link">
                <h3><i class="fa fa-link"></i></h3>
                <a
                  target="_blank"
                  href="<%= indexedEvent.onlineAccessLink %>"
                  class="btn btn-default"
                ><%= __('onlineAccess') %></a>
                <span class="display-none"><%= indexedEvent.onlineAccessLink %></span>
              </section>
              <% } %>
              <section class="detail-item margin-bottom-sm">
                <h3><% if (indexedEvent.isUpcoming) { %><i class="fa fa-clock-o"></i><% } else { %><i class="fa fa-history"></i><% } %></h3>
                <p class="detail-item-content">
                  <span><%= indexedEvent.dateRange %></span>
                  <% if (!indexedEvent.isUpcoming) { %><span class="badge badge-outline-default margin-all-xs"><%= __('pastEvent') %></span><% } %>
                </p>
              </section>
              <% if (indexedEvent.conditions || indexedEvent.registration.length ) { %>
                <section class="detail-item conditions margin-v-md">
                  <h3><i class="fa fa-ticket"></i> <span>Conditions</span></h3>
                  <% if (indexedEvent.conditions) { %>
                  <div class="detail-item-content">
                    <p><%= indexedEvent.conditions %></p>
                  </div>
                  <% } %>
                  <% if (indexedEvent.registration.length) { %>
                  <ul class="registration">
                  <% indexedEvent.registration.forEach(registrationItem => { %>
                    <li>
                      <i class="fa <%= registrationItem.icon %>"></i>
                      <span>
                        <% if (typeof registrationItem.label !== 'undefined') { %>
                          <%= registrationItem.label %> :
                        <% } %>
                        <a href="<%= registrationItem.prefix %><%= registrationItem.value %>">
                          <%= registrationItem.value %>
                        </a>
                      </span>
                    </li>
                  <% }); %>
                  </ul>
                  <% } %>
                </section>
              <% } %>
            </div>
            <div class="col-sm-12 col-print-6 padding-print-h-z">
              <section class="detail-item timings margin-bottom-md">
                <% include _months.part.ejs %>
              </section>
              <% if (indexedEvent.availableAccessibilities.length) { %>
              <% indexedEvent.availableAccessibilities.forEach(i => { %>
              <section class="detail-item margin-v-sm">
                <h3><i class="acc <%= i %>"></i></h3>
                <p class="detail-item-content"><%= __(impairments[i]) %></p>
              </section>
              <% }) %>
              <% } %>
              <% if (indexedEvent.age?.min || indexedEvent.age?.max) { %>
                <section class="detail-item margin-v-md">
                  <h3><i class="fa fa-child"></i></h3>
                  <% if (!indexedEvent.age.max) { %>
                  <p class="detail-item-content"><%= __('startingAt', { min: indexedEvent.age.min }) %></p>
                  <% } else { %>
                  <p class="detail-item-content"><%= __('minToMaxYearsOld', { min: indexedEvent.age.min, max: indexedEvent.age.max }) %></p>
                  <% } %>
                </section>
              <% } %>
            </div>
          </div>
          <div class="row">
            <div class="col-sm-12 padding-print-h-z">
              <% if (hasLocation) { %>
              <section class="detail-item location-side margin-v-md">
                <h3><i class="fa fa-map-marker"></i></h3>
                <div class="detail-item-content">
                  <p>
                    <%- indexedEvent.location.name %><% /* escaped in model already */ %>
                  </p>
                  <span class="margin-right-xs"><a target="_blank" href="<%= indexedEvent.location.OSMItineraryLink || '#' %>"><%= indexedEvent.location.address %></a></span>
                  <ul class="info list-inline location-info-parts">
                  <% ['department', 'region', 'country'].forEach(function(part) { %>
                  <% if ( indexedEvent.location[part] && locationPart(indexedEvent, part) ) { %>
                    <li><span><%= locationPart(indexedEvent, part) %></span></li>
                  <% } %>
                  <% }); %>
                  </ul>
                </div><!--
                --><div
                    class="map js_map"
                    data-coord="<%= indexedEvent.location.latitude %>|<%= indexedEvent.location.longitude %>"
                    data-tiles="<%= tiles %>"
                  ></div>
              </section>
              <% } %>
              <% if (agendaReferences.length > 0) { %>
              <div class="sharers">
                <ul><!--
              <% agendaReferences.forEach( function( ref ) { %>
               --><li <% if ( !ref.image ) { %>class="empty"<% } %>>
                    <a href="<%= genUrl('agendaShow', { slug: ref.slug }) %>"><!--
                   --><img class="avatar" alt="<%= ref.title %>" src="<%= ref.image %>"/><!--
                   --><span><%= _txt.truncate(ref.title, 26, ' ...') %></span>
                    </a>
                  </li><!--
              <% }); %>
             --></ul>
              </div>
              <% } %>
            </div>
          </div>
          <section class="detail-item">
            <% include ../bsLayout/footer.part.ejs %>
          </section>
        </div>
      </aside>

      <section class="col-sm-7 col-sm-offset-1 col-xs-12">
        <div class="event-content">
          <div class="js_additional_fields_info"></div>
          <% if (indexedEvent.image && indexedEvent.image.filename) { %>
          <div class="row">
            <div class="col-xs-12 col-print-6">
              <img  class="img-responsive col-print-6" src="<%= indexedEvent.image.base %><%= indexedEvent.image.filename %>">
              <% if (indexedEvent.imageCredits) { %>
              <div class="credits margin-h-xs"><%= indexedEvent.imageCredits %></div>
              <% } %>
            </div>
          </div>
          <% } %>
          <div class="description event-content-section"><%- indexedEvent.longDescription %></div>

<% if (typeof indexedEvent.keywords !== 'undefined' && indexedEvent.keywords.length) { %>
          <div class="keywords">
            <span><%= indexedEvent.keywords.join(', ') %></span>
          </div>
<% } %>

        </div>

        <div class="js_references"></div>

        <div class="js_additional_fields"></div>

<% if (hasLocation) { %>
    <div class="location-details event-secondary">
      <h3><%= __( 'aboutTheVenue' ) %></h3>
      <div class="event-content">

        <div class="location-head">
        <% if (indexedEvent.location.agendaUid === agenda.uid) { %>
          <div class="display-none js_edit_location pull-right">
            <a class="btn btn-default" rel="nofollow" href="/<%= slug %>/admin/locations/<%= indexedEvent.location.uid %>/edit?uids[]=<%= indexedEvent.location.uid %>"><%= __('editLocation') %></a>
          </div>
        <% } %>

          <label>
            <%- indexedEvent.location.name %>
          </label>
          <span><a target="_blank" href="<%= indexedEvent.OSMItineraryLink || '#' %>"><%- indexedEvent.location.address %></a></span>
<% if (indexedEvent.location.tags && indexedEvent.location.tags.length ) { %>
          <div class="tags">
            <label><%= __( 'tags' ) %>:</label>
            <ul>
<%- indexedEvent.location.tags.map( t => {
    return '<li>' + _txt.escape( t.label ) + '</li>';
}).join( ', ' ) %>
            </ul>
          </div>
<% } %>
        </div>

<% if ( indexedEvent.location.description ) { %>
        <p><%- indexedEvent.location.description %></p>
<% } %>
<% if ( indexedEvent.location.access ) { %>
        <p>
          <strong><%= __( 'access' ) %>:</strong>
          <span><%- indexedEvent.location.access %></span>
        </p>
<% } %>
<% if (indexedEvent.location.image) { %>
        <div class="location-image row">
          <div class="col-xs-12 col-print-6">
            <img class="img-responsive" src="<%= indexedEvent.location.image %>" alt="<%= indexedEvent.location.name %>" />
            <% if ( indexedEvent.location.imageCredits ) { %>
            <span class="credits"><%= indexedEvent.location.imageCredits %></span>
            <% } %>
          </div>
        </div>
<% } %>

<% if (
  indexedEvent.location.website
  || indexedEvent.location.phone
  || indexedEvent.location.links?.length
  || showRequestLocation
) { %>
        <ul class="list-unstyled">
<% if (indexedEvent.location.website) { %>
          <li>
            <i class="fa fa-globe"></i>
            <a href="<%= indexedEvent.location.website %>">
              <span><%= indexedEvent.location.website %></span>
            </a>
          </li>
<% } %>
<% if (indexedEvent.location.phone) { %>
          <li>
            <i class="fa fa-phone"></i>
            <a href="tel:<%= indexedEvent.location.phone %>">
              <span><%= indexedEvent.location.phone %></span>
            </a>
          </li>
<% } %>
<% if (indexedEvent.location.links && indexedEvent.location.links.length) { %>
          <li class="location-hlinks">
            <label><%= __('moreLinks') %></label>:
<% indexedEvent.location.links.forEach(function(link) { %>
            <a href="<%= link %>" target="_blank"><%= link %></a>
<% }); %>
          </li>
<% } %>

<% if ( showRequestLocation ) { %>
          <li>
            <a class="btn btn-default" rel="nofollow" href="<%= `/${slug}/locations/${uid}.${indexedEvent.location.uid}/suggest-change` %>">
              <%= __( 'requestChangeLocation' ) %>
            </a>
          </li>
<% } %>
          </ul>
<% } %>
      </div>
    </div>
<% } %>

    <div class="js_contributor"></div>

    <div class="js_activities activity-section"></div>
<% if ( mailto?.enabled ) { %>
    <h3 class="margin-top-lg"><%= __( 'contactEmail' ) %></h3>
    <div class="padding-all-md wsq" style="text-align: center;">
      <a href="mailto:<%= mailto.email %>?subject=<%= mailto.subject %>" class="btn btn-primary"><%= __( 'contactEmailButton' ) %></a>
    </div>
<% } else { %>
    <div class="display-none js_inbox_event_canvas inbox-section" id="inbox">
      <div class="event-secondary">
        <div class="js_inbox_event inbox"></div>
      </div>
    </div>
<% } %>

      </section>
    </div>
  </div>

</div>
<script type="application/ld+json">
  <%- indexedEvent.JSONLD %>
</script>
