<section>
  <div class="form-head">
    <h2><%= __('contributionNote') %></h2>
  </div>
  <form method="post" action="<%= genUrl( 'contributorsInfoSubmit', { slug: agenda.slug } ) %>">
    <div class="form-group">
      <label for="info"><%= __( 'provideGuidelines' ) %></label>
      <div>
        <textarea name="info" class="form-control"><%= info %></textarea>
      </div>
    </div>
    <div class="form-group bottom">
      <a href="<%= `/${agenda.slug}/admin/contributors` %>"><%= __('back') %></a>
      <button type="submit" class="btn btn-primary pull-right"><%= __('submit') %></button>
    </div>
  </form>
</section>
