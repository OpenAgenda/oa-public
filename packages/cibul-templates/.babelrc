{
  "presets": [
    "react",
    [
      "env",
      {
        "targets": {
          "browsers": [
            "last 2 versions",
            "Firefox >= 24",
            "Chrome >= 33",
            "Safari >= 9",
            "IE >= 10"
          ],
          "node": "6"
        },
        "useBuiltIns": "entry"
      }
    ]
  ],
  "plugins": [
    "lodash",
    "add-module-exports",
    "transform-decorators-legacy",
    "transform-react-display-name",

    "transform-object-rest-spread",
    "transform-class-properties",
    "transform-export-extensions",
    "transform-function-bind",
    "transform-runtime"
  ],
  "env": {
    "development": {
      "plugins": [
        [
          "react-transform",
          {
            "transforms": [
              {
                "transform": "react-transform-catch-errors",
                "imports": [
                  "react",
                  "redbox-react"
                ]
              }
            ]
          }
        ]
      ]
    }
  }
}