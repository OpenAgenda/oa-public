<div id="presentation" class="primary">
    <div class="container">
        <div class="spaced text-center">
            <h1 class="hook"><%= __( 'punchLine' ) %></h1>
            <p class="under-hook"><%= __( 'forYour' ) %> <br><span class="typed"><%= __( 'initialName' ) %></span></p>
            <div class="hook-action">
                <div class="row">
                    <div class="col-xs-offset-3 col-xs-6 col-sm-offset-4 col-sm-4">
                        <form action="<%= genUrl( 'agendaSearch' ) %>">
                            <div class="form-group input-icon-right search margin-v-md">
                                <input
                                    name="search"
                                    type="text"
                                    class="form-control input-lg"
                                    placeholder="<%= __( 'searchAnAgenda' ) %>"
                                />
                                <button type="submit" class="btn"><i class="fa fa-search" aria-hidden="true"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <p class="hook-secondary-action">
                <a href="/start?a=main" class="btn btn-primary btn-lg">
                    <%= __( 'createAnAgenda' ) %>
                </a>
            </p>
        </div>
    </div>
</div>

