      <li>
        <a href="/home/events"><%= __('myEvents') %></a>
      </li>
      <li>
        <a href="/settings"><%= __('settings') %></a>
      </li>
      <li>
        <a href="/signout"><%= __('signout') %></a>
      </li>
    </ul><!--
    --><ul>
      <li><h3><%= __( 'agendasTitle' ) %></h3></li>
      <li><a href="/home"><%= __( 'myAgendas' ) %></a></li>
      <li><a href="/agendas"><%= __( 'searchAgendas' ) %></a></li>
      <li><a href="/agendas/new"><%= __( 'createAgenda' ) %></a></li>
    </ul>
  </div>
</li>
