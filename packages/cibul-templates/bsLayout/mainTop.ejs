<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="shortcut icon" href="/images/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="language" content="<%= lang %>" />
<% if ( typeof indexed !== 'undefined' && !indexed ) { %><meta name="robots" content="noindex"><% } %>
<% if ( metas.title ) { %>
    <title><%- __( metas.title ) %></title>
<% } %>
    <% include ../layout/metas.part.ejs %>
    <% include ../layout/css.part.ejs %>

    <!--[if lt IE 9]>
      <script src="https://oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"></script>
    <![endif]-->
    <% if ( typeof top !== 'undefined' ) { %>
      <% if ( top.linkTags ) { %>
        <% top.linkTags.forEach( function( link ) { %>
          <%- link %>
        <% }); %>
      <% } %>
    <% } %>
    <script type="text/javascript">window.templates='bs';</script>
    <% if ( typeof preloaded !== 'undefined' ) { %>
    <script type="text/javascript">window.__PRELOADED__=<%= preloaded %>;</script>
    <% } %>
  </head>
  <body <% if ( pageId ) { %> id="<%= pageId %>"<% } %> class="<% if ( pageClass ) { %><%= pageClass %> <% } %>js_toggle" data-toggle="collapse"  data-options="<%- typeof scriptParams !== 'undefined' ? _esc( JSON.stringify( scriptParams ) ) : '' %>">
    <div id="outdated"></div>
    <nav class="oa-page-header navbar navbar-default navbar-static-top js_top_nav" id="nav">
      <div class="container">
        <div class="navbar-header">
          <button type="button" class="navbar-toggle collapsed js_toggle_trigger">
            <i class="fa fa-bars"></i>
          </button>
          <a class="navbar-brand" href="/">
            <img src="/images/openagenda.png" width="125" alt="OpenAgenda">
          </a>
        </div>
        <div class="navbar-collapse collapse">
          <form class="navbar-left search-form js_agenda_search" role="search" action="<%= genUrl( 'agendaSearch' ) %>">
            <input class="search-input" placeholder="<%= __('Search') %>" type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>">
<% if ( typeof lang !== 'undefined' && lang !== 'fr' ) { %>
            <input type="hidden" name="lang" value="<%= lang %>"/>
<% } %>
            <div class="search-button">
              <button class="search-submit" type="submit"><i class="fa fa-search"></i></button>
            </div>
          </form>
          <ul class="nav navbar-nav navbar-right js_header_links">
            <li>
              <div class="help-button-canvas">
                <a class="btn btn-primary btn-rounded btn-bordered" rel="nofollow" target="_blank" href="/support?origin=<%= encodeURIComponent( originalUrl ) %>">
                  <i class="fa fa-question-circle"></i>
                  <span><%= __( 'Help' ) %></span>
                </a>
              </div>
            </li>
            <li class="js_toggle language-menu js_not_logged js_language_menu" data-toggle="js_languages_menu">
              <a href="#"><% if ( lang === 'fr' ) { %>fr<% } else { %>en<% } %></a>
              <ul class="dropdown-menu js_languages_menu collapse">
<% [ 'fr', 'en' ].forEach( function( l ) { %>
<% if ( lang==l ) { %>
                <li><a href="?lang=<%= l %>" hreflang="<%= l %>" class="selected"><%= langLabels[ l ] %></a></li>
<% } else { %>
                <li><a rel="alternate" href="?lang=<%= l %>" hreflang="<%= l %>"><%= langLabels[ l ] %></a></li>
<% } %>
<% } ); %>
              </ul>
            </li>
            <li class="js_not_logged signin">
              <a class="js_signin_link" href="<%= genUrl('signin') %>"><%= __('Sign in') %></a>
            </li>
            <li class="inbox js_inbox_header hide">
              <a href="/home/inbox">
                <i class="fa fa-envelope" aria-hidden="true"></i>
              </a>
            </li>
            <li class="notifications js_notifications hide">
              <a class="js_notifications_opener">
                <i class="fa fa-bell" aria-hidden="true"></i>
                <span class="label label-danger hide"></span>
              </a>
              <div class="js_notifications_panel hide"></div>
            </li>
          </ul>
        </div>
      </div>
    </nav>
    <% /*<div class="alert alert-warning" style="margin-bottom:0;" role="alert"><i class="fa fa-alert"></i>
      <span>Une réindexation est en cours, ceci peut affecter temporairement l'affichage de vos agendas. Vous pouvez continuer de saisir des événements. Plus d'info sur <a target="_blank" href="https://twitter.com/oagendastatus">@oagendastatus</a></span>
    </div>*/ %>
