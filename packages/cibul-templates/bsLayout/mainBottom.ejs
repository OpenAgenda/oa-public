<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.5/js/bootstrap.min.js"></script>
<% if ( typeof bottom !== 'undefined' ) { %>
<% if ( typeof bottom.scriptSources !== 'undefined' ) { %>
<% bottom.scriptSources.forEach( function( src ) { %>
<script type="text/javascript" src="<%= src %>"></script>
<% } ); %>
<% } %>
<% if ( bottom.scripts ) { %>
<% bottom.scripts.forEach( function( script ) { %>
<script type="text/javascript"><%- script %></script>
<% }); %>
<% } %>
<% if ( bottom.scriptTags ) { %>
<% bottom.scriptTags.forEach( function( script ) { %>
<%- script %>
<% }); %>
<% } %>
<% } %>
<% include ../layout/js.part.ejs %>
</body>
</html>
