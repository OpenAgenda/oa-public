<li class="menu-item js_menu_item <%= 'js_menu_item_' + t.key %> <% if ( tab==t.key ) { %> selected<% } %> <% if ( typeof t.className !== 'undefined' ) { %><%= t.className %><% } %>">
  <a class="<% if ( tab==t.key ) { %> active<% } %>" href="<%= t.res || genUrl( t.uri, { slug: agenda.slug } ) + (t.suffix || '') %>">
<% if ( t.key === 'locations' ) { %>
    <span><%= t.label %></span>
    <span class="js_locations_counter" data-options="<%= JSON.stringify( {
      res: genUrl( 'locationToVerifyCount', { slug: agenda.slug } )
    } ) %>"></span>
<% } else if ( t.call ) { %>
    <span class="js_call_to_action" data-lang="<%= lang %>" data-subject="<%= t.call.subject %>" data-agenda="<%= t.call.agenda %>" style="opacity:0.3;">
      <%= t.label %>
      <i class="margin-sm-left golden-icon gi-20" style="vertical-align: middle;"></i><!-- Merci Kevin. :| "Mais c'est déjà mieux que rien"-->
    </span>
<% } else { %>
    <span><%= t.label %></span>
<% } %>
  </a>
<% if ( typeof t.badge !== 'undefined' ) { %>
  <a class="badge badge-primary" href="<%= t.badge.link %>" target="_blank">
    <%= t.badge.label %>
  </a>
<% } %>
</li>
