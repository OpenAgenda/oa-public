<% if ( agenda ) { %>
<%- include('../agenda/head.part.ejs') %>
<% } %>
<div class="container">
  <div class="row top-margined">
    <section class="col-sm-6 col-sm-offset-3 wsq">
      <div class="content">
        <h2><%= __( typeof title == 'undefined' ? 'Create an account' : title ) %></h2>
        <p><%= __( 'Complete the signup process by typing in your email' ) %></p>
      </div>
      <form class="content" method="get" action="<%= genUrl( uri, [ optionals, agenda ? { slug: agenda.slug } : {} ] ) %>">
        <div class="form-group">
          <label for="email"><%= __('Email') %></label>
          <input class="form-control" type="email" name="email" value="<%= email %>" />
<% if ( errors.email ) { %>
          <span class="error"><%= __( errors.email ) %></span>
<% } %>
        </div>
        <div class="form-group">
          <button class="btn btn-success" name="submit-email" type="submit"><%= __( 'Confirm Email' ) %></button>
        </div>
      </form>
    </section>
  </div>
</div>
