<% if ( agenda ) { %>
<% include ../agenda/head.part.ejs %>
<% } %>
<div class="container page-dialog signin">
  <div class="top-margined bottom-margined">
    <% include _headMessage.ejs %>
    <div class="row">
      <section class="col-sm-6 col-sm-offset-3 wsq padding-all-md">
        <div class="row">
          <div class="col-sm-12">
            <h2><%= __( 'connection' ) %></h2>
<% if ( typeof message !== 'undefined' || typeof errors.email !== 'undefined' || typeof errors.password !== 'undefined' ) { %>
<% if ( typeof message !== 'undefined' ) { %>
            <p class="bg-danger padding-all-sm"><%= __( message ) %></p>
<% } %>
<% if ( typeof errors.email !== 'undefined' ) { %>
            <p class="bg-danger padding-all-sm"><%= __( errors.email ) %></p>
<% } %>
<% if ( typeof errors.password !== 'undefined' ) { %>
            <p class="bg-danger padding-all-sm"><%- __( 'incorrectPassword' ) %> - <a href="<%- genUrl( 'lostPassword' ) %>"><%= __( 'resetPassword' ) %></a></p>              
            </p>
<% } %>
<% } %>
          </div>
        </div>

        <div class="row margin-top-md">
          <div class="col-md-6">
            <form class="margin-h-sm" method="post">
              <div class="form-group<%= errors.email ? ' has-error' : '' %>">
                <label for="email" class="control-label"><%= __('email') %></label>
                <input name="email" class="form-control" type="email"/>
<% if ( errors.email ) { %>
                <span class="text-danger"><%= __( errors.email ) %></span>
<% } %>
              </div>
              <div class="form-group<%= errors.password ? ' has-error' : '' %>">
                <label for="password" class="control-label"><%= __('password') %></label>
                <input name="password" class="form-control" type="password"/>
<% if ( errors.password ) { %>
                <span class="text-danger"><%= __( errors.password ) %></span>
<% } %>
              </div>
              <div class="form-group">
                <button
                  name="signin"
                  class="btn btn-primary"
                  type="submit"><%= __( 'signin' ) %></button>
              </div>
            </form>
          </div>
          <div class="col-md-6">
            <div class="margin-bottom-md">
              <a 
                href="<%= genUrl( agenda ? 'agendaFacebookSignin' : 'facebookSignin', [ optionals, agenda ? { slug: agenda.slug } : {} ] ) %>"
                class="btn btn-facebook btn-block">
                <i class="fa fa-facebook"></i>
                Facebook
              </a>
            </div>
            <div class="margin-bottom-md">
              <a
                href="<%= genUrl( agenda ? 'agendaGoogleSignin' : 'googleSignin', [ optionals, agenda ? { slug: agenda.slug } : {} ] ) %>"
                class="btn btn-google btn-block">
                <i class="fa fa-google"></i>
                Google
              </a>
            </div>
            <div>
              <a 
                href="<%= genUrl( agenda ? 'agendaTwitterSignin' : 'twitterSignin', [ optionals, agenda ? { slug: agenda.slug } : {} ] ) %>"
                class="btn btn-twitter btn-block">
                <i class="fa fa-twitter"></i>
                Twitter
              </a>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12 margin-v-md">
            <p><%= __( 'noAccount' ) %> <a href="<%= genUrl( agenda ? 'agendaSignup' : 'signup', [ optionals, agenda ? { slug: agenda.slug } : {} ] ) %>"><%= __('createAccount') %></a></p>
            <p><a href="<%= genUrl( 'lostPassword' ) %>"><%= __( 'lostPassword' ) %></a></p>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>