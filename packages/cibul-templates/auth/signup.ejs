<% if ( agenda && !agenda.private) { %>
  <%- include('../agenda/head.part.ejs') %>
<% } %>
<div class="container page-dialog signup">
  <div class="top-margined bottom-margined">
    <%- include('_headMessage.ejs') %>
    <div class="row">
      <section class="col-sm-6 col-sm-offset-3 wsq padding-all-md padding-bottom-lg">
        <div class="row">
          <div class="col-sm-12 margin-h-md">
            <h2><%= __( 'createAccount' ) %></h2>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12">
            <div class="info-block text-center margin-v-lg margin-h-md">
              <label><%= __( 'hasAccount' ) %></label>
              <a href="<%= signin %>" class="btn btn-primary"><%= __( 'connect' ) %></a>
            </div>
          </div>
        </div>
        <% if ( typeof message !== 'undefined' && message ) { %>
          <div class="row">
            <div class="col-sm-12">
              <p class="margin-h-md bg-danger padding-all-sm"><%= __( message ) %></p>
            </div>
          </div>
        <% } %>
        <div class="row margin-top-md">
          <div class="col-md-10 col-md-offset-1">
            <form id="signup-form" class="margin-h-md" method="post">
              <div class="form-group<%= errors.fullName ? ' has-error' : '' %>">
                <label for="full_name" class="control-label"><%= __( 'pseudonym' ) %></label>
                <input name="full_name" class="form-control js_full_name_input" value="<%= full_name %>" />
                <% if ( errors.fullName ) { %>
                  <span class="text-danger"><%= __( errors.fullName ) %></span>
                <% } else { %>
                  <span class="sub"><%= __( 'pseudonymSub' ) %> <a href="https://doc.openagenda.com/confidentialite/#votre-compte-utilisateur" target="_blank"><%= __( 'more' ) %></a></span>
                <% } %>
              </div>
              <div class="form-group<%= errors.email ? ' has-error' : '' %>">
                <label for="email" class="control-label"><%= __( 'email' ) %></label>
                <input name="email" class="form-control js_email_input" type="email" value="<%= email %>" />
                <% if ( errors.email ) { %>
                  <span class="text-danger"><%= __( errors.email ) %></span>
                <% } %>
              </div>
              <div class="js_password">
                <div class="form-group<%= errors.password ? ' has-error' : '' %>">
                  <label for="password" class="control-label"><%= __( 'password' ) %></label>
                  <input name="password" class="form-control" type="password" />
                  <% if ( errors.password ) { %>
                    <div class="text-danger js_password_sub"><%= __( errors.password ) %></div>
                  <% } %>
                </div>
              </div>
              <div class="form-group<%= errors.repeat ? ' has-error' : '' %>">
                <label for="repeat" class="control-label"><%= __( 'repeatPassword' ) %></label>
                <input name="repeat" class="form-control" type="password" />
                <% if ( errors.repeat ) { %>
                  <span class="text-danger"><%= __( errors.repeat ) %></span>
                <% } %>
              </div>
              <div class="form-group<%= errors.culture ? ' has-error' : '' %>">
                <label for="culture" class="control-label"><%= __( 'culture' ) %></label>
                <select
                  name="culture"
                  class="form-control"
                  value="<%= typeof culture !== 'undefined' ? culture : 'fr' %>"
                >
                  <option value="fr" <%= typeof culture === 'undefined' || !culture ? '' : 'selected' %>>
                    Français
                  </option>
                  <option value="en" <%= typeof culture !== 'undefined' && culture === 'en' ? 'selected' : '' %>>
                    English
                  </option>
                  <option value="de" <%= typeof culture !== 'undefined' && culture === 'de' ? 'selected' : '' %>>
                    Deutsch
                  </option>
                  <option value="es" <%= typeof culture !== 'undefined' && culture === 'es' ? 'selected' : '' %>>
                    Español
                  </option>
                  <option value="br" <%= typeof culture !== 'undefined' && culture === 'br' ? 'selected' : '' %>>
                    Brezhoneg
                  </option>
                  <option value="it" <%= typeof culture !== 'undefined' && culture === 'it' ? 'selected' : '' %>>
                    Italiano
                  </option>
                  <option value="oc" <%= typeof culture !== 'undefined' && culture === 'oc' ? 'selected' : '' %>>
                    Occitan
                  </option>
                </select>
                <% if ( errors.culture ) { %>
                  <span class="text-danger"><%= __( errors.culture ) %></span>
                <% } %>
              </div>
              <% if ( mtCaptchaEnabled ) { %>
                <div class="form-group<%= errors.captcha ? ' has-error' : '' %>">
                  <div id="mtcaptcha-local"></div>
                  <% if ( errors.captcha ) { %>
                    <span class="text-danger"><%= __( errors.captcha ) %></span>
                  <% } %>
                </div>
              <% } %>
              <p class="margin-v-md">
                <%- __( 'agree', {
                  terms: '<a target="_blank" href="https://doc.openagenda.com/conditions/">' + __( 'termsOfUse' ) + '</a>',
                  policy: '<a target="_blank" href="https://doc.openagenda.com/confidentialite/">' + __(
                    'policy' ) + '</a>'
                } ) %>
              </p>
              <div class="form-group margin-bottom-lg">
                <button id="signup-submit" class="btn btn-primary btn-block" type="submit"><%= __( 'signup' ) %></button>
              </div>
            </form>
            <% if ( enabledServices.includes( 'google' ) ) { %>
              <div class="margin-h-md margin-v-lg" style="display: flex; align-items: center; gap: 12px;">
                <div style="flex: 1; border-top: 1px solid #ddd;"></div>
                <strong class="gray"><%= __('orSocial') %></strong>
                <div style="flex: 1; border-top: 1px solid #ddd;"></div>
              </div>
              <div class="margin-h-md margin-bottom-lg">
                <form
                  id="signup-google"
                  action="<%= genUrl(
                    agenda ? 'agendaGoogleSignup' : 'googleSignup',
                    [ optionals, agenda ? { slug: agenda.slug } : {} ]
                  ) %>"
                  method="POST"
                >
                  <button
                    id="signup-google-button"
                    class="btn btn-google btn-block"
                    type="submit"
                  >
                    <i class="fa fa-google"></i>
                    Google
                  </button>
                </form>
                <% if ( errors.googleUid ) { %>
                  <span class="text-danger"><%= __( errors.googleUid ) %></span>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
