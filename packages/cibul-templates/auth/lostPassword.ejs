<div class="container">
  <div class="top-margined bottom-margined">
    <div class="row">
      <div class="col-sm-6 col-sm-offset-3 wsq padding-all-md">
        <div class="margin-h-sm">
          <h2><%= __('Lost password') %></h2>

          <% if ( typeof message !== 'undefined' ) { %>
            <p class="bg-danger padding-all-sm">
              <%= __(message) %>
            </p>
          <% } else { %>
            <p><%= __('Send a password reset link to your account\'s email address') %></p>
          <% } %>
        </div>

        <form class="margin-h-sm" method="post">
          <div class="form-group">
            <label for="email" class="control-label"><%= __('Your email') %></label>
            <input name="email" class="form-control" type="email" value="<%= email %>">
          </div>
          <div class="form-group">
            <button name="send" class="btn btn-primary" type="submit"><%= __('Send') %></button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
