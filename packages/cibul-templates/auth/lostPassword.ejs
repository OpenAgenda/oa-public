<div class="canvas page">
  <h1><%= __( 'Lost password' ) %></h1>
  <form class="cform" method="post">
    <ul>
      <li>
<% if ( typeof message !== 'undefined' ) { %>
        <span class="error"><%= __( message ) %></span>
<% } else { %>
        <span><%= __( 'Send a password reset link to your account\'s email address' ) %></span>
<% } %>
      </li>
      <li>
        <label for="email"><%= __('Your email') %></label>
        <input type="email" name="email" value="<%= email %>" />
      </li>
      <li>
        <button name="send" type="submit"><%= __('Send') %></button>
      </li>
    </ul>
  </form>
</div>