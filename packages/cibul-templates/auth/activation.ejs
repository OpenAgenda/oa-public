<% if ( agenda ) { %>
<% include ../agenda/head.part.ejs %>
<% } %>
<div class="container">
  <div class="row top-margined">
    <section class="col-sm-8 col-sm-offset-2 wsq">
      <div class="row">
        <div class="content">
          <h2><%= __('checkEmail') %></h2>
          <p><%= __('checkEmailInstruction') %></p>
          <p><%- __( 'didNotReceive', {
            resend : '<a class="url" href="' + genUrl( agenda ? 'agendaActivateResend' : 'activateResend', resendQuery ) + '">' +  __( 'resend' )  + '</a>',
            support : '<a class="url" href="mailto:support@openagenda.com">support@openagenda.com</a>'
          } ) %></p>
        </div>
      </div>
      <div class="row">
        <div class="content">
          <h2><%= __( 'stayUpToDate' ) %></h2>
          <div class="form-group social">
            <a class="btn btn-default btn-facebook" href="<%= facebookPage %>" target="_blank">
              <i class="fa fa-facebook"></i>
              <span><%= __( 'followUs' ) %></span>
            </a>
            <a class="btn btn-default btn-twitter" href="<%= twitterPage %>" target="_blank">
              <i class="fa fa-twitter"></i>
              <span><%= __( 'followUs' ) %></span>
            </a>
          </div>
          <div class="form-group">
            <form method="post" action="/newsletter/subscribe">
              <label for="email"><%= __( 'getOurNewsletter' ) %></label>
              <div class="input-group">
                <input class="form-control" type="text" name="email" placeholder="<%= __( 'yourEmail' ) %>">
                <span class="input-group-btn">
                  <button class="btn btn-primary" type="submit"><%= __( 'subscribe' ) %></button>
                </span>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
