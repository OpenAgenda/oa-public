<% if ( agenda ) { %>
<%- include('../agenda/head.part.ejs') %>
<% } %>
<div class="container">
  <div class="row top-margined">
    <section class="col-sm-8 col-sm-offset-2 wsq">
      <div class="row">
        <div class="content">
          <h2><%= __('checkEmail') %></h2>
          <p><%= __('checkEmailInstruction') %></p>
          <div class="text-center margin-v-md">
            <b><%= email %></b>
          </div>
          <p><%- __( 'didNotReceive', {
            resend : `<a class="url" href="${resend}">${__( 'resend' )}</a>`,
            support : '<a class="url" href="mailto:verif@openagenda.com">verif@openagenda.com</a>'
          } ) %></p>
        </div>
      </div>
      <div class="row">
        <div class="content">
          <h2><%= __( 'stayUpToDate' ) %></h2>
          <div class="form-group social">
            <a class="btn btn-default" href="<%= linkedInPage %>" target="_blank">
              <i class="fa fa-linkedin"></i>
              <span><%= __( 'followUsOnLinkedIn' ) %></span>
            </a>
            <a class="btn btn-default btn-twitter" href="<%= blueskyPage %>" target="_blank">
              <i><img width="14" src="https://cdn.openagenda.com/static/bluesky.svg"/></i>
              <span><%= __( 'followUsOnBlueSky' ) %></span>
            </a>
          </div>
          <div class="form-group">
            <form method="post" action="/newsletter/subscribe?origin=signup">
              <label for="email"><%= __( 'getOurNewsletter' ) %></label>
              <div class="input-group">
                <input class="form-control" type="text" name="email" placeholder="<%= __( 'yourEmail' ) %>">
                <span class="input-group-btn">
                  <button class="btn btn-primary" type="submit"><%= __( 'subscribe' ) %></button>
                </span>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
