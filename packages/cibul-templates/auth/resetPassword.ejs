<div class="canvas page">
  <h1><%= __( 'Reset your password' ) %></h1>
  <form class="cform" method="post">
    <ul>
      <li>
<% if ( typeof message !== 'undefined' ) { %>
        <span class="error"><%= __( message ) %></span>
<% } else { %>
        <span><%= __( 'Type in your new password' ) %></span>
<% } %>
      </li>
      <li>
        <label for="password"><%= __('Your new password') %></label>
        <input type="password" name="password" value="" />
      </li>
      <li>
        <label for="repeat"><%= __('Repeat') %></label>
        <input type="password" name="repeat" value="" />
      </li>
      <li>
        <button name="send" type="submit"><%= __('Update') %></button>
      </li>
    </ul>
  </form>
</div>