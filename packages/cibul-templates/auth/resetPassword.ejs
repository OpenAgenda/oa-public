<div class="container">
  <div class="top-margined bottom-margined">
    <div class="row">
      <div class="col-sm-6 col-sm-offset-3 wsq padding-all-md">
        <div class="margin-h-sm">
          <h2><%= __( 'Reset your password' ) %></h2>

          <% if ( typeof message !== 'undefined' ) { %>
            <p class="bg-danger padding-all-sm">
              <%= __(message) %>
            </p>
          <% } else { %>
            <p><%= __( 'Type in your new password' ) %></p>
          <% } %>
        </div>

        <form class="margin-h-sm" method="post">
          <div class="form-group">
            <label for="password" class="control-label"><%= __('Your new password') %></label>
            <input name="password" class="form-control" type="password" value="">
          </div>
          <div class="form-group">
            <label for="repeat" class="control-label"><%= __('Repeat') %></label>
            <input name="repeat" class="form-control" type="password" value="">
          </div>
          <div class="form-group">
            <button name="send" class="btn btn-primary" type="submit"><%= __('Update') %></button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
