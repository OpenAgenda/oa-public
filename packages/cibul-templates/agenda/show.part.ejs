<% if ( !total ) { %>
<div class="row">
  <div class="col-sm-3"></div>
  <div class="col-sm-9">
<% if ( ( passed === true ) && !hasSearchQuery ) { %>
    <p><%- __( 'agendaHasNotUpcomingEvents' ) %></p>
<% } else { %>
    <p><%- __( 'noResultForSearchWithLink', {
      'page' : '<a href="' + genUrl( 'agendaShow', { 'slug': agenda.slug } ) + '">' + __( 'reloadPage' ) + '</a>'
    } ) %></p>
<% } %>
  </div>
</div>
<% } else { %>

<% events.forEach(function( event ) { %>
  <% include ../eventLists/agendaItem.part.ejs %>
<% }) %>

<% } %>