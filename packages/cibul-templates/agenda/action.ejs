<% include ./head.part.ejs %>
<div id="content">
  <div class="container share-page">
    <div class="row">
      <div class="col-sm-offset-2 col-sm-8">
        <h2><%= __( 'Export' ) %></h2>
      </div>
    </div>
    <div class="row text-left">
      <div class="share-menu col-sm-offset-2 col-sm-8">

        <p class="legend"><%= __( 'Export your favorites' ) %></p>
        <div class="js_favorite_menu display-none">
          <span class="js_fav_info"><%= __( 'You favorited {count} events. Select the format in which you want to retrieve them.' ) %></span> <span><%- __( 'Or %clear%.', { '%clear%' : '<a class="url js_fav_clear" href="#">' + __( 'clear your selection' ) + '</a>' } ) %></span>
          <div class="btn-adds">
            <a class="btn btn-default js_google_calendar js_fav_export" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid }, { protocol: 'https://' } ) %>"><%= __( 'Google Agenda' ) %></a>
            <a class="btn btn-default js_fav_export" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid }) %>">iCal</a>
            <a class="btn btn-default js_fav_export" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid }) %>">ICS</a>
            <a class="btn btn-default js_fav_export js_spreadsheet" href="<%= genUrl( 'agendaCsvEvents', { uid: agenda.uid }) %>" data-extension="csv">CSV</a>
            <a class="btn btn-default js_fav_export js_spreadsheet" href="<%= genUrl( 'agendaXlsxEvents', { uid: agenda.uid } ) %>" data-extension="xlsx">Microsoft Excel ( xlsx )</a>
            <a class="btn btn-default js_fav_export" href="<%= genUrl( 'agendaPdfEvents', { uid: agenda.uid }) %>">PDF</a>
            <a class="btn btn-default js_fav_export" target="_blank" href="<%= genUrl( 'agendaJsonEvents', { uid: agenda.uid, key } ) %>">JSON *</a>
          </div>
        </div>
        <div class="js_favorite_menu_empty">
          <span><%- __( 'Your selection is currently empty for this agenda. To create one, browse the list of events and check %icon%', { '%icon%' : '<i class="fav fa fa-star"></i>' } ) %></span>
        </div>

        <p class="legend"><%= __( 'Export the your latest search' ) %></p>
        <span><%= __( 'Export the events included in your lastest search' ) %></span>
        <div class="btn-adds">
          <a class="btn btn-default js_google_calendar" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid, oaq: search }, { protocol: 'https://' } ) %>"><%= __( 'Google Agenda' ) %></a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid, oaq: search }) %>">iCal</a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid, oaq: search }) %>">ICS</a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaRssEvents', { uid: agenda.uid, oaq: search } ) %>">RSS</a>
          <a class="btn btn-default js_spreadsheet" href="<%= genUrl( 'agendaCsvEvents', { uid: agenda.uid, oaq: search }) %>" data-extension="csv">CSV</a>
          <a class="btn btn-default js_spreadsheet" href="<%= genUrl( 'agendaXlsxEvents', { uid: agenda.uid, oaq: search } ) %>" data-extension="xlsx">Microsoft Excel ( xlsx )</a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaPdfEvents', { uid: agenda.uid, oaq: search }) %>">PDF</a>
          <a class="btn btn-default" target="_blank" href="<%= genUrl( 'agendaJsonEvents', { uid: agenda.uid, oaq: search, key } ) %>">JSON *</a>
        </div>

        <p class="legend"><%= __( 'Export / Download everything' ) %></p>
        <div class="btn-adds">
          <a class="btn btn-default js_google_calendar" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid }, { protocol: 'https://' } ) %>"><%= __( 'Google Agenda' ) %></a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid, oaq: { passed: 1 } }) %>">iCal</a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaRssEvents', { uid: agenda.uid, oaq: { passed: 1 } }) %>">RSS</a>
          <a class="btn btn-default" href="<%= genUrl( 'agendaIcsEvents', { uid: agenda.uid, oaq: { passed: 1 } }) %>">ICS</a>
          <a class="btn btn-default js_spreadsheet" href="<%= genUrl( 'agendaCsvEvents', { uid: agenda.uid, oaq: { passed: 1 } }) %>" data-extension="csv">CSV</a>
          <a class="btn btn-default js_spreadsheet" href="<%= genUrl( 'agendaXlsxEvents', { uid: agenda.uid, oaq: { passed: 1 } }) %>" data-extension="xlsx">Microsoft Excel ( xlsx )</a>
<% if ( docxPath ) { %>
          <a class="btn btn-default" href="<%= docxPath %>"><strong><%= __( 'Microsoft Word ( docx )' ) %></strong></a>
<% } %>
          <a class="btn btn-default" href="<%= genUrl( 'agendaPdfEvents', { uid: agenda.uid, oaq: { passed: 1 } }) %>">PDF</a>
          <a class="btn btn-default" target="_blank" href="<%= genUrl( 'agendaJsonEvents', { uid: agenda.uid, page: 1, oaq: { passed: 1 }, key } ) %>">JSON *</a>
        </div>


<% if ( hasAggregator && !agenda.private ) { %>
        <p class="legend"><%= __('Aggregate this agenda in') %></p>
        <div class="btn-adds">
<% if ( agendas.length ) { %>
<% agendas.forEach( function( aggAgenda ) { %>
<% if ( aggAgenda.aggregates ) { %>
          <a class="btn btn-default checked uncheckable" href="<%= genUrl( 'agendaSourceRemove', { uid: agenda.uid, aggUid: aggAgenda.aggUid } ) %>"><%= aggAgenda.title %></a>
<% } else { %>
          <a class="btn btn-default" href="<%= genUrl( 'agendaSourceAdd', { uid: agenda.uid, aggUid: aggAgenda.aggUid } ) %>"><%= aggAgenda.title %></a>
<% } %>
<% }); %>
<% } else { %>
          <div class="text-center">
            <p><%= __('You do not own any OpenAgenda yet') %></p>
            <a class="btn green" href="<%= genUrl('agendaNew') %>"><%= __( 'Create an agenda' ) %></a>
          </div>
<% } %>
        </div>
<% } %>

        <div>
          <p>* <%= __( 'The data structure of this export may change.') %></p>
        </div>
      </div>
    </div>
  </div>
</div>