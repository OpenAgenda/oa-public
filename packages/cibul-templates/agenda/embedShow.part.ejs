<% if ( !total ) { %>
<% if ( ( passed === true ) && !hasSearchQuery ) { %>
    <p class="text-center"><%- __( 'noResultForSearch' ) %></p>
<% } else { %>
    <p class="text-center"><%= __( 'noResultForSearchPleaseWiden' ) %></p>
<% } %>
<% } else { %>

<% renders.eventItems.forEach(function( eventRender ) { %>
    <%- eventRender %>
<% } ); %>

<% } %>
