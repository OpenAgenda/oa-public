<div class="agenda-popup-overlay js_close_popup share-menu">
  <section>
    <header class="popup-title">
      <h2><%= __('Import / Add to my agenda') %></h2>
      <a class="close-link" <% if ( !xhr ) { %>href="<%= genUrl('agendaRedirect', { uid: uid } ) %>"<% } %>><i class="fa fa-times fa-lg"></i></a>
    </header>
    <div class="js_popup_content popup-content">
      <p class="legend"><%= __( 'Automatically import all dates of this agenda in your personal agenda' ) %></p>
      <div class="btn-adds">
        <a class="btn btn-default" href="https://www.google.com/calendar/render?cid=<%= genUrl( 'agendaIcsEvents', { uid: uid }, { protocol: 'http://' } ) %>"><%= __('Google Agenda') %></a>
        <a class="btn btn-default" href="<%= genUrl( 'agendaIcsEvents', { uid: uid }) %>?dl=1">iCal</a>
      </div>
      <p class="legend"><%= __('Download') %></p>
      <div class="btn-adds">
        <a class="btn btn-default" href="<%= genUrl( 'agendaFeed', { uid: uid }) %>">RSS</a>
        <a class="btn btn-default" href="<%= genUrl( 'agendaIcsEvents', { uid: uid }) %>?dl=1">ICS</a>
        <a class="btn btn-default "href="<%= genUrl( 'agendaCsvEvents', { uid: uid, search: { passed: 1 } }) %>">CSV</a>
        <a class="btn btn-default "href="<%= genUrl( 'agendaXlsxEvents', { uid: uid, search: { passed: 1 } }) %>">Excel ( xlsx )</a>
        <a class="btn btn-default" href="<%= `/agendas/${uid}.xml` %>?dl=1">XML</a>
        <a class="btn btn-default" target="_blank" href="<%= genUrl( 'agendaJsonEvents', { uid: uid, page: 1, search: { passed: 1 } } ) %>">JSON *</a>
      </div>
<% if ( hasAggregator ) { %>
      <p class="legend"><%= __('Add the events of this agenda to your agenda OpenAgenda') %></p>
      <div class="btn-adds">
<% if ( agendas.length ) { %>
<% agendas.forEach( function( agenda ) { %>
<% if ( agenda.aggregates ) { %>
      <a class="btn btn-default checked uncheckable" href="<%= genUrl( 'agendaSourceRemove', { uid: uid, aggUid: agenda.aggUid } ) %>"><%= agenda.title %></a>
<% } else { %>
      <a class="btn btn-default" href="<%= genUrl( 'agendaSourceAdd', { uid: uid, aggUid: agenda.aggUid } ) %>"><%= agenda.title %></a>
<% } %>
<% }); %>
<% } else { %>
      <div class="text-center">
        <p><%= __('You do not own any OpenAgenda yet') %></p>
        <a class="btn green" href="/new"><%= __( 'Create an agenda' ) %></a>
      </div>
<% } %>
      </div>
<% } %>

      <div>
        <p>* <%= __( 'The data structure of this export may change.') %></p>
      </div>

    </div>

  </section>
</div>
