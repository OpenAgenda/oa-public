<div class="canvas page sadmin">

  <article>

    <h2><%= __('Totals') %></h2>

	  <section class="w33">
	 		<h3><%= __('Reviews') %></h3>
	 		<p> <%= __('Number of reviews created %totalReviews%', {'%totalReviews%': reviews.total}) %> </p>
	 		<% if ( reviews.totalInWeek ) {%><p><%= __('Last week') %> <%= __( '%reviewsWeek% reviews' , {'%reviewsWeek%': reviews.totalInWeek} )  %></p>
			<% } %>
			<% if ( reviews.totalInMonth ) {%><p><%= __('Last month')%> <%= __( '%reviewsMonth% reviews' , {'%reviewsMonth%': reviews.totalInMonth} ) %></p> <% } %>
	 	</section>

	 	<section class="w33">
	 		<h3><%= __('Events') %></h3>
	 		<p> <%= __('Number of events created %totalEvents%', {'%totalEvents%': events.total} ) %>  </p>
	 		<% if ( events.totalInWeek ) {%><p><%= __('Last week') %> <%= __( '%eventsWeek% events' , {'%eventsWeek%': events.totalInWeek} )  %></p>
			<% } %>
			<% if ( events.totalInMonth ) {%><p><%= __('Last month')%> <%= __( '%eventsMonth% events' , {'%eventsMonth%': events.totalInMonth} ) %></p> <% } %>
	 	</section>

	 	<section class="w33">
	 		<h3><%= __('Users') %></h3>
	 		<p><%= __('Number of users created %totalUsers%', {'%totalUsers%': users.total}) %> </p>
	 		<% if ( users.totalInWeek ) {%><p><%= __('Last week') %> <%= __( '%usersWeek% users' , {'%usersWeek%': users.totalInWeek} )  %></p>
			<% } %>
			<% if ( users.totalInMonth ) {%><p><%= __('Last month')%> <%= __( '%usersMonth% users' , {'%usersMonth%': users.totalInMonth} ) %></p> <% } %>
	 	</section>

	 	<form class="cform js_totals_search" method="get" action="/admin/search" >
		  <ul class="line">
		  	<li>
					<input type="text" name="begin" class="js_begin" placeholder="Début"/>
				</li>
				<li>
					<input type="text" name="end" class="js_end" placeholder="Fin"/>
				</li>
				<li>
					<button type="submit"><%= __( 'Search' ) %> </button>
				</li>
			</ul>
		</form>

	 </article>

	 <article class="js_events_by_week">
	   <h2><%= __('Published events by week') %></h2>

	   <div class="graph">
	     <ul>
	     </ul>
	   </div>

	 </article>

	 <article>

	 	<h2><%= __('Diff between primary db and Elasticsearch') %></h2>

	 	<div class="js_events_diff"></div>

	 </article>

 </div>
