<html>
  <head>
<% js.forEach( function( jsPath ) { %>
    <script type="text/javascript" src="<%= jsPath %>"></script>
<% }) %>
    <style type="text/css">

      .separator {

        margin: 4em 0;
        border-top: 1px solid black;

      }

    </style>
  </head>
  <body>

    <style>

      .gni ul {

        list-style-type: none;
        padding: 0;
        max-width: 300px;

      }

      .gni li {

        padding-bottom: 1em;

      }

      .gni span {

        display: block;

      }

      .gni a {

        color: inherit;
        text-decoration: inherit;

      }

      .gni .title {

        text-transform: uppercase;

      }

      .gni img {

        display: block;
        max-width: 100%;

      }

      .gni .place {

        font-weight: bold;

      }

    </style>

    <p>preview widget with custom template:</p>
    <div <%- backup ? 'class="gni cbpgpr"' : 'data-oapr' %> data-cbctl="<%= uid %>">
      <a href="#here">Voir l'agenda</a>
      <!--
        Total à venir: {TotalEvents}
        <ul>
          {block:Events}
          <li>
            <a href="{Link}">
              <span class="title">{Title}</span>
              {block:ImageUrl}
              <img src="{ImageUrl}"/>
              {/block:ImageUrl}
              <span class="desc">{Description}</span>
              <span class="range">{DateRange}</span>
              <span class="place">{LocationName}</span>
              {block:Tags}
                <h1>{Tag}</h1>
              {/block:Tags}
              {TicketUrl}
              {block:Registration}
                {Value}
              {/block:Registration}
            </a>
          </li>
          {/block:Events}
        </ul>
      -->
    </div>

    <div class="separator"></div>

    <p>preview widget with default style, linking to oa.com:</p><!-- lang should be lowercase, uppercase is tolerated -->
    <div <%- backup ? 'class="gni cbpgpr"' : 'data-oapr' %> data-cbctl="<%= uid %>|EN">
      <a href="//d.openagenda.com/agendas/<%= uid %>">Voir l'agenda</a>
    </div>

    <div class="separator"></div>

    <p>preview widget without default style, with more items:</p>
    <div <%- backup ? 'class="gni cbpgpr"' : 'data-oapr' %> data-cbctl="<%= uid %>" data-count="10">
      <a href="#here">Voir l'agenda</a>
    </div>

    <div class="separator"></div>

    <a href="//d.openagenda.com/agendas/<%= uid %>">lien agenda</a>

  </body>
</html>
