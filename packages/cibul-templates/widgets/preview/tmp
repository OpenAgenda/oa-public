<ul>
<% for( var i in events ) { %><% var e = events[ i ]; %>
  <li>
    <p><a href="<%= e.link %>">
      <strong><%= e.title %></strong>
    </a></p>
<% if ( e.thumbnail ) { %>
    <a href="<%= e.link %>">
      <img src="<%= e.thumbnail %>"/>
    </a>
<% } %>
    <p><a href="<%= e.link %>"><%= e.description %></a></p>
    <p><a href="<%= e.link %>"><%= e.range %></a></p>
  </li>
<% } %>
</ul>


