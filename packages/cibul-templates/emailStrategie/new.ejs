<div class="header">
  <h2>EmailStrategie</h2>
  <p><%= __( 'Link your agenda with an EmailStrategie list' ) %></p>
</div>

<section>

  <form class="cform" method="post" action="<%= genUrl( 'emailStrategieNewSubmit', { slug: agenda.slug }) %>">
    <ul>
      <li>
        <label for="login"><%= __( 'EmailStrategie Login' ) %></label>
        <input name="login" value="<%= values.login %>" type="text" />
      </li>
      <li>
        <label for="password"><%= __( 'EmailStrategie Password' ) %></label>
        <input name="password" value="<%= values.password %>" type="password" />
      </li>
      <li>
        <button class="green" type="submit"><%= __( 'Link' ) %></button>
      </li>
<% if ( error ) { %>
      <li>
        <span class="error"><%= __( error ) %></span>
      </li>
<% } %>
    </ul>
  </form>

</section>