<div id="content">
  <div class="container">
    <div class="row">
      <div class="col-sm-offset-3 col-sm-6">
        <div class="page">
          <h1><%= __( 'Unsubscribe' ) %></h1>
          <form method="post" action="/emailunsubscribe">
            <div class="form-group <% if ( error ) { %>has-error<% } %>">
              <label for="email"><%= __( 'submit your email to stop receiving event emails' ) %></label>
              <input name="email" type="text" class="form-control" value="<%= email %>" />
<% if ( error ) { %>
              <p class="text-danger"><%= __( error ) %></p>
<% } %>
            </div>
            <div class="form-group">
              <button id="submitemail" type="submit" class="btn green"><%= __('Submit') %></button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<% var centeredFooter = true; %>
<% include ../bsLayout/footer.part.ejs %>
