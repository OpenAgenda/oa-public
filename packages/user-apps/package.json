  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "prepublish": "yarn build",
    "build": "babel src -d dist -s",
    "start": "concurrently --kill-others-on-fail -n \"fixtures,build,client,app\" \"yarn fixtures\" \"yarn build -w\" \"yarn watch-client\" \"sleep 3 && node test/app\"",
    "watch-client": "testapp-clientwatcher -i test/app/front.js -o .tmp/testapp-client.js",
    "fixtures": "node test/app/fixtures"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.1.2",
    "@openagenda/abilities": "^1.1.3",
    "@openagenda/dom-utils": "^2.2.0",
    "@openagenda/image-upload": "^1.0.8",
    "@openagenda/labels": "^2.1.0",
    "@openagenda/react-components": "^2.2.1",
    "@openagenda/react-form-components": "^2.1.1",
    "@openagenda/react-utils": "^2.0.1",
    "@openagenda/users": "^2.2.2",
    "@openagenda/utils": "^1.0.3",
    "create-react-class": "^15.6.3",
    "history": "^3.3.0",
    "lodash": "^4.17.10",
    "prop-types": "^15.6.1",
    "react-redux": "^5.0.7",
    "react-router": "^3.2.1",
    "react-router-redux": "^4.0.8",
    "redux": "^4.0.0",
    "redux-form": "^5.2.3",
    "superagent": "^3.8.2"
  },
  "devDependencies": {
