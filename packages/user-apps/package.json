{
  "name": "@openagenda/user-apps",
  "version": "1.1.2",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "concurrently -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ./node_modules/.bin/knex",
    "build": "babel src -d dist -s",
    "clean": "rimraf dist",
    "prepublish": "yarn clean && yarn build"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.3.1",
    "@loadable/component": "^5.6.0",
    "@openagenda/abilities": "^1.1.3",
    "@openagenda/dom-utils": "^2.2.0",
    "@openagenda/image-upload": "^1.0.8",
    "@openagenda/labels": "^2.1.0",
    "@openagenda/react-components": "^2.2.1",
    "@openagenda/react-utils": "^4.0.0",
    "@openagenda/users": "^2.2.2",
    "@openagenda/utils": "^1.0.3",
    "history": "^4.7.2",
    "knex": "^0.16.3",
    "lodash": "^4.17.10",
    "mysql": "^2.16.0",
    "prop-types": "^15.6.1",
    "react-redux": "^6.0.0",
    "react-router": "^4.3.1",
    "react-router-config": "^1.0.0-beta.4",
    "react-router-dom": "^4.3.1",
    "recompose": "^0.30.0",
    "redial": "^0.5.0",
    "redux": "^4.0.1",
    "redux-form": "^8.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.2.2",
    "@babel/node": "^7.2.2",
    "@loadable/babel-plugin": "^5.6.0",
    "@openagenda/bs-templates": "^2.2.0",
    "@openagenda/fixtures": "^2.0.1",
    "@openagenda/keys": "^2.1.1",
    "@openagenda/unsubscribed": "^2.1.1",
    "@storybook/react": "^4.1.11",
    "async": "^2.6.1",
    "babel-loader": "^8.0.4",
    "babel-preset-openagenda": "^1.1.1",
    "concurrently": "^4.1.0",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.16.4",
    "morgan": "^1.9.1",
    "nodemon": "^1.18.9",
    "react": "^16.8.4",
    "react-dom": "^16.8.4",
    "rimraf": "^2.6.2"
  },
  "peerDependencies": {
    "react": "^16.8.4",
    "react-dom": "^16.8.4"
  }
}
