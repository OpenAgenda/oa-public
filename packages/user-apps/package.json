{
  "name": "@openagenda/user-apps",
  "version": "1.2.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ./node_modules/.bin/knex",
    "build": "babel src -d dist -s",
    "clean": "rimraf dist",
    "prepack": "yarn clean && yarn build"
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.12.5",
    "@openagenda/abilities": "^1.3.0",
    "@openagenda/dom-utils": "^2.2.12",
    "@openagenda/labels": "^2.3.0",
    "@openagenda/react-components": "^2.3.10",
    "@openagenda/react-shared": "^2.1.0",
    "@openagenda/users": "^3.1.0",
    "@openagenda/utils": "^1.3.0",
    "core-js": "^3.6.5",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "mysql": "^2.16.0",
    "prop-types": "^15.6.1",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "recompose": "^0.30.0",
    "redial": "^0.5.0",
    "redux-form": "^8.1.0",
    "regenerator-runtime": "^0.13.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.1",
    "@babel/core": "^7.12.3",
    "@babel/node": "^7.12.6",
    "@loadable/babel-plugin": "^5.13.0",
    "@openagenda/babel-preset": "^1.4.0",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/fixtures": "^2.0.2",
    "@openagenda/keys": "^2.2.10",
    "@openagenda/unsubscribed": "^2.1.9",
    "@storybook/react": "^6.1.0",
    "async": "^2.6.1",
    "babel-loader": "^8.2.1",
    "concurrently": "^5.1.0",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.17.1",
    "final-form": "^4.20.1",
    "history": "^4.10.1",
    "morgan": "^1.9.1",
    "nodemon": "^2.0.4",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-router": "^5.1.2",
    "react-router-dom": "^5.1.2",
    "redux": "^4.0.5",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "@loadable/component": "^5.12.0",
    "final-form": "^4.18.5",
    "react": "^16.12.0",
    "react-router": "^5.0.0",
    "react-router-dom": "^5.0.0",
    "redux": "^4.0.5"
  }
}
