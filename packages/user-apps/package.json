    "@openagenda/test-app": "^3.0.1-6",
    "@openagenda/unsubscribed": "^2.1.1",
    "babel-preset-openagenda": "^1.1.1",
    "concurrently": "^3.5.1",
    "react": "^16.7.0",
    "react-dom": "^16.7.0",
    "redux-devtools": "^3.4.1",
    "redux-devtools-dock-monitor": "^1.1.3",
    "redux-devtools-log-monitor": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^16.7.0",
    "react-dom": "^16.7.0"
  }
