{
  "extends": "@openagenda",

  "parserOptions": {
    "sourceType": "script"
  },

  "ignorePatterns": [
    "build"
  ],

  "rules": {
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "test/**/*.js",
          "testconfig.sample.js",
          "testconfig.js"
        ]
      }
    ]
  }
}
