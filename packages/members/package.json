{
  "name": "@openagenda/members",
  "version": "1.15.1",
  "scripts": {
    "prepack": "yarn build",
    "test": "jest --runInBand --testEnvironment=node",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "build": "rimraf build && babel iso -d build -s",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.8.7",
    "@openagenda/logs": "^1.1.3",
    "@openagenda/validators": "^2.2.3",
    "core-js": "^3.6.4",
    "immutability-helper": "^3.0.1",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "regenerator-runtime": "^0.13.5",
    "slug": "0.9.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.8.4",
    "@openagenda/babel-preset": "^1.2.1",
    "@openagenda/eslint-config": "^1.0.2",
    "eslint": "^6.8.0",
    "jest": "^25.1.0",
    "lint-staged": "^10.0.7",
    "mysql": "^2.13.0",
    "prettier-eslint-cli": "^5.0.0",
    "rimraf": "^3.0.2"
  }
}
