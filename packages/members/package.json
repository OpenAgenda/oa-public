{
  "name": "@openagenda/members",
  "version": "1.15.13",
  "scripts": {
    "prepack": "yarn build",
    "test": "jest --runInBand --testEnvironment=node",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "build": "rimraf build && babel iso -d build -s",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.13.17",
    "@openagenda/logs": "^1.1.9",
    "@openagenda/validators": "^2.4.0",
    "@openagenda/verror": "^3.0.0",
    "core-js": "^3.10.2",
    "immutability-helper": "^3.0.1",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "regenerator-runtime": "^0.13.7",
    "slugify": "^1.4.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/core": "^7.13.16",
    "@openagenda/babel-preset": "^1.4.1",
    "@openagenda/eslint-config": "^1.3.1",
    "eslint": "^6.8.0",
    "jest": "^28.1.2",
    "lint-staged": "^10.2.11",
    "mysql": "^2.13.0",
    "prettier-eslint-cli": "^5.0.0",
    "rimraf": "^3.0.2"
  }
}
