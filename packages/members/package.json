{
  "name": "@openagenda/members",
  "version": "1.15.0",
  "scripts": {
    "prepublish": "yarn build",
    "test": "jest --runInBand --testEnvironment=node",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "build": "rimraf build && babel iso -d build -s",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc '**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc",
      "git add"
    ]
  },
  "dependencies": {
    "@openagenda/logs": "^1.1.1",
    "@openagenda/validators": "^2.1.6",
    "immutability-helper": "^3.0.1",
    "knex": "^0.19.5",
    "lodash": "^4.17.4",
    "slug": "0.9.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.6.3",
    "@babel/core": "^7.6.3",
    "@openagenda/babel-preset": "^1.1.1",
    "@openagenda/eslint-config": "^1.0.0",
    "eslint": "^6.5.1",
    "jest": "^24.9.0",
    "lint-staged": "^9.4.2",
    "mysql": "^2.13.0",
    "prettier-eslint-cli": "^5.0.0"
  }
}
