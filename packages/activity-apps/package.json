  },
  "homepage": "https://github.com/OpenAgenda/oa/tree/main/packages/activity-apps",
  "scripts": {
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node $(yarn bin knex)",
    "build": "babel --copy-files src -d dist -s",
    "clean": "rimraf dist",
    "prepack": "yarn clean && yarn oa-intl compile && yarn build",
    "extract-messages": "yarn oa-intl",
    "test": "jest --runInBand --detectOpenHandles --forceExit"
  },
