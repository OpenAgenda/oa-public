{
  "globals": {},
  "env": {
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 8,
    "sourceType": "module"
  },
  "rules": {
    "no-var" : [ "error" ],
    "prefer-const" : [ "error", {
      "destructuring": "any",
      "ignoreReadBeforeAssign": false
    } ],
    "object-shorthand" : [ "error" ]
  }
}