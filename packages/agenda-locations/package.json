  "homepage": "https://github.com/OpenAgenda/oa/tree/main/packages/agenda-locations",
  "scripts": {
    "clean": "rimraf components/build",
    "build": "babel --copy-files components/src -d components/build -s",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service server.dev.js",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prepack": "yarn clean && yarn build",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "test": "jest --runInBand --forceExit --testTimeout=40000 --env=node --verbose=false",
    "extract-messages": "yarn oa:extract-messages 'components/src/**/*.js' --out-dir 'components/src/locales' --compiled-dir 'components/src/locales-compiled'"
  },
