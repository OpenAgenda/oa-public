{
  "name": "@openagenda/react-filters",
  "version": "1.0.0",
  "main": "lib/index.js",
  "jsnext:main": "esm/index.js",
  "module": "esm/index.js",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "lib",
    "esm"
  ],
  "scripts": {
    "prepack": "yarn clean && yarn build",
    "build": "yarn build:esm && yarn build:cjs",
    "build:esm": "babel --copy-files src -d esm -s --env-name esm",
    "build:cjs": "babel --copy-files src -d lib -s",
    "extract-messages": "yarn oa:extract-messages",
    "clean": "rimraf esm lib",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc $(pwd)'/**/*.js'",
    "lint-staged": "lint-staged",
    "start": "start-storybook -p 6006 --no-dll",
    "build-storybook": "build-storybook --no-dll"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.12.5",
    "@emotion/core": "^10.0.35",
    "@formatjs/cli": "^2.11.3",
    "@openagenda/react-shared": "^2.0.7",
    "classnames": "^2.2.6",
    "core-js": "^3.6.5",
    "date-fns": "^2.11.1",
    "lodash": "^4.17.20",
    "react-date-range": "^1.1.3",
    "react-final-form": "^6.4.0",
    "react-final-form-listeners": "^1.0.2",
    "react-intl": "^5.8.2",
    "react-uid": "^2.3.0",
    "react-use": "^15.3.4",
    "use-debounce": "^5.0.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.1",
    "@babel/core": "^7.12.3",
    "@emotion/babel-preset-css-prop": "^10.0.27",
    "@mdx-js/react": "^1.6.19",
    "@openagenda/babel-preset": "^1.3.8",
    "@openagenda/bs-templates": "^2.4.6",
    "@openagenda/eslint-config": "^1.2.4",
    "@storybook/addon-actions": "^6.1.0",
    "@storybook/addon-docs": "^6.1.0",
    "@storybook/addon-essentials": "^6.1.0",
    "@storybook/addon-links": "^6.1.0",
    "@storybook/react": "^6.1.0",
    "babel-loader": "^8.2.1",
    "eslint": "^6.8.0",
    "final-form": "^4.20.1",
    "lint-staged": "^10.2.11",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "rimraf": "^3.0.1"
  },
  "peerDependencies": {
    "final-form": "^4.18.5",
    "react": "^16.12.0"
  }
}
