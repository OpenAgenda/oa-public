{
  "name": "@openagenda/react-timingspicker",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:Oagenda/oa.git"
  },
  "homepage": "https://github.com/Oagenda/oa/tree/master/packages/react-timingspicker",
  "main": "dist/index.js",
  "scripts": {
    "start": "start-storybook -p 9001",
    "test": "jest --forceExit --detectOpenHandles",
    "build": "babel --copy-files src -d dist -s",
    "extract-messages": "node scripts/extract-messages.js",
    "clean": "rimraf dist",
    "prepublish": "yarn clean && yarn build",
    "lint": "eslint -c .eslintrc '**/*.js'",
    "prettier": "prettier-eslint --write --eslint-config-path .eslintrc '**/*.js'",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier-eslint --write --eslint-config-path .eslintrc",
      "eslint -c .eslintrc",
      "git add"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.5.5",
    "classnames": "^2.2.6",
    "core-js": "^3.2.1",
    "date-fns": "^2.1.0",
    "react-day-picker": "^7.3.0",
    "react-final-form": "^6.3.0",
    "react-icons": "^3.7.0",
    "react-intl": "^2.8.0",
    "react-modal": "^3.8.1",
    "react-resize-detector": "^4.1.3",
    "react-select": "^2.1.1",
    "react-text-mask": "^5.4.3",
    "rrule": "^2.6.2",
    "text-mask-addons": "^3.8.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.5.5",
    "@babel/core": "^7.5.5",
    "@openagenda/babel-preset": "^1.1.1",
    "@openagenda/eslint-config": "^1.0.0",
    "@storybook/addon-viewport": "^5.1.11",
    "@storybook/addons": "^5.1.11",
    "@storybook/react": "^5.1.11",
    "babel-jest": "^24.9.0",
    "babel-loader": "^8.0.5",
    "babel-plugin-react-intl": "^3.0.1",
    "eslint": "^6.2.1",
    "final-form": "^4.18.5",
    "glob": "^7.1.3",
    "jest": "^24.9.0",
    "lint-staged": "^7.3.0",
    "prettier-eslint-cli": "^5.0.0",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "rimraf": "^2.6.2"
  },
  "peerDependencies": {
    "final-form": "^4.18.5",
    "react": "^16.8.6",
    "react-dom": "^16.8.6"
  }
}
