{
  "name": "@openagenda/mcp",
  "version": "0.0.0",
  "private": true,
  "description": "OpenAgenda v3 MCP server (POC) — code-mode tools over the read-only events API, with a pluggable sandbox executor",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "openagenda-mcp": "src/index.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node src/index.js",
    "smoke": "node scripts/smoke.mjs",
    "check": "node --check src/index.js",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --runInBand --forceExit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
