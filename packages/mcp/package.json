{
  "name": "@openagenda/mcp",
  "version": "0.0.0",
  "private": true,
  "description": "OpenAgenda v3 MCP server — code-mode tools over the v3 API, with a pluggable sandbox executor",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "openagenda-mcp": "src/index.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "start": "yarn build && node src/index.js",
    "smoke": "yarn build && node scripts/smoke.js",
    "smoke:oauth": "node scripts/smoke-oauth.js",
    "build": "tsdown",
    "check": "tsc --noEmit",
    "prepack": "yarn build",
    "test": "yarn build && NODE_OPTIONS=\"--experimental-vm-modules\" jest --runInBand --forceExit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openagenda/api-spec": "workspace:*",
    "@openagenda/logs": "^1.1.10",
    "express": "^4.18.2",
    "jose": "^6.2.3",
    "minisearch": "^7.2.0",
    "yaml": "^2.4.5",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "microsandbox": "^0.5.4"
  },
  "devDependencies": {
    "@openagenda/api-client": "workspace:*",
    "@types/node": "^22.0.0",
    "jest": "^30.4.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.3"
  }
}
