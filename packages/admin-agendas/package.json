  "main": "service/index.js",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "babel components/src -d components/lib -s --env-name esm --root-mode upward",
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "STORYBOOK_API_PORT=3000 storybook dev -p 9001",
    "knex": "babel-node $(yarn bin knex)",
    "clean": "rimraf components/lib",
    "prepack": "yarn clean && yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa.git"
