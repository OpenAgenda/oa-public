{
  "root": true,
  "extends": [
    "@openagenda/eslint-config/recommended",
    "next/core-web-vitals"
  ],
  "rules": {
    // "@next/next/no-html-link-for-pages": ["error", "src/pages/"]
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          ".storybook/**/*.js",
          "stories/**/*.{tsx,ts,jsx,js}",
          "scripts/**/*.mjs"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "src/**/*.{tsx,ts,jsx,js}",
        "*.stories.{tsx,ts,jsx,js}"
      ],
      "globals": {
        "React": true
      }
    },
    {
      "files": [
        "*.stories.{tsx,ts,jsx,js}"
      ],
      "rules": {
        "import/no-anonymous-default-export": "off"
      }
    },
    {
      "files": [
        "scripts/**/*.mjs"
      ],
      "rules": {
        // node esm modules require extensions
        "import/extensions": ["error", "ignorePackages"]
      }
    }
  ],
  "settings": {
    "next": {
      "rootDir": "."
    }
  }
}
