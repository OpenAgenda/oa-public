{
  "extends": "@openagenda/tsconfig/nextjs",
  "compilerOptions": {
    "baseUrl": "src",
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": true,
    "downlevelIteration": true,
    "target": "es5",
    "paths": {
      "@openagenda/uikit": ["../../../public/uikit/src"],
      "@openagenda/react-filters": ["../../../public/react-filters/src"],
      "@openagenda/react-filters/*": ["../../../public/react-filters/src/*"]
    },
  },
  "exclude": ["node_modules"],
  "include": [
    "next-env.d.ts",
    "src/types/*.d.ts",
    "src"
  ],
}
