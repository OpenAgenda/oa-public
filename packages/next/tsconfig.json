{
  "extends": "@openagenda/tsconfig/nextjs",
  "compilerOptions": {
    "baseUrl": "src",
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": true,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "target": "esnext",
    "paths": {
      "@/*": ["../*"],
      "@openagenda/intl": ["../../../public/intl/src"],
      "@openagenda/uikit": ["../../../public/uikit/src"],
      "@openagenda/uikit/*": ["../../../public/uikit/src/*"],
      "@openagenda/date-utils": ["../../../public/date-utils/src"],
      "@openagenda/react": ["../../../public/react/src"],
      "@openagenda/react/*": ["../../../public/react/src/*"],
      "@openagenda/react-filters": ["../../../public/react-filters/src"],
      "@openagenda/react-filters/*": ["../../../public/react-filters/src/*"],
      "@openagenda/react-shared": ["../../../public/react-shared/src"]
    }
  },
  "exclude": ["node_modules"],
  "include": ["next-env.d.ts", "src/types/*.d.ts", "src", "stories"]
}
