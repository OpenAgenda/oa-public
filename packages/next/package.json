{
  "name": "@openagenda/next",
  "version": "0.0.1",
  "private": true,
  "description": "OpenAgenda main NextJs app",
  "scripts": {
    "dev": "next dev -p ${OA_NEXT_PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${OA_NEXT_PORT:-3000}",
    "push": "node scripts/pushNextToCDN.mjs",
    "extract-messages": "node scripts/extractMessages.mjs src/**/*.{tsx,ts,jsx,js}",
    "storybook": "start-storybook -p 9001 --ci",
    "lint": "next lint",
    "prettier": "prettier-eslint --write '**/*.@(tsx,ts,jsx,js,mts,mjs,cts)'",
    "analyze": "ANALYZE=true yarn build"
  },
  "dependencies": {
    "@emotion/server": "^11.10.0",
    "@fortawesome/fontawesome-svg-core": "^6.2.0",
    "@fortawesome/pro-regular-svg-icons": "^6.2.0",
    "@fortawesome/pro-solid-svg-icons": "^6.2.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@next/bundle-analyzer": "^13.1.1",
    "@openagenda/common-labels": "^1.2.4",
    "@openagenda/intl": "^1.1.3",
    "@openagenda/react-filters": "^2.8.3",
    "@openagenda/react-shared": "^2.4.0",
    "@openagenda/uikit": "^0.0.1",
    "@storybook/react": "^6.5.9",
    "axios": "^0.21.1",
    "date-fns": "^2.29.3",
    "lodash": "^4.17.21",
    "next": "^12.3.1",
    "next-transpile-modules": "^9.1.0",
    "qs": "^6.11.0",
    "react": "^18.2.0",
    "react-content-loader": "^6.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^9.4.1",
    "react-intl": "^5.12.2",
    "react-use": "^17.4.0",
    "sharp": "^0.31.1",
    "swr": "^1.3.0"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^1.3.1",
    "@openagenda/tsconfig": "^0.0.0",
    "dedent": "^0.7.0",
    "eslint": "^8.24.0",
    "eslint-config-next": "^12.3.1",
    "ftp": "^0.3.10",
    "globby": "^13.1.3",
    "prettier-eslint-cli": "^7.1.0",
    "storybook-addon-next": "^1.6.9",
    "typescript": "^4.8.4",
    "webpack": "^5.72.0"
  }
