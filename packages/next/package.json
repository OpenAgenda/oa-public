{
  "name": "@openagenda/next",
  "version": "0.0.1",
  "private": true,
  "description": "OpenAgenda main NextJs app",
  "scripts": {
    "dev": "next dev -p ${OA_NEXT_PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${OA_NEXT_PORT:-3000}",
    "push": "node scripts/pushNextToCDN.mjs",
    "extract-messages": "node scripts/extractMessages.mjs src/**/*.{tsx,ts,jsx,js}",
    "storybook": "storybook dev -p 9001 -s public --ci",
    "sb": "yarn storybook",
    "lint": "next lint",
    "typecheck": "tsc --incremental false",
    "tc": "yarn typecheck",
    "prettier": "prettier-eslint --write '**/*.@(tsx,ts,jsx,js,mts,mjs,cts)'",
    "analyze": "ANALYZE=true yarn build"
  },
  "dependencies": {
    "@edge-runtime/cookies": "^3.0.5",
    "@emotion/server": "^11.10.0",
    "@fortawesome/fontawesome-svg-core": "^6.2.1",
    "@fortawesome/pro-duotone-svg-icons": "^6.2.1",
    "@fortawesome/pro-regular-svg-icons": "^6.2.1",
    "@fortawesome/pro-solid-svg-icons": "^6.2.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@next/bundle-analyzer": "^13.1.1",
    "@openagenda/browserslist-config": "^1.0.0",
    "@openagenda/common-labels": "^1.2.4",
    "@openagenda/intl": "^1.1.3",
    "@openagenda/outdated-browser": "^0.0.0",
    "@openagenda/react-filters": "^2.9.0",
    "@openagenda/react-shared": "^2.4.0",
    "@openagenda/sdk-js": "^2.0.3",
    "@openagenda/uikit": "^0.0.1",
    "@openagenda/verror": "^3.1.0",
    "@sentry/nextjs": "^7.45.0",
    "axios": "^0.21.1",
    "base64-js": "^1.5.1",
    "date-fns": "^2.29.3",
    "date-fns-tz": "^2.0.0",
    "fast-json-stable-stringify": "^2.1.0",
    "leaflet": "^1.9.3",
    "lodash": "^4.17.21",
    "next": "^12.3.1",
    "next-transpile-modules": "^9.1.0",
    "qs": "^6.11.0",
    "react": "^18.2.0",
    "react-content-loader": "^6.2.0",
    "react-cookie": "^4.1.1",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^9.4.1",
    "react-intl": "^5.12.2",
    "react-use": "^17.4.0",
    "sharp": "^0.31.1",
    "swr": "^2.1.1",
    "universal-cookie": "^4.0.4",
    "use-local-storage-state": "^18.1.2"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^1.4.0",
    "@openagenda/tsconfig": "^0.0.0",
    "@storybook/nextjs": "^7.0.0-beta.30",
    "dedent": "^0.7.0",
    "eslint": "^8.24.0",
    "eslint-config-next": "^12.3.1",
    "ftp": "^0.3.10",
    "globby": "^13.1.3",
    "msw": "^0.49.2",
    "msw-storybook-addon": "^1.7.0",
    "prettier-eslint-cli": "^7.1.0",
    "storybook": "^7.0.0-beta.30",
    "typescript": "^4.8.4",
    "webpack": "^5.72.0"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "browserslist": [
    "extends @openagenda/browserslist-config"
  ]
}
