    "ejs": "^2.4.1",
    "express": "^4.13.3",
    "font-awesome": "4.3.0",
    "husky": "^0.13.4",
    "node-sass": "^4.5.2",
    "node-sass-import-once": "^1.2.0",
    "node-watch": "^0.3.5",
    "reload": "^1.1.0",
    "walk": "^2.3.9"
  }
