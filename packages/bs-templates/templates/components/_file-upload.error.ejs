<div class="form-group has-error">
  <label>Chargez votre pdf ici (*)</label>
  <div class="file-upload">
    <div class="file-dropzone" aria-disabled="false">
      <button class="btn btn-primary">
        <label>Charger un fichier</label>
      </button>
      <div class="margin-v-xs">
        <label class="control-label">Un problème est survenu lors du chargement</label>
      </div>
      <input type="file" accept=".pdf" autocomplete="off" name="yourfile" style="display: none;">
    </div>
  </div>