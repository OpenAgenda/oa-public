<% include ../layout/_top.ejs %>

<div class="container agenda-settings">
    <div class="top-margined wsq">
        <div class="content">
            <div class="well">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <tbody>
                        <tr>
                            <td class="col-md-3">
                                Profil de l'agenda
                            </td>
                            <td>Modifier</td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Contribution
                            </td>
                            <td>Gérer</td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Administrateurs
                            </td>
                            <td>Gérer</td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Champs additionnels
                            </td>
                            <td>Premium (sale pauvre)</td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Grand agenda
                            </td>
                            <td>Premium (sale pauvre)</td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <tbody>
                        <tr>
                            <td class="col-md-3">
                                Profil de l'agenda
                            </td>
                            <td>
                                <form>
                                    <div class="form-group">
                                        <label for="title">Titre *</label>
                                        <input type="text" class="form-control" name="title"
                                               value="Gaetan Latouche - S'Latouche party">
                                    </div>
                                    <div class="form-group">
                                        <label for="describe">Description *</label>
                                        <div>
                                            <textarea name="describe" rows="6"></textarea>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label for="slug">Adresse web personnalisée *</label>
                                        <div class="input-group">
                                            <div class="input-group-addon">http://openagenda.com/</div>
                                            <input type="text" class="form-control" name="slug" placeholder="URL">
                                        </div>
                                    </div>
                                    <div class="form-inline pull-left">
                                        <button type="submit" class="btn btn-primary">Sauvegarder</button>
                                    </div>
                                    <div class="pull-right"><a href="#" class="text-danger">Supprimer l'agenda</a></div>
                                </form>
                            </td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Contribution
                            </td>
                            <td>
                                <form>
                                    <div class="checkbox">
                                        <label>
                                            <input type="checkbox" name="moderate"> Modérer les événements avant
                                            publication
                                        </label>
                                    </div>
                                    <div class="checkbox">
                                        <label>
                                            <input type="checkbox" name="onlyGuest"> Uniquement les invités peuvent
                                            ajouter des événements
                                        </label>
                                    </div>
                                    <div class="checkbox">
                                        <label>
                                            <input type="checkbox" name="requireStakeholder"> Les contributeurs
                                            requièrent un compte organisateur
                                        </label>
                                    </div>
                                    <div class="form-group">
                                        <label for="consigne">Consigne</label>
                                        <p>La consigne s'affiche au début du formalaire de saisie d'événement</p>
                                        <div>
                                            <textarea class="form-control" name="consigne" rows="6"></textarea>
                                        </div>
                                    </div>
                                    <div class="form-inline">
                                        <label>Limites des dates de saisie</label>
                                        <div class="container-fluid">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <div class="dropdown open">
                                                            <label for="startEntryDate">Du</label>
                                                            <input type="text" class="form-control" placeholder="Début"
                                                                   id="startEntryDate" data-toggle="dropdown"
                                                                   aria-haspopup="true" aria-expanded="true">
                                                            <ul class="dropdown-menu" aria-labelledby="startEntryDate">
                                                                <li>
                                                                    <% include ../components/_calendar %>
                                                                </li>
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <div class="dropdown open">
                                                            <label for="endEntryDate">Au</label>
                                                            <input type="text" class="form-control" placeholder="Fin"
                                                                   id="endEntryDate" data-toggle="dropdown"
                                                                   aria-haspopup="true" aria-expanded="true">
                                                            <ul class="dropdown-menu" aria-labelledby="startEntryDate">
                                                                <li>
                                                                    <% include ../components/_calendar %>
                                                                </li>
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-inline pull-left">
                                        <button type="submit" class="btn btn-primary">Sauvegarder</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Administrateurs
                            </td>
                            <td>

                            </td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Champs additionnels
                            </td>
                            <td>

                            </td>
                        </tr>
                        <tr>
                            <td class="col-md-3">
                                Modération premium
                            </td>
                            <td>
                                <form>
                                    <div class="form-group radio">
                                        <p><b>Circuit de validation</b></p>
                                        <label>
                                            <input type="radio" name="moderate"> Simple: En attente / Publié
                                        </label><br/>
                                        <label>
                                            <input type="radio" name="moderate"> Etendu: Nouveau / En attente / Refusé /
                                            Validé / Publié
                                        </label>
                                    </div>
                                    <div class="form-group radio">
                                        <p><b>Hiérarchie des membres</b></p>
                                        <label>
                                            <input type="radio" name="requireStakeholder"> Administrateurs et contributeurs
                                        </label><br>
                                        <label>
                                            <input type="radio" name="requireStakeholder"> Administrateurs, modérateurs et contributeurs
                                        </label>
                                    </div>
                                    <div class="form-group radio">
                                        <p><b>Les modérateurs peuvent-ils publier des événements?</b></p>
                                        <label>
                                            <input type="radio" name="moderatorCanPublish"> Oui
                                        </label><br>
                                        <label>
                                            <input type="radio" name="moderatorCanPublish"> Non, seuls les administrateurs peuvent publier
                                        </label>
                                    </div>
                                    <div class="form-inline pull-left">
                                        <button type="submit" class="btn btn-primary">Sauvegarder</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<% include ../layout/_bottom.ejs %>