{
  "extends": "@openagenda",

  "parserOptions": {
    "sourceType": "script"
  },

  "rules": {
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "test/**/*.js",
          "testconfig.sample.js",
          "testconfig.js"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "test/*.test.js",
        "stories/**/*.js",
        "src/**/*.js"
      ],
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ]
}
