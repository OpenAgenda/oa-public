{
  "presets" : [
    [ "env", {
        "targets": {
          "browsers": [
            "Explorer 11",
            "Firefox >= 24",
            "Chrome >= 33",
            "Safari >= 9",
            "last 4 Edge versions"
          ]
        },
        "useBuiltIns": true
    } ],
    "react",
    "stage-0"
  ]
}
