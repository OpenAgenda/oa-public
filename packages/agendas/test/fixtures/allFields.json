{
  "title": {
    "type": "text",
    "min": 2,
    "max": 255,
    "optional": false
  },
  "description": {
    "type": "text",
    "max": 400,
    "optional": false
  },
  "slug": {
    "type": "slug",
    "min": 2,
    "max": 255,
    "optional": false
  },
  "url": {
    "type": "link",
    "max": 255
  },
  "official": {
    "type": "boolean",
    "default": false
  },
  "networkUid": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "locationSetUid": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "settings": {
    "fields": {
      "admin": {
        "fields": {
          "filters": {
            "fields": {
              "displayed": {
                "type": "text",
                "list": { "default": null }
              }
            }
          }
        }
      },
      "locations": {
        "fields": {
          "extIds": {
            "type": "pass"
          }
        }
      },
      "public": {
        "fields": {
          "filters": {
            "fields": {
              "displayed": {
                "type": "text",
                "list": { "default": null }
              }
            }
          }
        }
      },
      "lab": {
        "fields": {
          "status": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "tracking": {
        "fields": {
          "googleAnalytics": {
            "type": "text",
            "max": 255
          },
          "matomoUrl": {
            "type": "text",
            "max": 255
          },
          "matomoSiteId": {
            "type": "text",
            "max": 255
          },
          "matomoAskForConsent": {
            "type": "boolean",
            "max": 255
          },
          "matomoCustom": {
            "type": "pass",
            "list": true
          }
        }
      },
      "inbox": {
        "fields": {
          "mailto": {
            "fields": {
              "enabled": {
                "type": "boolean",
                "default": false
              },
              "email": {
                "type": "email",
                "default": null
              },
              "subject": {
                "type": "text",
                "default": null
              },
              "body": {
                "type": "text",
                "default": null
              }
            }
          }
        }
      },
      "contribution": {
        "fields": {
          "type": {
            "default": 1,
            "type": "choice",
            "optional": false,
            "unique": true,
            "options": [2, 0, 1]
          },
          "defaultState": {
            "default": 2,
            "type": "choice",
            "optional": false,
            "unique": true,
            "options": [0, 1, 2]
          },
          "canPublish": {
            "type": "choice",
            "default": ["administrators", "moderators"],
            "options": ["administrators", "moderators"]
          },
          "moderateOnChangeBy": {
            "type": "choice",
            "default": [],
            "options": ["administrator", "moderator", "contributor"]
          },
          "modoCanInviteModo": {
            "max": 255,
            "type": "boolean"
          },
          "defaultLang": {
            "default": null,
            "type": "choice",
            "optional": true,
            "unique": true,
            "options": ["en", "fr", "it", "es", "de", "ar", null]
          },
          "allowLocationCreate": {
            "default": true,
            "type": "boolean"
          },
          "messages": {
            "fields": {
              "instructions": {
                "type": "text"
              },
              "complete": {
                "type": "text"
              },
              "publication": {
                "type": "text"
              },
              "GDPRInformation": {
                "type": "text"
              }
            }
          },
          "useFields": {
            "type": "boolean",
            "description": "require members to fill in a member form",
            "default": false
          },
          "authorizedIPAddresses": {
            "type": "ip",
            "list": true,
            "default": []
          },
          "status": {
            "fields": {
              "enabled": {
                "type": "choice",
                "default": [2, 5, 6],
                "options": [2, 3, 4, 5, 6]
              }
            }
          }
        }
      },
      "registration": {
        "fields": {
          "passCulture": {
            "fields": {
              "siren": {
                "list": {
                  "default": null
                },
                "optional": false,
                "type": "text"
              },
              "bookingEmail": {
                "default": null,
                "optional": true,
                "type": "email"
              },
              "access": {
                "list": { "default": null },
                "optional": true,
                "type": "text"
              },
              "defaultVenueId": {
                "default": null,
                "optional": true,
                "type": "integer"
              }
            },
            "optional": true
          }
        }
      }
    }
  },
  "uid": {
    "type": "integer",
    "optional": false
  },
  "ownerId": {
    "type": "integer",
    "optional": false
  },
  "updatedAt": {
    "type": "date",
    "optional": false
  },
  "createdAt": {
    "type": "date",
    "optional": false
  },
  "formSchemaId": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "memberSchemaId": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "officializedAt": {
    "type": "date",
    "default": null
  },
  "image": {
    "type": "pass",
    "default": null
  },
  "private": {
    "type": "boolean",
    "default": false
  },
  "indexed": {
    "type": "boolean",
    "default": true
  },
  "credentials": {
    "fields": {
      "premiumCustomFields": {
        "description": "Allow adding multiple custom fields to agenda form",
        "type": "boolean",
        "default": false
      },
      "moderators": {
        "description": "Add Moderator to member roles",
        "type": "boolean",
        "default": false
      },
      "activatingInvitations": {
        "description": "When the user with no account is invited to the agenda, no activation mail is required to complete signup",
        "type": "boolean",
        "default": false
      },
      "aggregator": {
        "description": "Agenda aggregation. Do not forget to initialize the tab on the agenda admin menu",
        "type": "boolean",
        "default": false
      },
      "invitationMessage": {
        "description": "Customizable members invitation message, contribution instruction, completion and publication, members grouped messaging",
        "type": "boolean",
        "default": false
      },
      "docxExport": {
        "description": "Word export feature",
        "type": "boolean",
        "default": false
      },
      "eventOwnershipTransfer": {
        "description": "Transfer ownership of event from one member to another within an agenda",
        "type": "boolean",
        "default": false
      },
      "memberCustom": {
        "default": false,
        "description": "Allow customisation of member fields",
        "type": "boolean"
      },
      "keepActivities": {
        "default": false,
        "description": "Keeps activities for an indefinite period",
        "type": "boolean"
      },
      "showTotals": {
        "default": false,
        "description": "Show totals on statistics page",
        "type": "boolean"
      }
    }
  }
}
