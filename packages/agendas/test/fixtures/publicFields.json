{
  "title": {
    "type": "text",
    "min": 2,
    "max": 255,
    "optional": false
  },
  "description": {
    "type": "text",
    "max": 255,
    "optional": false
  },
  "slug": {
    "type": "slug",
    "min": 2,
    "max": 255,
    "optional": false
  },
  "url": {
    "type": "link",
    "max": 255
  },
  "official": {
    "type": "boolean",
    "default": false
  },
  "networkUid": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "locationSetUid": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "settings": {
    "fields": {
      "lab": {
        "fields": {
          "status": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "tracking": {
        "fields": {
          "googleAnalytics": {
            "type": "text",
            "max": 255
          }
        }
      },
      "inbox": {
        "fields": {
          "mailto": {
            "fields": {
              "enabled": {
                "type": "boolean",
                "default": false
              },
              "email": {
                "type": "email",
                "default": null
              },
              "subject": {
                "type": "text",
                "default": null
              },
              "body": {
                "type": "text",
                "default": null
              }
            }
          }
        }
      },
      "contribution": {
        "fields": {
          "type": {
            "default": 1,
            "type": "choice",
            "optional": false,
            "unique": true,
            "options": [
              2,
              0,
              1
            ]
          },
          "defaultState": {
            "default": 2,
            "type": "choice",
            "optional": false,
            "unique": true,
            "options": [
              0,
              1,
              2
            ]
          },
          "canPublish": {
            "type": "choice",
            "default": [
              "administrators",
              "moderators"
            ],
            "options": [
              "administrators",
              "moderators"
            ]
          },
          "moderateOnChangeBy": {
            "type": "choice",
            "default": [],
            "options": [
              "administrator",
              "moderator",
              "contributor"
            ]
          },
          "defaultLang": {
            "default": null,
            "type": "choice",
            "optional": true,
            "unique": true,
            "options": [
              "en",
              "fr",
              "it",
              "es",
              "de",
              "ar",
              null
            ]
          },
          "allowLocationCreate": {
            "default": true,
            "type": "boolean"
          },
          "messages": {
            "fields": {
              "instructions": {
                "type": "text"
              },
              "complete": {
                "type": "text"
              },
              "publication": {
                "type": "text"
              },
              "GDPRInformation": {
                "type": "text"
              }
            }
          },
          "useFields": {
            "type": "boolean",
            "description": "require members to fill in a member form",
            "default": false
          },
          "authorizedIPAddresses": {
            "type": "ip",
            "list": true,
            "default": []
          }
        }
      },
      "translation": {
        "optional": true,
        "fields": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "source": {
            "type": "text",
            "min": 2,
            "max": 2,
            "default": "fr"
          },
          "sets": {
            "fields": {
              "source": {
                "type": "text",
                "min": 2,
                "max": 2,
                "default": "fr"
              },
              "target": {
                "list": {
                  "min": 0
                },
                "type": "text",
                "min": 2,
                "max": 2,
                "default": [
                  "en",
                  "es",
                  "it",
                  "de"
                ]
              },
              "checked": {
                "list": {
                  "min": 0
                },
                "type": "text",
                "min": 2,
                "max": 2,
                "default": []
              }
            },
            "list": {
              "min": 0
            },
            "default": []
          },
          "service": {
            "type": "text",
            "default": "reverso"
          },
          "options": {
            "type": "text"
          }
        }
      }
    }
  }
}
