{
  "title": {
    "type": "text",
    "min": 2,
    "max": 255,
    "optional": false
  },
  "description": {
    "type": "text",
    "max": 400,
    "optional": false
  },
  "slug": {
    "type": "slug",
    "min": 2,
    "max": 255,
    "optional": false
  },
  "url": {
    "type": "link",
    "max": 255
  },
  "official": {
    "type": "boolean",
    "default": false
  },
  "networkUid": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "locationSetUid": {
    "type": "integer",
    "optional": true,
    "default": null
  },
  "settings": {
    "fields": {
      "lab": {
        "fields": {
          "status": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "registration": {
        "fields": {
          "passCulture": {
            "fields": {
              "siren": {
                "list": {
                  "default": null
                },
                "optional": false,
                "type": "text"
              },
              "bookingEmail": {
                "default": null,
                "optional": true,
                "type": "email"
              },
              "access": {
                "list": { "default": null },
                "optional": true,
                "type": "text"
              },
              "defaultVenueId": {
                "default": null,
                "optional": true,
                "type": "integer"
              }
            },
            "optional": true
          }
        }
      },
      "tracking": {
        "fields": {
          "googleAnalytics": {
            "type": "text",
            "max": 255
          },
          "matomoUrl": {
            "type": "text",
            "max": 255
          },
          "matomoSiteId": {
            "type": "text",
            "max": 255
          },
          "matomoAskForConsent": {
            "type": "boolean",
            "max": 255
          },
          "matomoCustom": {
            "type": "pass",
            "list": true
          }
        }
      },
      "inbox": {
        "fields": {
          "mailto": {
            "fields": {
              "enabled": {
                "type": "boolean",
                "default": false
              },
              "email": {
                "type": "email",
                "default": null
              },
              "subject": {
                "type": "text",
                "default": null
              },
              "body": {
                "type": "text",
                "default": null
              }
            }
          }
        }
      },
      "contribution": {
        "fields": {
          "type": {
            "default": 1,
            "type": "choice",
            "optional": false,
            "unique": true,
            "options": [2, 0, 1]
          },
          "defaultState": {
            "default": 2,
            "type": "choice",
            "optional": false,
            "unique": true,
            "options": [0, 1, 2]
          },
          "canPublish": {
            "type": "choice",
            "default": ["administrators", "moderators"],
            "options": ["administrators", "moderators"]
          },
          "moderateOnChangeBy": {
            "type": "choice",
            "default": [],
            "options": ["administrator", "moderator", "contributor"]
          },
          "modoCanInviteModo": {
            "max": 255,
            "type": "boolean"
          },
          "defaultLang": {
            "default": null,
            "type": "choice",
            "optional": true,
            "unique": true,
            "options": ["en", "fr", "it", "es", "de", "ar", null]
          },
          "allowLocationCreate": {
            "default": true,
            "type": "boolean"
          },
          "messages": {
            "fields": {
              "instructions": {
                "type": "text"
              },
              "complete": {
                "type": "text"
              },
              "publication": {
                "type": "text"
              },
              "GDPRInformation": {
                "type": "text"
              }
            }
          },
          "useFields": {
            "type": "boolean",
            "description": "require members to fill in a member form",
            "default": false
          },
          "authorizedIPAddresses": {
            "type": "ip",
            "list": true,
            "default": []
          }
        }
      }
    }
  }
}
