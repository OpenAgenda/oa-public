{
  "name": "@openagenda/legacy",
  "version": "1.11.0",
  "description": "handle refactored legacy operations",
  "main": "index.js",
  "license": "MIT",
  "author": "Kaoré",
  "scripts": {
    "build": "babel --copy-files embeds/app/src -d embeds/app/dist -s",
    "start": "start-storybook -c embeds/app/.storybook -p 9001 --ci",
    "test": "jest --runInBand --testEnvironment=node",
    "prepack": "yarn extract-messages -c && yarn build",
    "extract-messages": "yarn oa-intl 'embeds/app/src/**/*.js' --output 'embeds/app/src/locales/%lang%.json' --compiled 'embeds/app/src/locales-compiled/%lang%.json'"
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.13.17",
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/intl": "^1.1.2",
    "@openagenda/logs": "^1.1.9",
    "@openagenda/react-shared": "^2.3.2",
    "@openagenda/utils": "^1.3.0",
    "@openagenda/validators": "^2.4.0",
    "@openagenda/verror": "^3.0.0",
    "axios": "^0.21.1",
    "axios-mock-adapter": "^1.19.0",
    "debug": "^4.1.1",
    "deep-diff": "^1.0.2",
    "immer": "^9.0.1",
    "immutability-helper": "^3.0.0",
    "knex": "^0.19.5",
    "leaflet": "^1.7.1",
    "locutus": "^2.0.14",
    "lodash": "^4.17.15",
    "moment-timezone": "^0.5.31",
    "mysql": "^2.16.0",
    "react-helmet-async": "^1.0.3",
    "react-intl": "^5.12.2",
    "react-leaflet": "^3.1.0",
    "react-query": "^3.6.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "react-use": "^15.3.4",
    "verror": "^1.10.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/core": "^7.13.16",
    "@loadable/babel-plugin": "^5.13.2",
    "@openagenda/babel-preset": "^1.4.1",
    "@storybook/react": "^6.2.8",
    "babel-loader": "^8.2.2",
    "jest": "^26.1.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "redis": "^2.8.0",
    "redux": "^4.0.5",
    "should": "^13.2.3"
  },
  "peerDependencies": {
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "redux": "^4.0.5"
  }
}
