{
  "name": "@openagenda/legacy",
  "version": "1.11.0",
  "description": "handle refactored legacy operations",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "author": "Kaoré",
  "scripts": {
    "sb": "yarn start",
    "build": "babel --copy-files embeds/app/src -d embeds/app/dist -s --env-name esm --root-mode upward",
    "start": "storybook dev -c embeds/app/.storybook -p 9001 --ci",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --runInBand --testEnvironment=node",
    "prepack": "yarn extract-messages -c && yarn build",
    "extract-messages": "oa-intl 'embeds/app/src/**/*.js' --output 'embeds/app/src/locales/%lang%.json' --compiled 'embeds/app/src/locales-compiled/%lang%.json' --esm"
  },
  "dependencies": {
    "@openagenda/bs-templates": "^2.5.0",
    "@openagenda/intl": "^1.1.5",
    "@openagenda/logs": "^1.1.9",
    "@openagenda/md": "^1.0.0",
    "@openagenda/react-shared": "^2.4.3",
    "@openagenda/utils": "^1.3.0",
    "@openagenda/validators": "^2.4.0",
    "@openagenda/verror": "^3.1.0",
    "axios": "^0.21.1",
    "debug": "^4.1.1",
    "deep-diff": "^1.0.2",
    "immer": "^10.0.3",
    "immutability-helper": "^3.0.0",
    "knex": "^2.4.2",
    "leaflet": "^1.7.1",
    "locutus": "^2.0.14",
    "lodash": "^4.17.15",
    "moment-timezone": "^0.5.31",
    "mysql": "^2.16.0",
    "react-helmet-async": "^1.0.3",
    "react-intl": "^6.8.4",
    "react-leaflet": "^3.1.0",
    "react-query": "^3.6.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "react-use": "^17.6.0",
    "slugify": "^1.4.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.6",
    "@storybook/react-webpack5": "^9.0.8",
    "jest": "^29.7.0",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^4.6.6",
    "redux": "^4.0.5",
    "storybook": "^9.0.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redux": "^4.0.5"
  },
  "msw": {
    "workerDirectory": "embeds/app/.storybook/public"
  },
  "jest": {
    "transform": {}
  }
}
