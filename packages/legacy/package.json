{
  "name": "@openagenda/legacy",
  "version": "1.11.3",
  "private": true,
  "description": "handle refactored legacy operations",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./embeds/app": "./embeds/app/dist/index.js",
    "./convertEventToLegacyFormat/*": "./convertEventToLegacyFormat/*",
    "./convertLegacyFilter/*": "./convertLegacyFilter/*",
    "./tagSetToFormSchema/*": "./tagSetToFormSchema/*",
    "./tagsAndCustom/*": "./tagsAndCustom/*",
    "./utils/*": "./utils/*"
  },
  "license": "MIT",
  "author": "Kaoré",
  "scripts": {
    "sb": "storybook dev -c embeds/app/.storybook",
    "build": "tsdown",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --runInBand --testEnvironment=node",
    "prepack": "yarn extract-messages -c && yarn build",
    "extract-messages": "oa-intl 'embeds/app/src/**/*.js' --output 'embeds/app/src/locales/%lang%.json' --compiled 'embeds/app/src/locales-compiled/%lang%.json' --esm"
  },
  "dependencies": {
    "@openagenda/bs-templates": "^2.6.0",
    "@openagenda/intl": "^2.0.0",
    "@openagenda/logs": "^1.2.0",
    "@openagenda/md": "^2.0.0",
    "@openagenda/react-shared": "^3.0.0",
    "@openagenda/utils": "^1.3.0",
    "@openagenda/validators": "^2.4.0",
    "@openagenda/verror": "^3.2.0",
    "debug": "^4.1.1",
    "deep-diff": "^1.0.2",
    "immer": "^10.0.3",
    "immutability-helper": "^3.0.0",
    "knex": "^2.4.2",
    "leaflet": "^1.7.1",
    "lodash": "^4.17.15",
    "moment-timezone": "^0.5.31",
    "react-helmet-async": "^1.0.3",
    "react-intl": "^10.1.1",
    "react-leaflet": "^3.1.0",
    "react-query": "^3.6.0",
    "react-redux": "^7.1.3",
    "react-router-config": "^5.1.1",
    "react-use": "^17.6.0",
    "slugify": "^1.4.5"
  },
  "devDependencies": {
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "jest": "^29.7.0",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.6",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "redis": "^4.6.6",
    "redux": "^4.0.5",
    "storybook": "^10.2.0",
    "tsdown": "^0.22.0"
  },
  "peerDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "redux": "^4.0.5"
  },
  "msw": {
    "workerDirectory": "embeds/app/.storybook/public"
  },
  "jest": {
    "transform": {}
  }
}
