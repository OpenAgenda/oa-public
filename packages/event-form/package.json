{
  "name": "@openagenda/event-form",
  "version": "1.5.5",
  "private": true,
  "type": "module",
  "main": "./build/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./build/index.js",
    "./*": "./build/*.js"
  },
  "scripts": {
    "sb": "storybook dev",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest --forceExit --detectOpenHandles",
    "prepack": "oa-intl compile --esm && yarn build",
    "build": "tsdown",
    "extract-messages": "oa-intl --esm"
  },
  "dependencies": {
    "@openagenda/agenda-locations": "^2.1.4",
    "@openagenda/agenda-locations-app": "^0.0.3",
    "@openagenda/common-labels": "^2.0.0",
    "@openagenda/countries": "^0.1.1",
    "@openagenda/events": "^3.0.3",
    "@openagenda/form-schemas": "^1.9.5",
    "@openagenda/intl": "^2.0.0",
    "@openagenda/labels": "^2.3.0",
    "@openagenda/react-shared": "^3.0.0",
    "@openagenda/react-timingspicker": "^2.0.0",
    "@openagenda/registration-apps": "^0.0.3",
    "@openagenda/utils": "^1.3.0",
    "@openagenda/validators": "^2.4.0",
    "classnames": "^2.3.1",
    "core-js": "^3.29.1",
    "date-fns": "^2.11.1",
    "immer": "^10.0.3",
    "immutability-helper": "^3.0.1",
    "languages": "^0.1.3",
    "lodash": "^4.17.15",
    "qs": "^6.10.3",
    "react": "^19.2.2",
    "react-date-range": "^1.1.3",
    "react-dom": "^19.2.2",
    "react-intl": "^10.1.1",
    "react-select": "^5.8.3",
    "react-tagsinput": "^3.19.0",
    "react-text-mask": "^5.4.3",
    "use-debounce": "^10.0.4"
  },
  "devDependencies": {
    "@openagenda/bs-templates": "^2.6.0",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "jest": "^29.7.0",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.6",
    "storybook": "^10.2.0",
    "tsdown": "^0.22.0"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/test/*.js"
    ],
    "transform": {}
  },
  "msw": {
    "workerDirectory": ".storybook/public"
  }
}
