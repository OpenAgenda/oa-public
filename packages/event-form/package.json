    "@openagenda/countries": "^0.1.1",
    "@openagenda/events": "^3.0.0",
    "@openagenda/form-schemas": "^1.9.2",
    "@openagenda/intl": "^1.1.5",
    "@openagenda/labels": "^2.3.0",
    "@openagenda/react-shared": "^2.4.3",
    "@openagenda/react-timingspicker": "^1.4.0",
    "@openagenda/registration-apps": "^0.0.0",
    "@openagenda/utils": "^1.3.0",
    "@openagenda/validators": "^2.4.0",
    "axios": "^1.4.0",
    "classnames": "^2.3.1",
    "core-js": "^3.29.1",
    "date-fns": "^2.11.1",
    "immer": "^10.0.3",
