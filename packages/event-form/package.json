    "qs": "^6.10.3",
    "react": "^19.0.0",
    "react-date-range": "^1.1.3",
    "react-dom": "^19.0.0",
    "react-intl": "^6.8.4",
    "react-select": "^5.8.3",
    "react-tagsinput": "^3.19.0",
