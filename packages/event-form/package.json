  "devDependencies": {
    "@openagenda/bs-templates": "^2.5.0",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.6",
    "@storybook/react-webpack5": "^9.0.8",
    "jest": "^29.7.0",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.5",
    "rimraf": "^3.0.1",
    "storybook": "^9.0.8",
    "tsup": "^8.3.5"
