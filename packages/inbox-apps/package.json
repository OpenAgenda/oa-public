  "homepage": "https://bitbucket.org/openagenda/oa/src/master/packages/inbox-apps",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "babel src -d dist -s",
    "start": "yarn clean && concurrently --kill-others-on-fail -n \"fixtures,build,client,app\" \"yarn fixtures\" \"yarn build -w\" \"yarn watch-client\" \" sleep 4 && yarn watch-server\"",
    "watch-client": "testapp-clientwatcher -i test/app/front.jsx -o .tmp/testapp-client.js",
    "watch-server": "nodemon -w test/app -w dist -w ../inboxes test/app",
    "fixtures": "node test/app/fixtures",
    "test": "jest --coverage --forceExit",
    "cov:watch": "reload -d coverage/lcov-report -p 3300 -b",
    "prepublish": "yarn clean && yarn build"
  },
  "peerDependencies": {
    "react": "^16.2.0",
    "react-dom": "^16.2.0"
  },
