{
  "name": "@openagenda/agenda-event-references",
  "version": "1.1.3",
  "description": "This service allows adding references within an event to other events in the same agenda.",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "main": "service/index.js",
  "scripts": {
    "test": "mocha --exit",
    "start": "concurrently -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ./node_modules/.bin/knex",
    "build": "babel react/src -d react/build -s",
    "clean": "rimraf react/build",
    "prepublish": "yarn clean && yarn build"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.3.1",
    "@openagenda/dom-utils": "^2.2.0",
    "@openagenda/labels": "^2.1.0",
    "@openagenda/mysql-utils": "^2.0.0",
    "@openagenda/react-components": "^2.2.1",
    "@openagenda/react-form-components": "^2.1.1",
    "@openagenda/utils": "^1.0.2",
    "create-react-class": "^15.5.2",
    "es6-promise": "^3.2.1",
    "immutability-helper": "^3.0.0",
    "knex": "^0.16.3",
    "lodash": "^4.17.4",
    "mysql": "^2.11.1",
    "prop-types": "^15.5.8",
    "react-redux": "^4.4.5",
    "redux": "^3.5.2",
    "redux-thunk": "^2.1.0",
    "when": "^3.7.7"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.2.2",
    "@babel/node": "^7.2.2",
    "@openagenda/bs-templates": "^2.2.0",
    "@storybook/react": "^4.1.11",
    "babel-loader": "^8.0.4",

"@openagenda/babel-preset": "^1.1.1",
    "concurrently": "^4.1.0",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.16.4",
    "mocha": "^5.0.0",
    "morgan": "^1.9.1",
    "nodemon": "^1.18.9",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "rimraf": "^2.6.2",
    "should": "^9.0.2"
  },
  "peerDependencies": {
    "react": "^16.8.6",
    "react-dom": "^16.8.6"
  }
