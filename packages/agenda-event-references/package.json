{
  "name": "@openagenda/agenda-event-references",
  "version": "1.1.15",
  "description": "This service allows adding references within an event to other events in the same agenda.",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "main": "service/index.js",
  "scripts": {
    "test": "mocha --exit",
    "start": "concurrently -r -k -i -n server,storybook \"yarn dev-server\" \"yarn storybook --ci\"",
    "dev-server": "NODE_ENV=development PORT=3000 nodemon -w server.dev.js -w src/service --signal SIGTERM --exec babel-node server.dev.js",
    "storybook": "NODE_ENV=development STORYBOOK_API_PORT=3000 start-storybook -p 9001",
    "knex": "babel-node ./node_modules/.bin/knex",
    "build": "babel react/src -d react/build -s",
    "clean": "rimraf react/build",
    "prepack": "yarn clean && yarn build"
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.12.5",
    "@openagenda/dom-utils": "^2.2.11",
    "@openagenda/labels": "^2.2.7",
    "@openagenda/mysql-utils": "^2.0.4",
    "@openagenda/react-components": "^2.3.9",
    "@openagenda/react-form-components": "^2.1.13",
    "@openagenda/utils": "^1.2.9",
    "core-js": "^3.6.5",
    "create-react-class": "^15.5.2",
    "es6-promise": "^3.2.1",
    "immutability-helper": "^3.0.0",
    "knex": "^0.19.5",
    "lodash": "^4.17.15",
    "mysql": "^2.11.1",
    "prop-types": "^15.5.8",
    "react-redux": "^7.1.3",
    "redux": "^3.5.2",
    "redux-thunk": "^2.1.0",
    "when": "^3.7.8"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.1",
    "@babel/core": "^7.12.3",
    "@babel/node": "^7.12.6",
    "@openagenda/babel-preset": "^1.3.8",
    "@openagenda/bs-templates": "^2.4.6",
    "@openagenda/fixtures": "^2.0.2",
    "@storybook/react": "^6.1.0",
    "babel-loader": "^8.2.1",
    "concurrently": "^5.1.0",
    "cors": "^2.8.5",
    "errorhandler": "^1.5.0",
    "express": "^4.17.1",
    "mocha": "^7.0.1",
    "morgan": "^1.9.1",
    "nodemon": "^2.0.4",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "rimraf": "^3.0.1",
    "should": "^13.2.3"
  },
  "peerDependencies": {
    "react": "^16.12.0"
  }
}
