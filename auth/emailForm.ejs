<div class="canvas page">

  <h1><%= __('Create an account') %></h1>

  <p><%= __( 'Complete the signup process by typing in your email' ) %></p>

  <form class="cform" method="get" action="<%= genUrl( uri, { iToken: iToken } ) %>">
    <ul>
      <li>
        <label for="email"><%= __('Email') %></label>
        <input type="email" name="email" value="<%= email %>" />
<% if ( errors.email ) { %>
        <span class="error"><%= __( errors.email ) %></span>
<% } %>        
      </li>
    <button type="submit"><%= __('Confirm Email') %></button>

  </form>

</div>