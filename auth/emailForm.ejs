<div class="canvas">

  <p><%= __('Complete the signup process by typing in your email') %></p>

  <form class="cform" method="post" action="<%= genUrl( 'twitterEmail', { user: user, iToken: iToken } ) %>">
    <ul>
      <li>
        <label for="email"><%= __('Email') %></label>
        <input type="email" name="email" value="<%= values.email %>" />
<% if ( errors.email ) { %>
        <span class="error"><%= __( errors.email ) %></span>
<% } %>        
      </li>
    <button type="submit"><%= __('Confirm Email') %></button>

  </form>

</div>