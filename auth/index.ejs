<div class="signin">

     <form method="post" action="<%= genUrl( 'localAuth', { redirect: redirect } ) %>" >
     	    <input type="email" name="email" placeholder="email" /> 
      	    <input type="password" name="password" placeholder="password"/ >
      	    <button type="submit"> Log in </button>
     </form>
     <a href="<%= genUrl( 'facebookAuth' ) %>"> Facebook </a>
     <a href="<%= genUrl( 'twitterAuth' ) %>"> Twitter </a>
     <a href="<%= genUrl( 'googleAuth' ) %>"> Google+ </a>
</div>