<div class="signin">

     <form method="post" action="<%= genUrl( 'localAuth', { redirect: redirect, iToken: iToken } ) %>" >
     	    <input type="email" name="email" placeholder="email" /> 
      	    <input type="password" name="password" placeholder="password"/ >
      	    <button type="submit"> Log in </button>
     </form>
     <a href="<%= genUrl( 'facebookAuth', { redirect: redirect, iToken: iToken } ) %>"> Facebook </a>
     <a href="<%= genUrl( 'twitterAuth', { redirect: redirect, iToken: iToken } ) %>"> Twitter </a>
     <a href="<%= genUrl( 'googleAuth', { redirect: redirect, iToken: iToken } ) %>"> Google+ </a>
</div>