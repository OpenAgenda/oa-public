<!DOCTYPE html>
<html>
  <head>
<% for ( var i in head.css ) { %>
    <link rel="stylesheet" href="<%= head.css[i] %>"/>
<% } %>
<% for ( var i in js ) { %>
    <script type="text/javascript" src="<%= js[i] %>"></script>
<% } %>
  </head>
  <body<% if ( pageClass ) { %> class="<%= pageClass %>"<% } %>>
    <header>
      <a class="logo" href="#"><img src="/images/biglogo.png"></a>
      <ul class="links site-links js_header_links">
        <li class="language-menu js_language_menu">
          <a><% if ( ( typeof lang == 'undefined' ) || lang=='fr' ) { %>fr<% } else { %>en<% } %></a>
          <ul class="language-menu">
            <li><a rel="alternate" href="?lang=fr" hreflang="fr">français</a></li><!--
            --><li><a href="?lang=en" hreflang="en">english</a></li>
          </ul>
        </li>
        <li>
          <form class="search" method="get" value="<%= search %>" action="<%= genUrl(searchRes) %>">
            <input type="text" name="search"/>
            <i class="fa fa-search"></i>
          </form>
        </li>
      </ul>
    </header>