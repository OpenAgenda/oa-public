{
  "name": "@openagenda/react-filters",
  "version": "2.13.8",
  "type": "module",
  "main": "./build/index.cjs",
  "module": "./build/index.mjs",
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://github.com/OpenAgenda/oa-public",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build",
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./build/index.mjs",
      "require": "./build/index.cjs"
    },
    "./locales": {
      "import": "./build/locales/index.mjs",
      "require": "./build/locales/index.cjs"
    },
    "./*": {
      "import": "./build/*.mjs",
      "require": "./build/*.cjs"
    }
  },
  "scripts": {
    "sb": "NODE_OPTIONS=\"--max-old-space-size=5120\" storybook dev",
    "prepack": "oa-intl compile --esm && yarn build && yarn dist",
    "build": "tsdown",
    "dist": "webpack-cli --config webpack.config.cjs",
    "extract-messages": "oa-intl --esm",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "start": "concurrently -r -k -i -n dist,sb \"yarn dist -w\" \"yarn sb\"",
    "example": "cd example && nodemon server.js"
  },
  "dependencies": {
    "@babel/runtime-corejs3": "^7.28.4",
    "@emotion/react": "^11.11.1",
    "@formatjs/cli": "^2.11.3",
    "@openagenda/intl": "^2.0.0",
    "@openagenda/leaflet-gesture-handling": "^1.5.0",
    "@openagenda/react-date-range": "^2.0.2",
    "@openagenda/react-portal-ssr": "^1.1.0",
    "@openagenda/react-shared": "^3.0.1",
    "@openagenda/verror": "^3.2.0",
    "classnames": "^2.3.1",
    "core-js": "^3.29.1",
    "date-fns": "^2.11.1",
    "date-fns-tz": "^2.0.1",
    "final-form": "^4.20.2",
    "fuse.js": "^7.1.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.20",
    "qs": "^6.9.1",
    "react-final-form": "^6.5.3",
    "react-final-form-listeners": "^1.0.3",
    "react-intl": "^10.1.1",
    "react-leaflet": "^5.0.0",
    "react-query": "^3.31.0",
    "react-select": "^5.8.3",
    "react-uid": "^2.3.0",
    "react-use": "^17.6.0",
    "slate-dom": "^0.112.2",
    "swiper": "^12.1.2",
    "use-debounce": "^10.0.4",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^2.1.0",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "babel-loader": "^9.1.3",
    "body-parser": "^1.20.3",
    "bootstrap": "4.3.1",
    "concurrently": "^6.3.0",
    "dotenv": "^10.0.0",
    "ejs": "^3.1.9",
    "express": "^4.21.2",
    "jest": "^29.7.0",
    "ky": "^1.14.0",
    "mkdirp": "^3.0.1",
    "msw": "^2.3.0",
    "msw-storybook-addon": "^2.0.6",
    "nodemon": "^2.0.15",
    "raw-loader": "^4.0.2",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "sass": "^1.83.1",
    "source-map-loader": "^2.0.1",
    "storybook": "^10.2.0",
    "terser-webpack-plugin": "^5.3.9",
    "tsdown": "^0.22.0",
    "webpack": "^5.53.0",
    "webpack-cli": "^5.1.4",
    "webpackbar": "^5.0.0-3"
  },
  "peerDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  },
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  }
}
