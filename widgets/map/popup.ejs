<div class="map-location">
<% if (typeof count !== 'undefined') { %>
    <span class="count">
      <span><%= count %></span>
      <label> <%= count==1?labels.events.replace('s', ''):labels.events %></label>
    </span>
<% } %>
<% if (typeof image !== 'undefined') { %><img src="<%= image %>"/><% } %>
  <span>
    <p><%= name %></p>
    <span class="map-address"><%= address %></span>
    <span class="map-postalcode"><%= postalCode %></span>
    <span class="map-city"><%= city %></span>
    <span class="map-department"><%= department %></span>
    <span class="map-region"><%= region %></span>
  </span>
</div>