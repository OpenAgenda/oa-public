<div class="header">
  <h2><%= __("Contact List Menu") %> - <%= title %></h2>
  <a class="url" href="<%= genUrl('newsletterIndex') %>"><%= __('back to index') %></a>
</div>

<section>

<% include ../../general/pages %>
  
<% if (contacts.length) { %>
<ul class="glist">
<% contacts.forEach(function(contact) { %>
  <li>
    <span><%= contact.email %></span>
    <a class="url right" href="<%= genUrl('contactRemove', { uid: uid, email: contact.email }, { maintain: true }) %>"><%= __('remove') %></a>
  </li>
<% }) %>
</ul>  
<% } else { %>
  <p><%= __('This list is currently empty. Add some emails in the field below.') %></p>
<% } %>

<% include ../../general/pages %>

</section>

<section>
  <form class="cform" method="post" action="<%= genUrl('contactsAdd', { uid: uid }) %>">
    <ul>
      <li>
        <label><%= __('Add contacts') %></label>
        <textarea name="emails" rows="6"><% if (values.emails) { %><%= values.emails %><% } %></textarea>
        <span class="info"><%= __('Emails should be separated by a comma, a semicolon or a new line.') %></span>
<% if (errors.emails) { %>
        <span class="error"><%= __(errors.emails) %></span>
<% } %>
      </li>
      <li>
        <button type="submit"><%= __('Add') %></button>
      </li>
    </ul>
  </form>
</section>