<div class="cbody dialog">
  <div class="wsq">

    <h1><%= __('Unsubscribe') %></h1>

    <form class="cform" method="post" action="<%= genUrl('unsubscribeSubmit', { uid : uid } ) %>">
      <ul>
        <li>
          <label for="email"><%= __('Type in your email to unsubscribe to the newsletter') %></label>
          <input name="email" type="text"/>
        </li>
        <li>
          <button type="submit"><%= __('Confirm') %></button>
        </li>
      </ul>
    </form>

  </div>
</div>