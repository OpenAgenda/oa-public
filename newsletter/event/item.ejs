<% if (type=='html') {             // HTML PART               %>
<% include ../sections/top %>
  <span class="itemTitle" target="_blank" style="<%= css.itemTitle %>">
    <a class="itemTitlea" href="<%= genUrl('agendaEventShow', { eSlug: event.slug }, { abs: true }) %>" style="<%= css.itemTitlea %>"><%= event.title %></a>
  </span>
  <span class="itemSpaceTime" target="_blank" style="<%= css.itemSpaceTime %>">
    <a class="itemSpaceTimea" href="<%= genUrl('agendaEventShow', { eSlug: event.slug }, { abs: true }) %>" style="<%= css.itemSpaceTimea %>"><%= __(event.spaceTimeInfo[0], _t(event.spaceTimeInfo[1])) %></a>
  </span>   
  <span class="itemDesc" target="_blank" style="<%= css.itemDesc %>">
    <a class="itemDesca" href="<%= genUrl('agendaEventShow', { eSlug: event.slug }, { abs: true }) %>" style="<%= css.itemDesca %>"><%= event.description %></a>
  </span>
<% if ( nextIsItem ) { %>
  <span class="itemSeparator" style="<%= css.itemSeparator %>"></span>
<% } %>
<% include ../sections/bottom %>

<% } else {              // TEXT PART              %><%- event.title %>
<%- __(event.spaceTimeInfo[0], _t(event.spaceTimeInfo[1])) %>
<%- event.description %>
<% } %>