<% if (type=='html') {             // HTML PART               %>
<% include ../sections/top %>
<table>
  <tr>
<% if (event.image) { %>
    <td>
      <img src="<%= event.image %>"/>
    </td>
<% } %>
    <td>
      <span target="_blank" style="<%= css.itemTitle %>">
        <a href="<%= genUrl('agendaEventShow', { eSlug: event.slug }) %>" style="<%= css.itemTitlea %>"><%= event.title %></a>
      </span>
      <span target="_blank" style="<%= css.itemSpaceTime %>">
        <a href="<%= genUrl('agendaEventShow', { eSlug: event.slug }) %>" style="<%= css.itemSpaceTimea %>"><%= __(event.spaceTimeInfo[0], _t(event.spaceTimeInfo[1])) %></a>
      </span>   
      <span target="_blank" style="<%= css.itemDesc %>">
        <a href="<%= genUrl('agendaEventShow', { eSlug: event.slug }) %>" style="<%= css.itemDesca %>"><%= event.description %></a>
      </span> 
    </td>
  </tr>
</table>
<% include ../sections/bottom %>

<% } else {              // TEXT PART              %><%- event.title %>
<%- __(event.spaceTimeInfo[0], _t(event.spaceTimeInfo[1])) %>
<%- event.description %>
<% } %>