<% if (type=='html') {             // HTML PART               %>
<% include ../sections/top %>
<table>
  <tr>
<% if (event.image) { %>
    <td>
      <img src="<%= event.image %>"/>
    </td>
<% } %>
    <td>
      <h3 target="_blank" style="<%= css.h3 %>">
        <a href="<%= genUrl('agendaEventShow', { eSlug: event.slug }) %>" style="<%= css.h3a %>"><%= event.title %></a>
      </h3>
      <h4 target="_blank" style="<%= css.h4 %>">
        <a href="<%= genUrl('agendaEventShow', { eSlug: event.slug }) %>" style="<%= css.h4a %>"><%= event.description %></a>
      </h4>
      <h4 target="_blank" style="<%= css.h4 %>">
        <a href="<%= genUrl('agendaEventShow', { eSlug: event.slug }) %>" style="<%= css.h4a %>"><%= __(event.spaceTimeInfo[0], _t(event.spaceTimeInfo[1])) %></a>
      </h4>    
    </td>
  </tr>
</table>
<% include ../sections/bottom %>

<% } else {              // TEXT PART              %><%- event.title %>
<%- __(event.spaceTimeInfo[0], _t(event.spaceTimeInfo[1])) %>
<%- event.description %>
<% } %>