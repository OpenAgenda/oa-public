                            <div class="carousel-caption">
                                <h3>La semaine de l'industrie</h3>
                            </div>
                        </a>
                    </div>
                    <div class="item">
                        <a href="http://www.dutilleux2016.com/agenda/" target="_blank">
                            <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_3.png" alt="integration_3">
                            <div class="carousel-caption">
                                <h3>L'agenda Dutilleux</h3>
                            </div>
                        </a>
                    </div>
                    <div class="item">
                        <a href="http://www.lasemainenumerique.paris/" target="_blank">
                            <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_4.png" alt="integration_4">
                            <div class="carousel-caption">
                                <h3>La semaine numérique</h3>
                            </div>
                        </a>
                    </div>
                    <div class="item">
                        <a href="http://journee-arts-culture-sup.fr/" target="_blank">
