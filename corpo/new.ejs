<div id="presentation">
    <div class="container">
        <div class="row spaced">
            <div class="col-md-offset-8 col-md-4">
                <h1>Une solution de <br>
                    <div class="typed"></div>
                    <br>
                    pour vos événements
                </h1>
                <p>Pour votre université, festival, salon, ville, lieu, tournée, campagne, entreprise, magazine,
                    communauté, etc.&nbsp;!</p>
                <p>
                    <a href="<%= genUrl( 'signup' ) %>" class="btn btn-default btn-lg">
                        Créez votre agenda
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

<div class="background-white" id="fonctions">
    <div class="container">
        <div class="row spaced">
            <ul class="list-unstyled text-center">
                <li class="col-xs-4">
                    <div class="box-tooltip" data-toggle="tooltip" data-placement="bottom"
                         title="Lorem ipsum dolor sit amet, consectetur adipisicing elit. Laudantium nostrum perferendis vel?">
                        <p><img src="//s3.eu-central-1.amazonaws.com/oastatic/contribuer.png" width="70"></p>
                        <p>Créez votre agenda</p>
                    </div>
                </li>
                <li class="col-xs-4">
                    <div class="box-tooltip">
                        <p><img src="//s3.eu-central-1.amazonaws.com/oastatic/collaborez.svg" width="70"></p>
                        <p>Collaborez</p>
                    </div>
                </li>
                <li class="col-xs-4">
                    <div class="box-tooltip">
                        <p><img src="//s3.eu-central-1.amazonaws.com/oastatic/diffusez.svg" width="70"></p>
                        <p>Diffusez</p>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>

<div class="background-gray">
    <div class="container">
        <div class="spaced">
            <div id="carousel-screens" class="carousel slide" data-ride="carousel">
                <!-- Indicators -->
                <ol class="carousel-indicators">
                    <li data-target="#carousel-screens" data-slide-to="0" class="active"></li>
                    <li data-target="#carousel-screens" data-slide-to="1"></li>
                    <li data-target="#carousel-screens" data-slide-to="2"></li>
                    <li data-target="#carousel-screens" data-slide-to="3"></li>
                    <li data-target="#carousel-screens" data-slide-to="4"></li>
                </ol>

                <!-- Wrapper for slides -->
                <div class="carousel-inner" role="listbox">
                    <div class="item active">
                        <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_1.png" alt="integration_1">
                    </div>
                    <div class="item">
                        <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_2.png" alt="integration_2">
                    </div>
                    <div class="item">
                        <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_3.png" alt="integration_3">
                    </div>
                    <div class="item">
                        <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_4.png" alt="integration_4">
                    </div>
                    <div class="item">
                        <img src="//s3-eu-west-1.amazonaws.com/cibulstatic/integration_5.jpg" alt="integration_5">
                    </div>
                </div>

                <!-- Controls -->
                <a class="left carousel-control" href="#carousel-screens" role="button" data-slide="prev">
                    <i class="fa fa-angle-left fa-4" aria-hidden="true"></i>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="right carousel-control" href="#carousel-screens" role="button" data-slide="next">
                    <i class="fa fa-angle-right fa-4" aria-hidden="true"></i>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="background-white" id="produits" name="produits">
    <div class="container">
        <div class="row spaced">
            <div class="media col-md-offset-1 col-md-10 col-lg-offset-2 col-lg-8">
                <article class="media-body media-middle">
                    <h2 class="media-heading">Un agenda <em>complet</em> et <em>structuré</em></h2>
                    <p>Vos événements sont détaillés et vous pouvez explorer votre agenda par de multiples facettes&nbsp;!</p>
                </article>
                <figure class="media-right media-middle">
                    <img src="//s3.eu-central-1.amazonaws.com/oastatic/explorez.svg" width="256">
                </figure>
            </div>
        </div>
    </div>
</div>

<div class="background-gray">
    <div class="container">
        <div class="row spaced">
            <div class="media col-md-offset-1 col-md-10 col-lg-offset-2 col-lg-8">
                <figure class="media-left media-middle">
                    <img src="//s3.eu-central-1.amazonaws.com/oastatic/adaptez.svg" width="256">
                </figure>
                <article class="media-body media-middle">
                    <h2 class="media-heading">Pour petits, moyens et grands agendas <em>participatifs</em></h2>
                    <p>Seul&nbsp;? En équipe de quelques dizaines&nbsp;? De dizaines de milliers&nbsp;?<br>Votre agenda
                        s'adapte à votre contexte&nbsp;!</p>
                </article>
            </div>
        </div>
    </div>
</div>

<div class="background-white">
    <div class="container">
        <div class="row spaced">
            <div class="media col-md-offset-1 col-md-10 col-lg-offset-2 col-lg-8">
                <article class="media-body media-middle">
                    <h2 class="media-heading">Déployez <em>votre réseau</em> d'agendas&nbsp;!</h2>
                    <p>Vous animez une fédération&nbsp;? Un territoire&nbsp;?<br>Déployez un réseau d'agendas et agrégez
                        en temps réel tous les événements&nbsp;!</p>
                </article>
                <figure class="media-right media-middle">
                    <img src="//s3.eu-central-1.amazonaws.com/oastatic/deployez.svg" width="256">
                </figure>
            </div>
        </div>
    </div>
</div>

<div class="background-gray">
    <div class="container">
        <div class="row spaced">
            <div class="media col-md-offset-1 col-md-10 col-lg-offset-2 col-lg-8">
                <figure class="media-left media-middle">
                    <img src="//s3.eu-central-1.amazonaws.com/oastatic/partagez.svg" width="256">
                </figure>
                <article class="media-body media-middle">
                    <h2 class="media-heading">Partagez <em>vos événements</em></h2>
                    <p>
                        Votre agenda est synchronisable avec tous vos supports et diffusables par tous&nbsp;!<br>
                        #DonnéesOuvertes #OpenData</p>
                </article>
            </div>
        </div>
    </div>
</div>

<div class="background-blue" id="tarifs">
    <div class="container">
        <div class="spaced">
            <h2 class="text-center">Tarifs</h2>
            <div class="price">
                <section class="price-item">
                    <h3 class="price-title"><i class="fa fa-bookmark"></i><br>Standard</h3>
                    <p class="price-accent">Gratuit</p>
                    <ul class="price-features list-unstyled">
                        <li class="price-feature">Nombre d'événements illimité</li>
                        <li class="price-feature">Nombre de membre illimité</li>
                        <li class="price-feature">Téléchargements illimités</li>
                        <li class="price-feature">OpenData</li>
                        <li class="price-feature">Multilingue et multimédia</li>
                        <li class="price-feature">Pré &amp; post modération</li>
                        <li class="price-feature">Agrégation</li>
                    </ul>
                    <p class="price-btn">
                        <a class="btn btn-primary btn-lg btn-block" href="mailto:contact@openagenda.com">
                            Nous contacter
                        </a>
                    </p>
                </section>
                <section class="price-item">
                    <h3 class="price-title"><i class="fa fa-cog"></i><br>Custom</h3>
                    <p class="price-accent">600&nbsp;€ / an</p>
                    <ul class="price-features list-unstyled">
                        <li class="price-feature"><strong>les fonctions Standard <i class="fa fa-check"></i></strong>
                        </li>
                        <li class="price-feature">Champs personnalisables</li>
                        <li class="price-feature">Embed personnalisable</li>
                        <li class="price-feature">Limitation des dates et lieux</li>
                        <li class="price-feature">Fiches lieux détaillées</li>
                        <li class="price-feature">Privé ou public</li>
                    </ul>
                    <p class="price-btn">
                        <a class="btn btn-primary btn-lg btn-block" href="mailto:contact@openagenda.com">
                            Nous contacter
                        </a>
                    </p>
                </section>
                <section class="price-item price-item-featured">
                    <h3 class="price-title"><i class="fa fa-star"></i><br>Premium</h3>
                    <p class="price-accent">6&nbsp;000&nbsp;€ / an</p>
                    <ul class="price-features list-unstyled">
                        <li class="price-feature"><strong>les fonctions Custom <i class="fa fa-check"></i></strong></li>
                        <li class="price-feature">Circuit de validation étendu</li>
                        <li class="price-feature">Modérateurs</li>
                        <li class="price-feature">Emailing interne</li>
                    </ul>
                    <p class="price-btn">
                        <a class="btn btn-primary btn-lg btn-block" href="mailto:contact@openagenda.com">
                            Nous contacter
                        </a>
                    </p>
                </section>
                <section class="price-item">
                    <h3 class="price-title"><i class="fa fa-sitemap"></i><br>Portail</h3>
                    <p class="price-accent">Sur mesure</p>
                    <ul class="price-features list-unstyled">
                        <li class="price-feature">Définition de l'axe éditorial</li>
                        <li class="price-feature">Animation de communauté</li>
                        <li class="price-feature">Pyramide d'agendas</li>
                        <li class="price-feature">Déploiement et reporting</li>
                    </ul>
                    <p class="price-btn">
                        <a class="btn btn-primary btn-lg btn-block" href="mailto:contact@openagenda.com">
                            Nous contacter
                        </a>
                    </p>
                </section>
            </div>
        </div>
    </div>
</div>

