<div id="presentation">
    <div class="container">
        <div class="spaced text-center">
            <h1 class="hook">Créez un agenda public performant</h1>
            <p class="under-hook">Pour votre <br><span class="typed"></span></p>
            <p class="hook-action">
                <a href="<%= genUrl( 'signup' ) %>" class="btn btn-primary btn-lg">
                    Créer un agenda
                </a>
            </p>
        </div>
    </div>
</div>

<div class="background-white" id="trio-actions">
    <div class="container">
        <div class="spaced">
            <ul class="list-unstyled row text-center">
                <li class="col-xs-12 col-sm-4">
                    <i class="fa fa-sliders fa-4x" aria-hidden="true"></i>
                    <p>Paramétrez</p>
                </li>
                <li class="col-xs-12 col-sm-4">
                    <i class="fa fa-users fa-4x" aria-hidden="true"></i>
                    <p>Collaborez</p>
                </li>
                <li class="col-xs-12 col-sm-4">
                    <i class="fa fa-bullhorn fa-4x" aria-hidden="true"></i>
                    <p>Diffusez</p>
                </li>
            </ul>
        </div>
    </div>
</div>

