<div class="background-gray">
    <div class="container">
        <div class="spaced">
            <h2 class="text-center">En ce moment</h2>
            <ul class="list-unstyled text-center">
                <div class="row">
                    <li class="col-sm-4">
                        <p>
                            <strong class="h1"><%= stats.agendas.toString().replace( /\B(?=(\d{3})+(?!\d))/g, " " ) %></strong>
                            agendas
                        </p>
                    </li>
                    <li class="col-sm-4">
                        <p>
                            <strong class="h1"><%= stats.contributors.toString().replace( /\B(?=(\d{3})+(?!\d))/g, " " ) %></strong>
                            contributeurs
                        </p>
                    </li>
                    <li class="col-sm-4">
                        <p>
                            <strong class="h1"><%= stats.events.toString().replace( /\B(?=(\d{3})+(?!\d))/g, " " ) %></strong>
                            événements
                        </p>
                    </li>
                </div>
            </ul>
        </div>
    </div>
</div>

