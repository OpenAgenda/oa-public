<div class="background-white" id="references">
  <div class="container">
    <div class="spaced">
      <h2 class="text-center"><%= __( 'ourReferences' ) %></h2>
      <div id="carousel-screens" class="carousel slide" data-ride="carousel">
        <!-- Indicators -->
        <ol class="carousel-indicators">
          <% references.forEach( function( reference, i ) { %>
          <li data-target="#carousel-screens"
            data-slide-to="<%= i %>"<%- i == 0 ? ' class="active"' : '' %>></li>
          <% } ); %>
        </ol>

        <!-- Wrapper for slides -->
        <div class="carousel-inner" role="listbox">
          <% references.forEach( function( reference, i ) { %>
          <div class="item<%= i == 0 ? ' active' : '' %>">
            <a href="<%= reference.url %>" target="_blank">
              <img src="<%= reference.image %>" alt="integration_<%= i %>">
              <div class="hidden-xs carousel-caption">
                <h3><%= reference.caption %></h3>
                <p><i><%= reference.url %></i></p>
              </div>
            </a>
          </div>
          <% } ); %>
        </div>

        <!-- Controls -->
        <a class="left carousel-control" href="#carousel-screens" role="button" data-slide="prev">
          <!-- <i class="fa fa-angle-left" aria-hidden="true"></i>
          <span class="sr-only"><%= __( 'previous' ) %></span> -->
        </a>
        <a class="right carousel-control" href="#carousel-screens" role="button" data-slide="next">
          <!-- <i class="fa fa-angle-right" aria-hidden="true"></i>
          <span class="sr-only"><%= __( 'next' ) %></span> -->
        </a>
      </div>
    </div>
  </div>
</div>

<div class="background-white" id="testimonials">
  <div class="container">
    <div class="spaced">
      <h2 class="text-center"><%= __( 'customersSay' ) %></h2>
      <ul class="list-unstyled row">
        <% testimonials.forEach( function( testi ) { %>
        <li class="col-sm-4">
          <blockquote>
            <div class="quote">
              <p><%- testi.text[ [ 'fr', 'en' ].indexOf( lang ) !== -1 ? lang : 'fr' ] %></p>
            </div>
            <footer class="media">
              <img class="img-circle" src="<%- testi.image %>"
                 width="40">
              <strong><%= testi.name %></strong><br>
              <span><%= testi.job %></span>
            </footer>
          </blockquote>
        </li>
        <% }); %>
      </ul>
      <!--<p class="text-center">
        <a class="btn btn-link btn-lg" href="">Voir plus de références</a>
      </p>-->
    </div>
  </div>
</div>

