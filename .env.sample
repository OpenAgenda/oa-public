REPO_SSL_CLIENT=/home/you/.ssh/id_rsa
NPM_TOKEN=
DEBUG_COLORS=true
DEBUG_INCLUDE_SPAN=0
NODE_ENV=development

OA_NEXT_PORT=8901
OA_API_PORT=8902
OA_SERVER_PORT=8903

# User for node and devinstaller containers (https://docs.docker.com/engine/reference/run/#user),
# result of `echo $(id -u):$(id -g)`
DOCKER_USER=1000:1000

ASSETS_PATH=/home/you/dev/oa/packages/cibul-templates/dist

OA_SUPERADMIN_UIDS=75052324,99999999

# Certificate used to sign client certificates for
# accessing restricted ressources. Leave empty if local dev
CLIENT_SSL_CERT=

# Swap if client ssl is to be used to access remote ressource
CLIENT_SSL_NGINX_CONF=
#CLIENT_SSL_NGINX_CONF=ssl_client_certificate /ssl/client.crt; ssl_verify_client on;

TOP_DOMAIN=openagenda.com

DEPLOY_API_NGINX_PROXY=1
DEPLOY_MCP_NGINX_PROXY=1
DEV_DOC_HOMEPAGE=https://developers.openagenda.com

# If online dev, certs can be generated using letsencrypt
# SITE_SSL_CERT=/etc/letsencrypt/live/dev.domain/fullchain.pem
# SITE_SSL_KEY=/etc/letsencrypt/live/dev.domain/privkey.pem

# If local dev, use certs generated through devinstaller
SITE_SSL_CA=/pathto/oa/docker/devinstaller/ssl/certs/ca.crt
SITE_SSL_CERT=/pathto/oa/docker/devinstaller/ssl/domains/d.openagenda.com.crt
SITE_SSL_KEY=/pathto/oa/docker/devinstaller/ssl/domains/d.openagenda.com.key
API_SSL_CERT=/pathto/oa/docker/devinstaller/ssl/domains/dapi.openagenda.com.crt
API_SSL_KEY=/pathto/oa/docker/devinstaller/ssl/domains/dapi.openagenda.com.key

# MCP HTTP server — its own subdomain. The protocol endpoint is POST /mcp and
# the root serves a landing page. The devinstaller generates the cert from OA_MCP_DOMAIN.
OA_MCP_DOMAIN=dmcp.openagenda.com
OA_MCP_SSL_CERT=/pathto/oa/docker/devinstaller/ssl/domains/dmcp.openagenda.com.crt
OA_MCP_SSL_KEY=/pathto/oa/docker/devinstaller/ssl/domains/dmcp.openagenda.com.key
# OAuth resource-server config for the mcp container. Issuer/resource are the
# PUBLIC identifiers a token's iss/aud must match; JWKS + the v3 API are reached
# over the internal docker network (overridable). The HTTP server is
# delegation-only — it relays each caller's OWN OAuth token to the v3 API, so
# there is NO shared API key here (a key is the self-hosted stdio model only).
OA_MCP_OAUTH_ISSUER=https://d.openagenda.com/api/auth
OA_MCP_OAUTH_JWKS_URL=http://node:8903/api/auth/jwks
# The `/mcp` path IS the resource id / token audience (it must match the endpoint
# clients connect to, byte-for-byte). Must end in /mcp; do not use the bare origin.
OA_MCP_RESOURCE_URL=https://dmcp.openagenda.com/mcp
OA_MCP_BASE_URL=http://node:8902/v3
# O2.5 token-exchange (RFC 8693). The MCP's confidential-client secret (client_id
# `mcp`), shared with the node (auth) container's registry: setting it ENABLES
# /oauth2/token-exchange, so the MCP swaps each caller's aud=mcp token for a short
# aud=api token before the sandbox (the full grant never reaches executed code).
# The v3 resource id (aud=api) derives from API_ROOT (+ /v3), nothing else to set.
# Generate the secret: `openssl rand -hex 32`.
OA_MCP_EXCHANGE_SECRET=

# Ensure there is an empty folder at the specified path. Will be used by the mysql container
MYSQL_CONTAINER_DATA_PATH=/home/you/containers-data/mysql
MYSQL_DUMP_FILE_PATH=/pathtothe/oa.dump

# MySQL server on Docker
MYSQL_SECURE_TRANSPORT=ON

# MySQL client credentials
MYSQL_HOST=mysql
MYSQL_USER=root
MYSQL_PASSWORD=grut
MYSQL_DATABASE=oadev
MYSQL_SSL_VERIFY=1
MYSQL_SSL_CA=/home/you/containers-data/mysql/client-ca.pem
MYSQL_SSL_CERT=/home/you/containers-data/mysql/client-cert.pem
MYSQL_SSL_KEY=/home/you/containers-data/mysql/client-key.pem

# Redis docker host is "redis". Leave as is.
REDIS_PORT=6379
REDIS_HOST=redis

# Amazon Web Services settings
AWS_KEY=
AWS_SECRET=
AWS_REGION=
AWS_MAIN_BUCKET=
AWS_MAIN_PATH=

# Uppy companion session secret — signs upload/session tokens.
# Generate: `openssl rand -hex 32`
UPPY_SECRET=

S3_ASSETS_PATH=https://cdn.openagenda.com

NEXT_API_INTERNAL_BASE_URL=http://localhost:8903
NEXT_PUBLIC_ASSET_PREFIX=

# Use only if remote Elasticsearch is to be used
#DEPLOY_ES_NGINX_PROXY=1
ES_HOST=es7
ES_DOMAIN=
ES_SSL_CERT=
ES_SSL_KEY=

# Use to access local db with phpmyadmin
#DEPLOY_PMA_NGINX_PROXY=1
PMA_HOST=
PMA_SSL_CERT=
PMA_SSL_KEY=

# Mail configuration
MAIL_PORT=1025
MAIL_HOST=mailpit

# Use to access mailpit
#DEPLOY_MAILPIT_NGINX_PROXY=1
MAILPIT_DOMAIN=
MAILPIT_SSL_CERT=
MAILPIT_SSL_KEY=

# Use to access elasticHQ
#DEPLOY_ELASTICHQ_NGINX_PROXY=1
ELASTICHQ_DOMAIN=
ELASTICHQ_SSL_CERT=
ELASTICHQ_SSL_KEY=
ELASTICHQ_CLIENT_URL=
ELASTICHQ_CLIENT_KEY=
ELASTICHQ_CLIENT_CERT=

AGENDA_SEARCH_RECENT_THRESHOLD_DAYS=14
# GOOGLE_ANALYTICS_ID=
# GOOGLE_ANALYTICS_EMBED_ID=
# MATOMO_CLOUD_ID=

# OpenCage for geocoding
OPENCAGE_KEY=

# Get oembed content
IFRAMELY_KEY=

# for users wishing to subscribe to the newsletter
# MAILJET_KEY=
# MAILJET_SECRET=
# MAILJET_CONTACTS_LIST_ID=

MAP_TILES=https://a.tile.openstreetmap.org/{z}/{x}/{y}.png
STATIC_MAP_TILES=

OA_AUTH_SECRET=

# comma separated keys
OA_SESSION_KEYS=
OA_SESSION_SECRET=

#authentication
OA_OAUTH_GOOGLE_ID=
OA_OAUTH_GOOGLE_SECRET=
OA_FACEBOOK_ID=
OA_FACEBOOK_SECRET=
# Comma-separated client_ids treated as verified first-party OAuth clients
# (drops the "unverified app" warning on the consent screen; does NOT skip
# consent). Server-only, read by @openagenda/next. e.g. NEXT_VERIFIED_OAUTH_CLIENT_IDS=oa-rsvp
NEXT_VERIFIED_OAUTH_CLIENT_IDS=

OA_AGENDA_SEARCH_ALIAS=agendas

DOMAIN=openagenda.com
ROOT=https://openagenda.com
API_DOMAIN=api.openagenda.com
API_ROOT=https://api.openagenda.com

OA_DISCORD_TOKEN=
OA_DISCORD_CHANNEL=

CRISP_WEBSITE_ID=

OA_DETECT_LOCATION_DUPLICATES=1
OA_DETECT_LOCATION_DUPLICATES_IGNORED_SET_UIDS=1
OA_DETECT_LOCATION_DUPLICATES_IGNORED_AGENDA_UIDS=2
OA_DETECT_LOCATION_DUPLICATES_SLEEP=1000

FONTAWESOME_NPM_AUTH_TOKEN=

PASS_CULTURE_KEY=
PASS_CULTURE_API=
PASS_CULTURE_OFFER_LINK=
PASS_CULTURE_OFFER_EDIT_LINK=

# Server
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
STRAPI_ADMIN_API_PORT=5173

# Secrets
STRAPI_APP_KEYS=
STRAPI_API_TOKEN_SALT=
STRAPI_ADMIN_JWT_SECRET=
STRAPI_TRANSFER_TOKEN=
STRAPI_TRANSFER_TOKEN_SALT=
STRAPI_S3_ROOT_PATH=

# Database
STRAPI_DATABASE_CLIENT=sqlite
STRAPI_DATABASE_SSL=false
STRAPI_DATABASE_FILENAME=/home/you/containers-data/strapi.db
STRAPI_JWT_SECRET=

# Proxy
STRAPI_DOMAIN=strapi.local

STRAPI_SSL=1
