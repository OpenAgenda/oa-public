STRAPI_SSL_KEY=/pathto/oa/docker/devinstaller/ssl/domains/strapi.local.key
STRAPI_API_AUTH_TOKEN=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy-agent:4318
