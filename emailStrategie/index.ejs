<div class="header">
  <h2>EmailStrategie</h2>
</div>
<section>

  <p><%- __( 'The agenda is linked with the EmailStrategie account %account%', { 
    '%account%': '<strong>' + accountName + '</strong>' 
  } ) %></p>

  <% if ( state ) { %>
    <a class="url" href="<%= genUrl( 'emailStrategieShow', { slug: agenda.slug } ) %>"><strong><%= __( state ) %></strong></a> &rarr; <a class="url" href="<%= genUrl( 'emailStrategieShow', { slug: agenda.slug } ) %>"><%= __( 'refresh' ) %></a>
  <% } else if ( list ) { %>
    <p><%- __( 'Total events currently in EmailStrategie list: %count%', { '%count%' : '<strong>' + emailStrategieCount + '</strong>' } ) %></p>
  <% } %>

  <% if ( error ) { %>
    <span class="error"><%= __( error ) %></span>
  <% } %>
</section>

<section>

  <form class="cform" method="post" action="<%= genUrl( 'emailStrategieSync', { slug: agenda.slug }) %>">
    <ul>
      <li>
        <label for="fields"><strong>1. <%= __( 'Select the fields to include in the export') %></strong></label>
      </li>
      <li><ul class="line">
<% fields.forEach( function( f ) { %>
        <li>
          <input type="checkbox" name="fields[<%= f.name %>]" <% if ( f.checked ) { %>checked<% } %>/>
          <label for="fields[<%= f.name %>]"><%= f.name %></label>
        </li>
<% }) %>
      </ul></li>
      <li>
        <label for="fields"><strong>2. <%= __( 'Send your selection to EmailStrategie') %></strong></label>
      </li>
      <li><ul class="line">
        <li>
          <button class="button blue" type="submit"><%= __( 'Push events' ) %></button>
        </li>
        <li style="float:right;">
          <a href="<%= genUrl( 'emailStrategieUnlink', { slug: agenda.slug } ) %>" class="button red"><%= __( 'Unlink' ) %></a>
        </li>
      </ul></li>
    </ul>
  </form>

</section>