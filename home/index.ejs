<form method="get" action="<%= genUrl( 'home' )  %>">
	<% if ( reviews.length ) { %>
	  <select name="slug">
	  <% for(var key in reviews ) { %>
		<option value="<%= reviews[key].slug%>" <% if (reviews[key].slug == review.slug) { %>selected<% }%>><%= reviews[key].title %> </option>
	  <% } %>
	  </select>
	  <button type="submit">Ok</button>
	<% } else { %>
	<p> <%= __('No reviews found') %> </p>
	<% } %>
</form>

<div>
    <h1> <%= review.title %> </h1>
</div>

<% include ../general/pages %>

<% if (events.length) { %>
<ul class="glist">
<% for(var key in events) { %>
  <li>
    <span class="title"><%= events[key].title.fr %></span>
  </li>
</ul>
<% } %>
<% } else { %>
  <p><%= __('Your agenda does not have any events on display.') %></p>
<% } %>

<% include ../general/pages %>