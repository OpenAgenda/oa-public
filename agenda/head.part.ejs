<header id="header" <% if ( agenda.theme ) { %> style="background-image:url(<%= _i( agenda.theme.image ) %>)" <% } %>>
<% if ( agenda.theme ) { %>
  <div class="layer"></div>
<% } %>
  <div class="container profile<% if ( !agenda.theme ) { %> notheme <% } %>">
    <div class="row"><!--
      --><div class="col-sm-2 avatar-container">
<% if ( agenda.image ) { %>
      <a href="<%= genUrl( 'agendaShow', { slug: agenda.slug } ) %>">
        <img class="avatar" src="<%= _i( agenda.image ) %>" alt="<%= agenda.title %>">
      </a>
<% } %>
      </div><!--
      --><div class="col-sm-6 title-container">
        <a href="<%= genUrl( 'agendaShow', { slug: agenda.slug } ) %>">
          <h1><%= agenda.title %></h1>
          <p><%- _txt.setLinks( agenda.description ) %></p>
        </a>
<% if ( agenda.url ) { %>
        <p><a target="_blank" href="<%= agenda.url %>"><%= agenda.url %></a></p>
<% } %>
      </div><% if ( includeActionLinks ) { %><!--
<% include ./actionLinks.part.ejs %>
    --><% } %></div>
  </div>
</header>