--><div class="col-sm-3 action-container">
  <p>
    <a class="btn btn-success js_use_search" href="<%= agenda.importUri %>" rel="nofollow">
      <i class="fa fa-share-alt"></i>
      <%= __( 'Export' ) %>
    </a>
  </p>
  <p class="share"><%= __('Share') %>&nbsp;:
    <%- _sl.fb( { title: agenda.title, url: genUrl( 'agendaShow', { slug: agenda.slug }, { abs: true } ) } ) %>
    <%- _sl.tw( { title: agenda.title, url: genUrl( 'agendaShow', { slug: agenda.slug }, { abs: true } ) } ) %>
    <%- _sl.gp( { title: agenda.title, url: genUrl( 'agendaShow', { slug: agenda.slug }, { abs: true } ) } ) %>
    <%- _sl.li( { title: agenda.title, url: genUrl( 'agendaShow', { slug: agenda.slug }, { abs: true } ) } ) %>
  </p>
<% if ( agenda.isEmpty ) { %>
  <p>
    <a href="<%= genUrl( 'conversationAgendaContact', { 
      uid: agenda.uid, 
      redirect: _r({ module: 'review', action: 'show', 'slug': agenda.slug }) 
    }) %>" rel="nofollow"><%= __('Contact the administrator of this agenda') %></a>
  </p>
<% } %>
</div><!--