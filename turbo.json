{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["NPM_TOKEN", "FONTAWESOME_NPM_AUTH_TOKEN"],
  "tasks": {
    "prepack": {
      "dependsOn": ["^prepack"],
      "env": [
        "NODE_ENV",
        "CDN",
        "S3_ASSETS_BUCKET",
        "S3_ENDPOINT",
        "S3_REGION",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY"
      ],
      "outputs": ["build/**", "dist/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/admin-agendas#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["components/lib/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/agenda-docx#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["client/build/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/agenda-portal#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["assets/js/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/bs-templates#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["compiled/*.scss"],
      "outputLogs": "new-only"
    },
    "@openagenda/cibul-templates#prepack": {
      "dependsOn": ["^@openagenda/cibul-templates#build:dev"]
    },
    "@openagenda/cibul-templates#build:dev": {
      "dependsOn": ["^prepack"],
      "outputs": ["build/**", "dist/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/common-labels#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["build/**", "locales-compiled/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/form-schemas#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["client/build/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/legacy#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["embeds/app/dist/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/network-apps#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["client/dist/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/next#build": {
      "dependsOn": ["^prepack"],
      "outputs": [".next/**", "!.next/cache/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/sdk-js#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["esm/**", "lib/**"],
      "outputLogs": "new-only"
    },
    "@openagenda/validators#prepack": {
      "dependsOn": ["^prepack"],
      "outputs": [
        "lib/*.js",
        "lib/*.js.map",
        "schema/*.js",
        "schema/*.js.map",
        "*.js",
        "*.js.map"
      ],
      "outputLogs": "new-only"
    }
  }
}
