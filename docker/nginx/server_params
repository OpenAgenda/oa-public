# /:first/settings — the App Router user settings page. Matches any first
# segment (locale) rather than enumerating locales, so adding a locale needs no
# nginx edit. This is safe because the legacy per-agenda /:agendaSlug/settings
# route no longer exists (it 404s; real agenda settings live under
# /:agendaSlug/admin/settings/...), so there is no /X/settings to send to cibul.
# Must come before the /:agendaSlug/... catch-all below. A non-locale slug here
# (e.g. /some-agenda/settings) still resolves to a 404 via Next.
#
# The bare (no-locale) /settings and /settings/... paths are deliberately not
# matched here (this rule needs a segment before "settings"); they fall through
# to the default `location /` -> Next, whose proxy then 307s them to
# /:locale/settings. So no separate bare-/settings block is needed.
location ~ ^/[^/]+/settings(|/.+)$ {
  include conf.d/nextjs_params;
}

