##########################################################
#             SF1.4 - SPECIFIC PREFIXED
# /videos, /surveys, /prezis, /sitemap.xml, /change-language
# /securesignin, /fbsignin, /howto
# /termsofuse, /404

location ~ ^/(frontend_dev.php|)(videos|surveys|sitemap|change-language|securesignin|fbsignin|howto|termsofuse|404|captcha) {
  try_files $uri $uri/ /index.php$uri?$args;
  include conf.d/php_params;
}

# /preview, /email, /ical, /calendarexport, /remove
# /api, /publish, /unpublish, /linktwitter, /password_regenerate
location ~ ^/(frontend_dev.php|)(preview|email|ical|calendarexport|remove|api|publish|unpublish|linktwitter|unlinktwitter|password_regenerate) {
  try_files $uri $uri/ /index.php$uri?$args;
  include conf.d/php_params;
}

# /imageupload, imageremove, myagenda, programarticle, submit, cred, authlostpassword, authlostpasswordsubmit
location ~ ^/(frontend_dev.php|)(imageupload|imageremove|myagenda|programarticle$|submit|authlostpassword|authlostpasswordsubmit) {
  try_files $uri $uri/ /index.php$uri?$args;
  include conf.d/php_params;
}

# /event, /embed, /oa, /messages, /auth, /account, /invitation, /agenda
location ~ ^/(frontend_dev.php|)(event[^s][/|$]|embed|messages|auth(/|$)|account|invitation|agenda[/|$]|agendas[/|$]|program[/|$]) {
  try_files $uri $uri/ /index.php$uri?$args;
  include conf.d/php_params;
}

# legacy newsletter interface
location ~ ^/[^/]+/admin/newsletter(^s) {
  try_files $uri $uri/ /index.php$uri?$args;
  include conf.d/php_params;
}

# categories administration
location ~ ^/[^/]+/admin/categories/[^/]+/remove {
  try_files $uri $uri/ /index.php$uri?$args;
  include conf.d/php_params;
}


