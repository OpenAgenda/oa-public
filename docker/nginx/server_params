##########################################################
#             STATIC FILES

location /_next {
  include conf.d/nextjs_params;
}

location = /js/outdated-browser.js {
  include conf.d/nextjs_params;
}

location = /css/outdated-browser.css {
  include conf.d/nextjs_params;
}

# dynamic scripts
location ~ ^/js/(matomo|crisp)\.js$ {
  include conf.d/nodejs_params;
}

# cibul-templates/dist
location ~ ^/(css|fonts|images|js) {
  add_header Access-Control-Allow-Origin *;
  include conf.d/static_params;
}

location ~ /\.ht {
  deny all;
}

location = /robots.txt {
  return 200 "User-agent: *\nDisallow:";
}

location = /favicon.ico {
  include conf.d/static_params;
}



##########################################################
# CLOSED STUFF

location ~ ^/legacy(|/.+)$ {
  return 403 "Nope.";
}



##########################################################
#            REDIRECTIONS

# /event/:slugOrUid -> /events/:slugOrUid
location ~ ^/event/[^/]+$ {
  rewrite ^/event/([^/]+) /events/$2 permanent;
  return 403;
}

# /:agenda/event/:slugOrUid -> /:agenda/events/:slugOrUid
location ~ ^/[^/]+/event/[^/]+$ {
  rewrite ^/([^/]+)/event/([^/]+) /$2/events/$3 permanent;
  return 403;
}

# /:agendaSlug/event/:eventSlug/:lang
location ~ ^/[^/]+/event/[^/]+/(fr|en|de|es|it|br)$ {
  rewrite ^/([^/]+)/event/([^/]+)/(fr|en|de|es|it|br)$ /$2/events/$3?lang=$4 permanent;
  return 403;
}

# /:agendaSlug/:lang
location ~ ^/[^/]+/(fr|en|de|es|it|br)$ {
  rewrite ^/([^/]+)/(fr|en|de|es|it|br)$ /$2?lang=$3 permanent;
  return 403;
}



##########################################################
#            NEXT SPECIFIC ROUTES

location /api/monit {
  include conf.d/nextjs_params;
}



