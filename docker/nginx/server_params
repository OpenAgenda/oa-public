set $client_ip $remote_addr;

error_page  403  http://s3.eu-central-1.amazonaws.com/oastatic/403.html;

if ($http_x_forwarded_for) {
  set $client_ip $http_x_forwarded_for;
}

root /cibul-symfony/web;

gzip on;
gzip_types text/plain text/css application/json application/x-javascript text/xml application/xml application/xml+rss text/javascript;

server_tokens off;
client_max_body_size 20m;

##########################################################
#             STATIC FILES

location ~ ^/dist {
  include conf.d/nodejs_params;
}

location ~ \.(js|png|html|svg|ttf|woff|gif|ejs|ico|css)$ {
  root /static;
}

location /fonts {
  add_header Access-Control-Allow-Origin *;
  root /static;
}

location ~^/js/ {
  root /static;
}

location ~ /\.ht {
  deny all;
}

location = /robots.txt {
  return 200 "User-agent: *\nDisallow:";
}

location = /favicon.ico {
  root /static;
}



##########################################################
# CLOSED STUFF

location /legacy {
  return 403 "Nope.";
}


