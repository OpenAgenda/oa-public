{
  "name": "@openagenda/api-client",
  "version": "0.2.0",
  "description": "OpenAgenda v3 API client — generated from @openagenda/api-spec via Hey API (typed SDK + zod validators). Source of truth for the MCP's oa client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa-public.git"
  },
  "homepage": "https://github.com/OpenAgenda/oa-public",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "generate:check": "yarn generate && git diff --exit-code -- src/generated",
    "build": "tsdown",
    "prepack": "yarn generate && yarn build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "ky": "^1.14.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.3",
    "@openagenda/api-spec": "^0.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.3"
  }
}
