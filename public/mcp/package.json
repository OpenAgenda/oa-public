{
  "name": "@openagenda/mcp",
  "version": "1.0.0",
  "description": "OpenAgenda v3 MCP server — code-mode tools over the v3 API, with a pluggable sandbox executor",
  "license": "MIT",
  "mcpName": "com.openagenda/mcp",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa-public.git"
  },
  "homepage": "https://mcp.openagenda.com",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "openagenda-mcp": "src/index.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "start": "yarn build && node src/index.js",
    "smoke": "yarn build && node scripts/smoke.js",
    "smoke:oauth": "node scripts/smoke-oauth.js",
    "build": "tsdown",
    "check": "tsc --noEmit",
    "prepack": "yarn build",
    "test": "yarn build && NODE_OPTIONS=\"--experimental-vm-modules\" jest --runInBand --forceExit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openagenda/api-spec": "^0.1.0",
    "@openagenda/logs": "^1.1.10",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "express": "^4.18.2",
    "jose": "^6.2.3",
    "minisearch": "^7.2.0",
    "yaml": "^2.4.5",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "microsandbox": "^0.5.4"
  },
  "devDependencies": {
    "@openagenda/api-client": "^0.1.0",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@types/node": "^22.0.0",
    "jest": "^30.4.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.3"
  }
}
