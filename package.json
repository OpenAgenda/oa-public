{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "prepack": "lerna link && lerna run --stream prepack",
    "start": "yarn workspace cibul-node start",
    "dev": "concurrently -n \"node,ria\" \"yarn workspace cibul-node watch\" \"yarn workspace @openagenda/react-integration-app dev\"",
    "mails-editor": "yarn workspace cibul-node mails-editor",
    "test": "yarn workspaces foreach -tv run test --colors",
    "commit": "git-cz",
    "release": "lerna publish"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lerna run lint-staged --concurrency 1 --stream --since HEAD --exclude-dependents",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": "@openagenda/cz-conventional-changelog"
    }
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "installConfig": {
    "pnp": true
  },
  "resolutions": {
    "final-form": "4.20.1",
    "react": "16.13.0",
    "react-dom": "16.13.0",
    "react-hot-loader": "4.12.20"
  },
  "dependencies": {
    "mime": "^2.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.10.4",
    "@babel/runtime-corejs3": "^7.10.4",
    "@commitlint/cli": "^9.1.1",
    "@commitlint/config-conventional": "^9.1.1",
    "@commitlint/config-lerna-scopes": "^9.1.1",
    "@commitlint/load": "^9.1.1",
    "@openagenda/babel-preset": "^1.2.0",
    "@openagenda/cz-conventional-changelog": "^3.2.1",
    "codecov": "^3.6.2",
    "commitizen": "^4.1.2",
    "concurrently": "^5.2.0",
    "conventional-changelog-conventionalcommits": "^4.3.0",
    "core-js": "^3.6.5",
    "husky": "^4.2.1",
    "jest": "^26.1.0",
    "lerna": "^3.22.1",
    "regenerator-runtime": "^0.13.5"
  },
  "dependenciesMeta": {
    "webpack-dev-server": {
      "unplugged": true
    }
  }
}
