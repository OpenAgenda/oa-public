{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "bs": "lerna bootstrap",
    "install": "lerna link",
    "prepublish": "lerna run prepublish",
    "start": "yarn workspace cibulNode start",
    "release": "lerna publish",
    "mails-editor": "yarn workspace cibulNode mails-editor",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "**/react",
      "**/react/**",
      "**/react-dom",
      "**/react-dom/**",
      "**/react-redux",
      "**/react-redux/**",
      "**/redux-connect",
      "**/redux-connect/**",
      "**/redux-form",
      "**/redux-form/**",
      "**/prettier-eslint",
      "**/prettier-eslint-cli",
      "**/babel-core",
      "**/babel-register",
      "**/@storybook/**"
    ]
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.3.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.2.2",
    "codecov": "^3.1.0",
    "husky": "^2.4.1",
    "jest": "^23.6.0",
    "lerna": "^2.11.0",
    "react": "^16.7.0",
    "react-dom": "^16.7.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lerna run lint-staged"
    }
  }
}
