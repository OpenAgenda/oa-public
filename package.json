{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "bs": "lerna bootstrap",
    "install": "lerna link",
    "prepublish": "lerna run prepublish",
    "start": "yarn workspace cibulNode start",
    "release": "lerna publish",
    "mails-editor": "yarn workspace cibulNode mails-editor",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "resolutions": {
    "**/final-form": "4.18.5",
    "**/react": "16.9.0",
    "**/react-dom": "16.9.0"
  },
  "devDependencies": {
    "@babel/runtime-corejs3": "^7.6.0",
    "codecov": "^3.1.0",
    "core-js": "^3.2.1",
    "husky": "^3.0.0",
    "jest": "^24.9.0",
    "lerna": "^2.11.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lerna run lint-staged"
    }
  }
}
