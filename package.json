{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "postinstall": "lerna link && yarn workspaces foreach -ptv run prepack",
    "start": "yarn workspace cibulNode start",
    "release": "lerna publish",
    "mails-editor": "yarn workspace cibulNode mails-editor",
    "test": "yarn workspaces foreach -tv run test --colors"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "installConfig": {
    "pnp": true
  },
  "resolutions": {
    "final-form": "4.18.6",
    "react": "16.12.0",
    "react-dom": "16.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.4",
    "@babel/runtime-corejs3": "^7.8.4",
    "@openagenda/babel-preset": "^1.2.0",
    "codecov": "^3.6.2",
    "core-js": "^3.6.4",
    "husky": "^4.2.1",
    "jest": "^25.1.0",
    "lerna": "^3.20.2",
    "regenerator-runtime": "^0.13.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lerna run lint-staged --concurrency 1 --stream --since HEAD"
    }
  },
  "dependenciesMeta": {
    "webpack-dev-server": {
      "unplugged": true
    }
  }
}
