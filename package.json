{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "See license.txt",
  "private": true,
  "scripts": {
    "install": "lerna link",
    "bs": "lerna bootstrap",
    "commitmsg": "commitlint -e $GIT_PARAMS"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "**/react",
      "**/react-dom",
      "**/redbox-react",
      "**/create-react-class",
      "**/create-react-class/**",
      "**/rc-switch",
      "**/rc-switch/**",
      "**/font-awesome",
      "**/uppy",
      "**/uppy/**",
      "**/uppy-server",
      "**/uppy-server/**",
      "**/fetch",
      "**/fetch/**",
      "**/superagent",
      "**/superagent/**"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^6.1.3",
    "@commitlint/config-conventional": "^6.1.3",
    "@commitlint/config-lerna-scopes": "^6.1.3",
    "husky": "^0.14.3",
    "lerna": "^2.9.0"
  }
}
