{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "prepack": "lerna link && lerna run --stream prepack",
    "start": "yarn workspace cibul-node start",
    "mails-editor": "yarn workspace cibul-node mails-editor",
    "test": "yarn workspaces foreach -tv run test --colors",
    "commit": "git-cz",
    "release": "lerna publish",
    "lint-staged": "lerna run lint-staged --concurrency 1 --stream --since HEAD --exclude-dependents",
    "stash-unstaged": "git stash save -k 'pre-linting-stash' >> /dev/null",
    "pop-stash": "git stash && git stash pop \"stash@{1}\" && git read-tree stash && git stash drop"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn stash-unstaged && yarn lint-staged || (yarn run pop-stash >> /dev/null && exit 1)",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": "@openagenda/cz-conventional-changelog"
    }
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "installConfig": {
    "pnp": true
  },
  "resolutions": {
    "final-form": "4.19.1",
    "react": "16.13.0",
    "react-dom": "16.13.0",
    "react-hot-loader": "4.12.20",
    "conventional-changelog-conventionalcommits@^4.2.3": "patch:conventional-changelog-conventionalcommits@4.2.3#./patches/conventional-changelog-conventionalcommits.patch"
  },
  "dependencies": {
    "mime": "^2.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.8.4",
    "@babel/runtime-corejs3": "^7.8.4",
    "@commitlint/cli": "^8.3.5",
    "@commitlint/config-conventional": "^8.3.4",
    "@commitlint/config-lerna-scopes": "^8.3.4",
    "@commitlint/load": "^8.3.5",
    "@openagenda/babel-preset": "^1.2.0",
    "@openagenda/cz-conventional-changelog": "^3.2.1",
    "codecov": "^3.6.2",
    "commitizen": "^4.0.3",
    "conventional-changelog-conventionalcommits": "^4.2.3",
    "core-js": "^3.6.4",
    "husky": "^4.2.1",
    "jest": "^26.0.1",
    "lerna": "^3.20.2",
    "regenerator-runtime": "^0.13.5"
  },
  "dependenciesMeta": {
    "webpack-dev-server": {
      "unplugged": true
    }
  }
}
