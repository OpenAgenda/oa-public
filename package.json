{
  "name": "oa",
  "version": "1.0.2",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://github.com/OpenAgenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "postinstall": "husky public/.husky",
    "prepack": "yarn workspaces foreach -Apv --topological-dev run prepack",
    "start": "yarn workspace cibul-node start",
    "watch": "yarn workspace cibul-node watch",
    "dev": "concurrently -n \"node,ria\" \"yarn workspace cibul-node watch\" \"yarn workspace @openagenda/react-integration-app dev\"",
    "mails-editor": "yarn workspace cibul-node mails-editor",
    "test": "yarn workspaces foreach -Atv run test --colors",
    "commit": "git-cz",
    "release": "./scripts/release/00-release.sh",
    "pull-public": "git subtree pull --prefix public oa-public",
    "push-public": "git subtree push --prefix public --rejoin oa-public",
    "changeset:publish": "changeset publish && node scripts/sync-releases-to-public.sh",
    "changeset:version": "changeset version"
  },
  "config": {
    "commitizen": {
      "path": "@openagenda/cz-conventional-changelog"
    }
  },
  "browserslist": [
    "extends @openagenda/browserslist-config"
  ],
  "workspaces": [
    "packages/*",
    "public",
    "public/*"
  ],
  "packageManager": "yarn@4.5.3",
  "resolutions": {
    "eslint-import-resolver-typescript": "3.5.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "jest-runtime@npm:^29.7.0": "patch:jest-runtime@npm%3A29.7.0#~/public/.yarn/patches/jest-runtime-npm-29.7.0-120fa64128.patch"
  },
  "dependencies": {
    "@openagenda/intl": "workspace:^",
    "@strapi/strapi": "^5.13.1",
    "browserslist": "^4.20.0",
    "mime": "^2.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/runtime-corejs3": "^7.23.2",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@commitlint/cli": "^17.6.5",
    "@commitlint/config-conventional": "^17.6.5",
    "@crowdin/crowdin-api-client": "^1.33.1",
    "@openagenda/babel-preset": "^1.5.0",
    "@openagenda/cz-conventional-changelog": "^3.2.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "codecov": "^3.6.2",
    "commitizen": "^4.3.0",
    "concurrently": "^6.0.2",
    "conventional-changelog-conventionalcommits": "^4.5.0",
    "core-js": "^3.29.1",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jszip": "^3.9.1",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "regenerator-runtime": "^0.13.8",
    "tmp": "^0.2.1",
    "turbo": "^2.5.4"
  },
  "dependenciesMeta": {
    "webpack-dev-server": {
      "unplugged": true
    }
  }
}
