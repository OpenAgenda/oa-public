{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://bitbucket.org/openagenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "bs": "lerna bootstrap",
    "install": "lerna link",
    "prepublish": "lerna run prepublish",
    "start": "yarn workspace cibulNode start",
    "release": "lerna publish",
    "mails-editor": "yarn workspace cibulNode mails-editor",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "**/react",
      "**/react/**",
      "**/react-dom",
      "**/react-dom/**",
      "**/prettier-eslint",
      "**/prettier-eslint-cli",
      "**/babel-core",
      "**/babel-register"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.1.5",
    "@babel/core": "^7.1.6",
    "codecov": "^3.1.0",
    "jest": "^23.6.0",
    "lerna": "^2.11.0",
    "react": "^16.6.1",
    "react-dom": "^16.6.1"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.2.0"
  }
}
