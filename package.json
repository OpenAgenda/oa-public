{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://github.com/OpenAgenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "postinstall": "husky install public/.husky",
    "prepack": "yarn workspaces foreach --topological-dev --interlaced --verbose run prepack",
    "start": "yarn workspace cibul-node start",
    "watch": "yarn workspace cibul-node watch",
    "dev": "concurrently -n \"node,ria\" \"yarn workspace cibul-node watch\" \"yarn workspace @openagenda/react-integration-app dev\"",
    "mails-editor": "yarn workspace cibul-node mails-editor",
    "test": "yarn workspaces foreach -tv run test --colors",
    "commit": "git-cz",
    "release": "./scripts/release/00-release.sh",
    "pull-public": "git subtree pull --prefix public --squash oa-public",
    "push-public": "git subtree push --prefix public oa-public"
  },
  "config": {
    "commitizen": {
      "path": "@openagenda/cz-conventional-changelog"
    }
  },
  "browserslist": [
    "extends @openagenda/browserslist-config"
  ],
  "workspaces": [
    "packages/*",
    "public",
    "public/*"
  ],
  "packageManager": "yarn@3.2.4",
  "resolutions": {
    "@rushstack/eslint-patch@1.2.0": "patch:@rushstack/eslint-patch@npm:1.2.0#public/.yarn/patches/@rushstack-eslint-patch-npm-1.2.0-917f402e4e",
    "@types/react": "18.0.28",
    "eslint-import-resolver-typescript": "3.5.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "dependencies": {
    "browserslist": "^4.20.0",
    "mime": "^2.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/runtime-corejs3": "^7.21.0",
    "@commitlint/cli": "^17.6.5",
    "@commitlint/config-conventional": "^17.6.5",
    "@crowdin/crowdin-api-client": "^1.16.0",
    "@openagenda/babel-preset": "^1.5.0",
    "@openagenda/cz-conventional-changelog": "^3.2.1",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "codecov": "^3.6.2",
    "commitizen": "^4.1.2",
    "concurrently": "^6.0.2",
    "conventional-changelog-conventionalcommits": "^4.5.0",
    "core-js": "^3.29.1",
    "husky": "^8.0.3",
    "jest": "^28.1.2",
    "jszip": "^3.9.1",
    "regenerator-runtime": "^0.13.8",
    "tmp": "^0.2.1",
    "turbo": "^1.10.14"
  },
  "dependenciesMeta": {
    "webpack-dev-server": {
      "unplugged": true
    }
  }
}
