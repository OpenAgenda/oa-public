{
  "private": true,
  "name": "cibulTemplates",
  "version": "0.0.2",
  "description": "cibul templates library",
  "scripts": {
    "start": "nodemon --ignore build --ignore node_modules app",
    "build:dev": "better-npm-run build:dev",
    "build:prod": "better-npm-run build:prod"
