{
  "name": "oa",
  "version": "1.0.0",
  "description": "OpenAgenda monorepo",
  "main": "index.js",
  "repository": "https://github.com/OpenAgenda/oa",
  "author": "OpenAgenda Dev Team",
  "license": "SEE LICENCE IN LICENSE",
  "private": true,
  "scripts": {
    "postinstall": "git config core.hooksPath public/.husky && yarn workspace oa-public postinstall",
    "prepack": "yarn workspaces foreach --topological-dev --interlaced --verbose --parallel --jobs 2 run prepack",
    "start": "yarn workspace cibul-node start",
    "watch": "yarn workspace cibul-node watch",
    "dev": "concurrently -n \"node,ria\" \"yarn workspace cibul-node watch\" \"yarn workspace @openagenda/react-integration-app dev\"",
    "mails-editor": "yarn workspace cibul-node mails-editor",
    "test": "yarn workspaces foreach -tv run test --colors",
    "commit": "git-cz",
    "release": "./scripts/release/00-release.sh"
  },
  "config": {
    "commitizen": {
      "path": "@openagenda/cz-conventional-changelog"
    }
  },
  "browserslist": [
    "extends @openagenda/browserslist-config"
  ],
  "workspaces": [
    "packages/*",
    "public"
  ],
  "resolutions": {
    "react": "16.13.1",
    "react-dom": "16.13.1"
  },
  "dependencies": {
    "browserslist": "^4.20.0",
    "mime": "^2.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.13.16",
    "@babel/runtime-corejs3": "^7.13.17",
    "@commitlint/cli": "^12.1.1",
    "@commitlint/config-conventional": "^12.1.1",
    "@commitlint/config-lerna-scopes": "^12.1.1",
    "@openagenda/babel-preset": "^1.4.1",
    "@openagenda/cz-conventional-changelog": "^3.2.1",
    "codecov": "^3.6.2",
    "commitizen": "^4.1.2",
    "concurrently": "^6.0.2",
    "conventional-changelog-conventionalcommits": "^4.5.0",
    "core-js": "^3.10.2",
    "husky": "^5.0.4",
    "jest": "^26.1.0",
    "regenerator-runtime": "^0.13.8"
  },
  "dependenciesMeta": {
    "webpack-dev-server": {
      "unplugged": true
    }
  }
}
