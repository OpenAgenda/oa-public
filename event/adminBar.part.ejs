<div id="admin-bar" class="edge-bar js_admin_controls">
  <ul class="edge-list"><!--
<% if ( !loner ) { %>
    --><li class="edge-item w25 js_admin_item js_role_agenda_admin js_role_agenda_moderator">
      <div class="admin-nav">
        <a class="nav-link prev edge-link<% if ( adminNav && adminNav.first ) { %> inactive<% } %>" href="<%= adminNav && adminNav.first ? '#' : genUrl( 'agendaEventAdminNavigate', [ { slug: slug, nav: 'prev', admin_nav: adminNav } ] ) %>">
          <i class="fa fa-chevron-left"></i>
        </a>
        <a class="edge-link center" rel="nofollow" data-href="<%= genUrl( 'agendaAdminShow', [ adminNav, { slug: slug } ] ) %>">
          <i class="fa fa-list"></i>
          <span><%= __( 'backToDashboard' ) %></span>
        </a>
        <a class="nav-link next edge-link<% if ( adminNav && adminNav.last ) { %> inactive<% } %>" href="<%= adminNav && adminNav.last ? '#' : genUrl( 'agendaEventAdminNavigate', [ { slug: slug, nav: 'next', admin_nav: adminNav } ] ) %>">
          <i class="fa fa-chevron-right"></i>
        </a>
      </div>
    </li><!--
<% } %>  
    --><li class="edge-item js_toggle w25 js_admin_item js_role_agenda_admin js_role_agenda_moderator js_current_state_control" data-toggle="js_dropdown_menu">
      <span class="edge-selected state <%= event.currentState %>"><i class="sticker"></i><span><%= __( 'state' ) %>: <%= __( states[ event.currentState ].label ) %></span></span>
      <ul class="list-group js_dropdown_menu">  
<% for( var i in states ) { %>
<% if ( !states[ i ].hideAction ) { %>
<% if ( !loner ) { %>
        <li class="list-group-item js_admin_item <%= states[ i ].classNames %>">
          <a data-href="<%= states[ i ].type !== null ? genUrl( 'agendaEventChangeState', { slug: slug, eventSlug: event.slug, type: states[ i ].type, redirect: event.uri } ) : '#' %>" class="item bullet js_change_state_to_<%- states[ i ].type %><% if ( i !== event.currentState ) { %> active<% } %>" rel="nofollow"><%= __( states[ i ].label ) %></a>
        </li>
<% } %>
<% } %>
<% } %>
      </ul>
    </li><!--
 --><li class="edge-item w25 js_current_state display-none">
      <span class="edge-info state <%= event.currentState %>"><i class="sticker"></i><span><%= __( 'state' ) %>: <%= __( states[ event.currentState ].label ) %></span></span>
    </li><!--
    --><li class="edge-item js_admin_item js_role_event_editor w25">
      <a class="edge-link" href="<%= genUrl( loner ? 'eventEdit' : 'agendaEventEdit', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ] ) %>" rel="nofollow"><%= __( 'edit' ) %></a>
    </li><!--
    --><li class="edge-item js_admin_item js_role_event_editor js_role_agenda_admin js_toggle w25" data-toggle="js_dropdown_menu">
      <span class="edge-selected"><%= __( 'actions' ) %></span>
      <ul class="list-group js_dropdown_menu">
<% if ( !loner ) { %>
        <li class="list-group-item js_admin_item js_role_agenda_admin js_role_agenda_moderator">
<% if ( event.featured ) { %>
          <a class="item starify active" href="<%= genUrl( 'agendaEventChangeFeatured', { slug: slug, eventSlug: event.slug, type: 'notfeatured' } ) %>" rel="nofollow"><span><%= __( 'featured' ) %></span><span class="hovered"><%= __('removeFromFeatured') %></span><i class="fa fa-thumb-tack"></i><i class="fa fa-thumb-tack"></i></a>
<% } else { %>
          <a class="item starify active" href="<%= genUrl( 'agendaEventChangeFeatured', { slug: slug, eventSlug: event.slug, type: 'featured' } ) %>" rel="nofollow"><%= __('addToFeatured') %><i class="fa fa-thumb-tack-o"></i><i class="fa fa-thumb-tack"></i></a>
<% } %>      
        </li>
<% } %>
<% if ( !loner && hasOwnershipTransfer ) { %>
        <li class="list-group-item js_role_agenda_moderator js_ownership_transfer" data-res="<%= genUrl( 'eventTransfer', { slug: slug, eventSlug: event.slug } ) %>">
          <a class="item active" rel="nofollow"><%= __( 'transferOwnership' ) %></a>
        </li>
<% } %>
        <li class="list-group-item js_admin_item js_role_event_editor">
          <a class="item active" href="<%= !loner ? genUrl( 'agendaEventDuplicate', { slug: slug, eventSlug: event.slug } ) : genUrl( 'eventDuplicate', { eventSlug: event.slug } ) %>" rel="nofollow"><%= __( 'duplicate' ) %></a>
        </li>
        <li class="list-group-item js_admin_item js_role_event_editor w25">
          <a class="item active js_message_confirm" data-confirm="<%= __( 'areYouSureToDelete' ) %>" data-ok="<%= __( 'confirm' ) %>" data-cancel="<%= __( 'cancel' ) %>" href="<%= genUrl( 'eventRemove', { eventUid: event.uid, agendaUid: uid }) %>" rel="nofollow"><%= __( 'delete' ) %></a>
        </li>
      </ul>
    </li>
  </ul>
</div>