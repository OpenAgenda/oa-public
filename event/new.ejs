<header id="header">
  <div class="container">
    <div class="row">
      <div class="col-sm-12 agenda-container">
<% if ( !loner ) { %>
        <a href="<%= genUrl('agendaShow', { slug: slug }) %>">
<% if ( image ) { %>
          <img class="avatar" src="<%= _i( image ) %>" alt="<%= title %>">
<% } %>
          <%= title %>
        </a>
<% } %>
      </div>
      <div class="col-sm-12 event-container">
        <h1><%= event.title %></h1>
      </div>
    </div>
  </div>
</header>
<div id="content" class="js_page_body">
  <div class="container">
    <div class="row">
      <aside class="col-sm-4 col-aside sidebar">

        <div class="meta-container">
          <p>
            <a class="btn btn-success event-action js_import_action" href="<%= event.importUri %>">
              <i class="fa fa-plus-circle"></i><%= __('Add to my agenda') %>
            </a>
          </p>
          <p class="share">
            <%= __('Share') %>&nbsp;:
            <%- _sl.fb( { title: event.title, url: genUrl( loner ? 'eventShow' : 'agendaEventShow', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ], { abs: true } ) } ) %>
            <%- _sl.tw( { title: event.title, url:  genUrl( loner ? 'eventShow' : 'agendaEventShow', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ], { abs: true } ) } ) %>
            <%- _sl.gp( { title: event.title, url:  genUrl( loner ? 'eventShow' : 'agendaEventShow', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ], { abs: true } ) } ) %>
            <%- _sl.li( { title: event.title, url:  genUrl( loner ? 'eventShow' : 'agendaEventShow', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ], { abs: true } ) } ) %>
          </p>
<% if ( !event.isUpcoming ) { %>
          <p>
            <span class="event-action disabled">
              <i class="fa fa-history"></i> <%= __('Past event') %>
            </span>
          </p>
<% } %>
        </div>

        <div class="event-infos">
<% if ( event.ticketLink || event.pricingInfo ) { %>
          <section class="event-side">
            <h3><i class="fa fa-ticket"></i></h3>
<% if ( event.pricingInfo ) { %>
            <p><%= event.pricingInfo %></p>
<% } %>
<% if ( event.ticketLink ) { %>
            <p><a href="<%= event.ticketLink %>"><%= __('Ticketing link') %></a></p>
<% } %>
          </section>
<% } %>
          <section class="event-side">
            <h3><i class="fa fa-clock-o"></i></h3>
            <p><%= __( event.dateRange[0], _t(event.dateRange[1]) ) %></p>
          </section>

          <section class="event-side">
            <h3><i class="fa fa-map-marker"></i></h3>
            <p><%= event.placeName %></p>
            <p><%= event.address %></p>
          </section>

          <div class="event-map js_map" data-coord="<%= event.latitude %>|<%= event.longitude %>"></div>
          
        </div>
<% if ( event.agendaReferences.length > ( loner ? 0 : 1 ) ) { %>
        <div class="sharers">
          <ul><!--
<% event.agendaReferences.forEach( function( ref ) { %>
<% if ( loner || ( ref.slug !== slug ) ) { %>
            --><li>
              <a href="<%= genUrl( 'agendaShow', { slug: ref.slug } ) %>"><!--
<% if ( ref.thumbnail ) { %>
                --><img class="avatar" alt="<%= ref.title %>" src="<%= _i( ref.thumbnail ) %>"/><!--
<% } %>
                --><%= ref.title %>
              </a>
            </li><!--
<% } %>
<% }); %>
          --></ul>
        </div>
<% } %>
      
        <% include ../agenda/footer.part.ejs %>

      </aside>

      <section class="col-sm-8">
        
        <div class="event-content">
          <p class="short-description"><%= event.description %></p>
<% if ( event.languages ) { %>
          <div class="langs">
            <p><%= __('Description available in') %>&nbsp;</p>
            <ul>
<% event.languages.selection.forEach( function( lang ) { %>
<% if ( lang.label==event.languages.current ) { %>
              <li class="current"><a><%= lang.label %></a></li>
<% } else { %>
              <li><a hreflang="<%= lang %>" href="<%= lang.link %>"><%= lang.label %></a></li>
<% } %>
<% }); %>
            </ul>
          </div>
<% } %>
<% if ( event.image ) { %>
          <img  class="img-responsive" src="<%= _i( event.image ) %>">
<% } %>
          <div class="description">
            <%- _txt.nl2br( event.freeText ) %>
          </div>

<% if ( event.timings.length > 1 ) { %>
          <section class="dates">
            <h3 class="title"><%= __('Date details') %></h3>
            <ul>
<% event.timings.forEach( function( timing ) { %>
              <li class="date"><%= _t( timing.start, 'dddd Do - HH:mm' ) %></li>
<% }) %>
            </ul>
          </section>
<% } %>

        </div>
<% if ( event.owner ) { %>  
        <p class="signature"><%= __('Published by %owner%', { '%owner%' : event.owner.name } ) %></p>
<% } %>
      </section>
    </div>
  </div>

  <div id="admin-bar" class="js_admin_controls">
    <ul class="admin-list">
      <li class="admin-item">
        <a class="admin-link" href="<%= genUrl( loner ? 'eventEdit' : 'agendaEventEdit', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ] ) %>"><%= __('Edit') %></a>
      </li><!--
      --><li class="admin-item">
        <a class="admin-link js_message_confirm" data-confirm="<%= __('Are you sure you want to delete this event?') %>" data-ok="<%= __( 'Confirm' ) %>" data-cancel="<%= __( 'Cancel' ) %>" href="<%= genUrl('eventRemove', { eventSlug: event.slug }) %>" href=""><%= __('Delete') %></a>
      </li>
    </ul>
  </div>

</div>