<% if ( agenda ) { %>
<%= agenda.title %>
<% } %>

<%= event.title %>
<%= event.dateRange %>
<% if ( event.pricingInfo ) { %>
  <%= event.pricingInfo %>
<% } %>
<% if ( event.ticketLink ) { %>
<%= __( 'book' ) %>: <%= event.ticketLink %>
<% } %>

<%= event.description %>

<% event.freeText.split('\n').forEach(function(freeTextLine) { %>
<%- freeTextLine %>
<% }); %>

<%= __( 'I do not wish to receive events by email any longer' ) %> - <%= __( 'unsubscribe' ) %>: <%= genUrl( 'emailUnsubscribe', {}, { protocol: 'https://' } ) %>