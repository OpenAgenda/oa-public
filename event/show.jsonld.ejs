<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type" : "Event",
  "name" : "<%= event.title %>",
  "description" : "<%= event.description %>",
  "url" : "<%= genUrl( loner ? 'eventShow' : 'agendaEventShow', [ { eventSlug: event.slug }, loner ? {} : { slug: slug } ], { abs: true } ) %>",
<% if ( event.image ) { %>
  "image" : "<%= _i( event.image ) %>",
<% } %>
<% if ( event.timings.length ) { %>   
  "startDate" : "<%= _t( event.timings[ 0 ].start, 'YYYY-MM-DDThh:mm' ) %>",
  "endDate" : "<%= _t( event.timings[ event.timings.length - 1 ].start, 'YYYY-MM-DDThh:mm' ) %>",
  "duration" : "<%= _t.diff( event.timings[ 0 ].start, event.timings[ 0 ].end ) %>",
<% } %>
  "location" : {
    "@type" : "Place",
    "name" : "<%= event.placeName %>",
    "address" : {
      "@type" : "PostalAddress",
<% if ( event.postalCode ) { %>
      "postalCode" : "<%= event.postalCode %>",
<% } %>
<% if ( event.city ) { %>
      "addressLocality" : "<%= event.city %>",
<% } %>
<% if ( event.region ) { %>
      "addressRegion" : "<%= event.region %>",
<% } %>
      "streetAddress" : "<%= event.address %>"
    },
    "geo": {
      "@type" : "GeoCoordinates",
      "latitude" : "<%= event.latitude %>",
      "longitude" : "<%= event.longitude %>"
    }
  }
}
</script>