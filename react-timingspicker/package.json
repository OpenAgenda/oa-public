  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/OpenAgenda/oa-public.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/OpenAgenda/oa-public",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.mjs"
    },
    "./App.css": "./dist/App.css",
    "./*": {
      "import": "./dist/*.mjs"
    }
  },
  "scripts": {
    "sb": "storybook dev",
    "test": "TZ=Europe/Paris NODE_OPTIONS=\"--experimental-vm-modules\" jest --forceExit --detectOpenHandles",
    "build": "tsdown",
    "extract-messages": "oa-intl --esm",
    "prepack": "oa-intl compile --esm && yarn build"
  },
  "dependencies": {
    "@openagenda/intl": "^2.0.0",
    "@openagenda/react-shared": "^3.0.1",
    "classnames": "^2.3.1",
    "core-js": "^3.29.1",
    "date-fns": "^2.1.0",
    "final-form": "^4.20.2",
    "react-day-picker": "^7.3.0",
    "react-final-form": "^6.5.3",
    "react-icons": "^3.8.0",
    "react-intl": "^10.1.1",
    "react-modal": "^3.11.1",
    "react-select": "^5.8.3",
    "react-text-mask": "^5.4.3",
    "rrule": "^2.6.8",
    "text-mask-addons": "^3.8.0"
  },
  "devDependencies": {
    "@openagenda/eslint-config": "^2.1.0",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.2.0",
    "bootstrap": "3.3.5",
    "jest": "^29.7.0",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "storybook": "^10.2.0",
    "tsdown": "^0.22.0"
  },
  "peerDependencies": {
    "react": "^19.2.2"
  }
}
